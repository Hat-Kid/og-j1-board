(defbehavior target-compute-slopes target ((arg0 vector))
  (let ((gp-0 (new-stack-vector0)))
    (let ((a1-0 (new-stack-vector0))
          ;; og:j1-board added
          (s4-0 (vector-y-quaternion! (new 'stack-no-clear 'vector) (-> self control unknown-quaternion00)))
          (s5-0 (new 'stack-no-clear 'matrix)))
      (set! (-> a1-0 quad) (-> self control c-R-w vector 2 quad))
      (forward-up-nopitch->inv-matrix s5-0 a1-0 arg0)
      (set-vector! gp-0 0.0 0.0 1.0 1.0)
      (vector-matrix*! gp-0 gp-0 s5-0)
      (set! (-> self control unknown-float63) (- (vector-dot (-> self control surface-normal) gp-0)))
      (set! (-> self control gspot-slope-z) (- (vector-dot (-> self control gspot-normal) gp-0)))
      (set! (-> self control unknown-float61) (- (vector-dot (-> self control local-normal) gp-0)))
      ;; og:j1-board added
      (set! (-> self control ctrl-slope-z) (- (vector-dot s4-0 gp-0)))
      (set-vector! gp-0 1.0 0.0 0.0 1.0)
      (vector-matrix*! gp-0 gp-0 s5-0)
      (set! (-> self control unknown-float64) (- (vector-dot (-> self control surface-normal) gp-0)))
      (set! (-> self control gspot-slope-x) (- (vector-dot (-> self control gspot-normal) gp-0)))
      (set! (-> self control unknown-float62) (- (vector-dot (-> self control local-normal) gp-0)))
      ;; og:j1-board added
      (set! (-> self control ctrl-slope-x) (- (vector-dot s4-0 gp-0))))
    ;; og:j1-board added
    (set-vector! gp-0 1.0 0.0 0.0 1.0)
    (vector-matrix*! gp-0 gp-0 (-> self control c-R-w))
    (set! (-> self control ctrl-slope-heading)
          (vector-dot gp-0
                      (vector-flatten! (new 'stack-no-clear 'vector) (-> self control dynam gravity-normal) (-> self control local-normal)))))
  0)

(defbehavior do-rotations1 target ()

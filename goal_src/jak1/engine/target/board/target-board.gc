                             (-> self board charge-sound-id)
                             (the int (* 1024.0 (-> self board charge-progress)))
                             0
                             0
                             (sound-group sfx)
                             (the symbol (-> self control trans))))
        ((!= (-> self board charge-progress) 0.0)
         (seek! (-> self board charge-progress)
                0.0
                (* (/ 300.0 (the float (-> *TARGET_BOARD-bank* charge-jump-fade-time))) (seconds-per-frame)))
         (if (= (-> self board charge-progress) 0.0) (sound-stop (-> self board charge-sound-id)))))
      (if (and (!= (-> self board charge-progress) 0.0)
               (not (or (logtest? (-> self draw status)
                                  (draw-status hidden
                                               #| no-draw no-draw-temp no-draw-bounds no-draw-bounds2 |#
                                               ))
                        (zero? (-> self skel active-channels)))))
        (spawn (-> self board charge-part) (vector<-cspace! (new 'stack-no-clear 'vector) (-> self node-list data 47))))
      (cond
        ((and (cpad-pressed? (-> self control cpad number) circle)
              (time-elapsed? (-> self board zap-start-time)
                             (+ (-> *TARGET_BOARD-bank* zap-duration) (-> *TARGET_BOARD-bank* zap-reset-time)))
              (not (-> self control danger-mode))
              (not (logtest? (-> self state-flags) (state-flags prevent-attack)))
              (not (and (-> self next-state) (symbol-member? (-> self next-state name) '(target-board-get-on target-board-get-off))))
              (not (logtest? (-> self state-flags) (state-flags dying being-attacked grabbed))))
         (let ((pos (vector<-cspace! (new-stack-vector0) (-> self node-list data 47))))
           (sound-play "board-zap")
           (target-start-attack)
           (target-danger-set! 'board-zap #f)
           (set-time! (-> self board zap-start-time))
           (cond
             ((and (= (-> self fact eco-type) (pickup-type eco-green)) (< 0.0 (-> self fact eco-level)))
              (process-spawn part-tracker :init part-tracker-init group-board-green-eco-zap-attack -1 #f #f #f pos :to self)
              (-! (-> self fact eco-timeout) (seconds 2)))
             ((and (= (-> self fact eco-type) (pickup-type eco-red)) (< 0.0 (-> self fact eco-level)))
              ; (effect-control-method-10 (-> self skel effect) 'group-red-eco-strike-ground (ja-frame-num 0) 0)
              (process-spawn part-tracker :init part-tracker-init group-board-red-eco-zap-attack -1 #f #f #f pos :to self))
             ((and (= (-> self fact eco-type) (pickup-type eco-yellow)) (< 0.0 (-> self fact eco-level)))
              (process-spawn part-tracker :init part-tracker-init group-board-yellow-eco-zap-attack -1 #f #f #f pos :to self)
              (target-board-yellow-eco-zap-attack))
             (else (process-spawn part-tracker :init part-tracker-init group-board-zap-attack -1 #f #f #f pos :to self))))
         (target-timed-invulnerable (-> *TARGET_BOARD-bank* zap-duration) self))
        ((and (-> self control danger-mode) (time-elapsed? (-> self board zap-start-time) (-> *TARGET_BOARD-bank* zap-duration)))
         (target-danger-set! 'harmless #f)))
      (do-rotations2)
      (reverse-conversions (-> self control transv))
      (pre-collide-setup)
      (cond
        ((and (-> self next-state) (= (-> self next-state name) 'target-board-get-off))
         (seek! (-> self board cushion-offset) 0.0 (* (meters 5) (seconds-per-frame))))
        ((and (logtest? (-> self control mod-surface flags) (surface-flags jump))
              (not (logtest? (-> self control status) (cshape-moving-flags onsurf))))
         (seek! (-> self board cushion-offset)
                (lerp-scale (-> *TARGET_BOARD-bank* cushion) 0.0 (target-height-above-ground) 0.0 (meters 3))
                (* (meters 5) (seconds-per-frame))))
        ((logtest? (-> self control status) (cshape-moving-flags on-water))
         (set! (-> self water drip-wetness) 0.0)
         (seek! (-> self board cushion-offset)
                (+ (meters 0.5) (-> *TARGET_BOARD-bank* cushion))
                (* (meters 5) (seconds-per-frame))))
        (else (seek! (-> self board cushion-offset) (-> *TARGET_BOARD-bank* cushion) (* (meters 2) (seconds-per-frame)))))
      (target-board-collision)
      (if (!= (-> self control bend-speed) 0.0) (bend-gravity))
      (post-flag-setup))
    (set-time-ratios *display* (the float f30-0)))
  (ja-post)
  (joint-points)
  (do-target-gspot)
  (do-target-shadow)
  (target-powerup-process)
  (set-time! (-> self board board-time))
  (target-board-exit-check)
  (target-board-effect)
  (when (board-on-ground?)
    (vector-copy! (-> self board up-vector 1) (-> self board up-vector 0))
    (vector-copy! (-> self board up-vector 0) (-> self control local-normal))
    (if (= (-> self board roty-cum) 0.0)
      (vector-copy! (-> self board ground-on-dir) (-> self node-list data 3 bone transform fvec))))
  (none))


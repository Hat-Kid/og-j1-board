    (add-debug-vector *display-target-marks*
                      (bucket-id debug-no-zbuf)
                      (-> self control trans)
                      s5-0
                      (meters 2)
                      (new 'static 'rgba :r #xff :a #x80)))
  (add-debug-vector *display-target-marks*
                    (bucket-id debug-no-zbuf)
                    (-> self control trans)
                    (-> self control c-R-w vector 2)
                    (meters 2)
                    (new 'static 'rgba :r #xff :b #xff :a #x80))
  (if (board?)
    (rotate-toward-orientation2! (-> self control)
                                 (-> self control dir-targ)
                                 (-> self control current-surface turnv)
                                 0.0
                                 (the int (-> self control current-surface turnvf))

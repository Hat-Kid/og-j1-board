            (set-mode! (-> self board board 0 main) (joint-mod-handler-mode flex-blend))
            (let ((s5-3 (new 'stack-no-clear 'vector)))
              (vector-copy! s5-3 (-> self node-list data 3 bone transform fvec))
              (vector-rotate-y! s5-3 s5-3 (degrees 83))
              (if (not (and (-> self next-state)
                            (symbol-member? (-> self next-state name) '(target-board-flip target-board-hold target-board-trickx target-board-tricky))))
                (forward-up-nopitch->quaternion (-> self control quat-for-control)
                                                s5-3
                                                (vector-y-quaternion! (new 'stack-no-clear 'vector) (-> self control quat-for-control)))))
            (forward-up-nopitch->quaternion (-> self control dir-targ)
                                            (vector-normalize-copy! (new 'stack-no-clear 'vector) (-> self control transv) 1.0)
                                            (vector-y-quaternion! (new 'stack-no-clear 'vector) (-> self control dir-targ)))

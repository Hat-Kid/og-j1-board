(define *board-ride-jump-mods*
  (new 'static
       'surface
       :name 'jump
       :turnv 49152.0
       :turnvf 30.0
       :turnvv 32768.0
       :turnvvf 300.0
       :tiltv 32768.0
       :tiltvf 30.0
       :tiltvv 131072.0
       :tiltvvf 18.0
       :transv-max
       BOARD_MAX_SPEED
       :target-speed 102400.0
       :nonlin-fric-dist 1.0
       :slip-factor 1.0
       :slide-factor 1.0
       :slope-slip-angle 1.0
       :bend-factor 1.0
       :bend-speed 1.0
       :alignv 1.0
       :slope-up-traction 1.0
       :align-speed 1.0
       :mult-hook
       (lambda :behavior target ((arg0 surface) (arg1 surface) (arg2 surface) (arg3 int))
         (case arg3
           ((1)
            (when (!= (-> *cpad-list* cpads (-> self control cpad number) stick0-speed) 0.0)
              (if (< BOARD_MAX_SPEED (-> self control ctrl-xz-vel))
                (set! (-> arg0 transv-max) (lerp (-> self control ctrl-xz-vel) BOARD_MAX_SPEED 0.2))
                (set! (-> arg0 transv-max) (fmin (-> arg0 transv-max) BOARD_MAX_SPEED)))
              (vector+float*! (-> self control transv)
                              (-> self control transv)
                              (vector-flatten! (new 'stack-no-clear 'vector) (-> self control to-target-pt-xz) (-> self board ride-dir))
                              (* (+ (meters -5) (-> arg0 transv-max)) (seconds-per-frame) (-> self control turn-to-magnitude)))))))
       :mode 'air
       :flags (surface-flags no-turn-around turn-to-pad allow-edge-grab jump)))

(define *board-duck-jump-mods* *board-jump-mods*)

(let ((spin-mods (define *board-spin-mods* (copy *board-jump-mods* 'global))))
  (set! (-> spin-mods name) 'spin)
  (set! (-> spin-mods flags) (surface-flags no-turn-around allow-edge-grab jump))
  (set! (-> spin-mods seek0) 0.0)
  (set! (-> spin-mods seek90) 0.0)
  (set! (-> spin-mods seek180) 0.0)
  (set! (-> spin-mods vel-turn) 0.0)
  (set! (-> spin-mods turnv) 0.0)
  (set! (-> spin-mods turnvv) 0.0)
  (set! (-> spin-mods tiltv) 0.0)
  (set! (-> spin-mods tiltvf) 0.0))

(let ((spin-post-mods (define *board-spin-post-mods* (copy *board-jump-mods* 'global))))
  (set! (-> spin-post-mods seek0) 0.0)
  (set! (-> spin-post-mods seek90) 0.0)
  (set! (-> spin-post-mods seek180) 0.0)
  (set! (-> spin-post-mods vel-turn) 0.0))

(let ((flip-mods (define *board-flip-mods* (copy *board-duck-jump-mods* 'global))))

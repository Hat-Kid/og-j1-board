(defpartgroup group-board-launch
  :id 712
  :duration (seconds 0.035)
  :linger-duration (seconds 1.5)
  :bounds (static-bspherem 0 0 0 2)
  :parts
  ((sp-item 3002
            :flags
            (launch-asap
              #| sp3 |#
              ))
   (sp-item 3001
            :flags
            (launch-asap
              #| sp3 |#
              ))
   (sp-item 3000
            :flags
            (launch-asap
              #| sp3 sp7 |#
              ))))

(defpart 3000
  :init-specs
  ((:texture (starflash effects))
   (:num 1.0)
   (:scale-x (meters 5))
   (:rot-x (degrees 2250))
   (:scale-y :copy scale-x)
   (:r 255.0)
   (:g 255.0)
   (:b 255.0)
   (:a 255.0)
   (:omega (degrees 18011.25))
   (:scalevel-x (meters -0.125))
   (:scalevel-y :copy scalevel-x)
   (:fade-a -6.375)
   (:timer (seconds 0.135))
   (:flags
    (bit2 bit3
          #| glow |#
          ))
   (:userdata 409600.0)))


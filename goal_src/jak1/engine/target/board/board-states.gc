(defstate target-board-trickx (target)
  :event
    (-> target-board-jump
        event)
  :enter
    (-> target-board-tricky
        enter)
  :exit
    (behavior ()
      (send-event (ppointer->process (-> self sidekick)) 'matrix 'board)
      (sound-play "board-boots")
      ((-> target-board-tricky exit)))
  :trans
    (behavior ()
      (target-board-spin-check)
      (when (!= (-> self control unknown-spoolanim00) 'halfpipe)
        (set! (-> self control unknown-float123)
              (fmax (-> self control unknown-float123)
                    (* 0.003921569 (the float (-> *cpad-list* cpads (-> self control cpad number) abutton (abutton-idx x))))))
        (mod-var-jump-board #t #f (cpad-hold? (-> self control cpad number) x) (-> self control transv)))
      (when (jump-hit-ground-stuck?)
        (set-time! (-> self board jump-land-time))
        (go target-board-hit-ground))
      (vector-copy! (-> self board slow-transv) (-> self control transv)))
  :code
    (behavior ((arg0 float) (arg1 float) (arg2 symbol))
      (let ((gp-0 (>= (-> self board unk-float005) 0.0))
            (s5-0 (new 'stack-no-clear 'vector)))
        (set! (-> s5-0 x) 0.0)
        (set! (-> s5-0 y) 0.0)
        (set! (-> s5-0 z) (* -0.0078125 (+ -128.0 (the float (-> self control cpad lefty)))))
        (set! (-> s5-0 w) 1.0)
        (let ((f0-9 (analog-input (the int (* 128.0 (-> s5-0 z))) 0.0 96.0 110.0 1.0))
              (s4-0 0))
          (while (not (and (or (not (cpad-hold? (-> self control cpad number) r1))
                               (or (= f0-9 0.0) (jump-hit-ground-stuck?) (< (target-time-to-ground) (seconds 0.5))))
                           (nonzero? s4-0)))
            (cond
              (gp-0
               (add-to-trick-list (-> self board) (board-tricks board-kickflip) 500.0)
               (set! (-> self board trick-sound-id) (sound-play "board-kickflip"))
               (ja-channel-push! 1 (seconds 0.07))
               (ja-no-eval :group! eichar-board-kickflip-a-ja :num! (seek!) :frame-num 0.0)
               (until (ja-done? 0)
                 (suspend)
                 (ja :num! (seek!)))
               (send-event (ppointer->process (-> self sidekick)) 'matrix #f)
               (ja-no-eval :group! eichar-board-kickflip-b-ja :num! (seek! max 1.05) :frame-num 0.0)
               (until (ja-done? 0)
                 (suspend)
                 (ja :num! (seek! max 1.05)))
               (send-event (ppointer->process (-> self sidekick)) 'matrix 'board)
               (ja-no-eval :group! eichar-board-kickflip-c-ja :num! (seek!) :frame-num 0.0)
               (until (ja-done? 0)
                 (suspend)
                 (ja :num! (seek!))))
              (else
               (add-to-trick-list (-> self board) (board-tricks board-board-spin) 500.0)
               (set! (-> self board trick-sound-id) (sound-play "board-boardspin"))
               (ja-channel-push! 1 (seconds 0.05))
               (ja-no-eval :group! eichar-board-spin-ja :num! (seek! max 0.95) :frame-num 0.0)
               (until (ja-done? 0)
                 (suspend)
                 (ja :num! (seek! max 0.95)))))
            (1+! (-> self board trickx-count))
            (set! f0-9 (analog-input (the int (* 128.0 (-> s5-0 z))) 0.0 96.0 110.0 1.0))
            (1+! s4-0))))
      (go target-board-falling))
  :post target-board-post)

(defstate target-board-hit-ground (target)
  :event target-board-handler
  :enter
    (behavior ()
      ; (logclear! (-> self focus-status) (focus-status halfpipe))
      ; (if (= (-> self control ground-pat mode) (pat-mode halfpipe))
      ;   (go target-board-turn-to (-> self control transv) (seconds 0.5)))
      )
  :exit target-board-exit
  :trans
    (behavior ()
      (if (and (cpad-hold? (-> self control cpad number) l1) (not (logtest? (-> self state-flags) (state-flags prevent-duck))))
        (go target-board-duck-stance))
      ;; og:preserve-this - High FPS Fix
      (when (and (recently-pressed? x) (can-jump? 'board))
        (flush-trick-list (-> self board))
        (go target-board-jump
            (-> *TARGET_BOARD-bank* jump-height-min)
            (-> *TARGET_BOARD-bank* jump-height-max)
            (the surface #f)))
      (if (target-board-smack-surface?) 0))
  :code
    (behavior ()
      (set! (-> self control mod-surface) *board-walk-mods*)
      (let ((v1-3 (ja-group)))
        (cond
          ((and v1-3 (or (= v1-3 eichar-board-method-end-ja) (= v1-3 eichar-board-nosegrab-end-ja)))
           (ja-no-eval :num! (seek! max 1.5))
           (while (not (ja-done? 0))
             (suspend)
             (ja-eval)))
          ((let ((v1-18 (ja-group))) (and v1-18 (= v1-18 eichar-board-method-loop-ja)))
           (ja-channel-push! 1 (seconds 0.08))
           (ja-no-eval :group! eichar-board-method-end-ja :num! (seek! max 1.5) :frame-num 0.0)
           (until (ja-done? 0)
             (suspend)
             (ja :num! (seek! max 1.5))))
          ((let ((v1-48 (ja-group))) (and v1-48 (= v1-48 eichar-board-nosegrab-loop-ja)))
           (ja-channel-push! 1 (seconds 0.08))
           (ja-no-eval :group! eichar-board-nosegrab-end-ja :num! (seek! max 1.5) :frame-num 0.0)
           (until (ja-done? 0)
             (suspend)
             (ja :num! (seek! max 1.5))))))
      (go target-board-stance))
  :post target-board-post)

(defstate target-board-turn-to (target)
  :event target-board-handler
  :enter
    (behavior ((arg0 vector) (arg1 time-frame))
      ; (logclear! (-> self focus-status) (focus-status halfpipe))
      (when (not (or (= (-> self control dynam gravity-length) (meters 60))
                     (not (time-elapsed? (-> self board ride-time) (seconds 0.2)))))
        (let ((v1-11 (new-stack-vector0))
              (f0-2 (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
          (vector-! v1-11 (-> self control transv) (vector-float*! v1-11 (-> self control dynam gravity-normal) f0-2))
          (let* ((f1-3 (vector-length v1-11))
                 (f2-0 f1-3))
            (if (< f0-2 0.0) (set! f0-2 (* 5.0 f0-2)))
            (vector+! (-> self control transv)
                      (vector-float*! (-> self control transv) (-> self control dynam gravity-normal) f0-2)
                      (vector-float*! v1-11 v1-11 (/ f1-3 f2-0))))))
      (set-time! (-> self state-time))
      (set! (-> self control mod-surface) *board-turn-to-mods*)
      (set! (-> self board mods-backup) (-> self control mod-surface))
      (set! (-> self control sliding-start-time) arg1)
      (vector-normalize-copy! (-> self control unknown-vector103) arg0 1.0)
      (forward-up-nopitch->quaternion (-> self control dir-targ)
                                      (-> self control unknown-vector103)
                                      (vector-y-quaternion! (new-stack-vector0) (-> self control dir-targ)))
      (set! (-> self control turn-lockout-end-time) (+ (current-time) arg1)))
  :exit target-board-exit
  :trans
    (behavior ()
      ;; og:preserve-this - High FPS Fix
      (when (and (recently-pressed? x) (can-jump? 'board))
        (flush-trick-list (-> self board))
        (go target-board-jump
            (-> *TARGET_BOARD-bank* jump-height-min)
            (-> *TARGET_BOARD-bank* jump-height-max)
            (the surface #f)))
      (if (time-elapsed? (-> self state-time) (-> self control sliding-start-time)) (go target-board-stance))
      (target-board-anim-trans)
      (when (board-on-ground?)
        (let ((gp-0 (-> self board turn-anim-tilt?))) (target-board-ground-check) (set! (-> self board turn-anim-tilt?) gp-0)))
      (set! (-> self board turn-anim-targ) (* 8.0 (-> self board turn-anim-targ))))
  :code
    (-> target-board-stance
        code)
  :post target-board-post)

(defstate target-board-turn-around (target)
  :event target-board-handler
  :enter
    (behavior ()
      (set-time! (-> self state-time))
      ; (logclear! (-> self focus-status) (focus-status halfpipe))
      (set! (-> self control mod-surface) *turn-around-mods*)
      (set! (-> self control unknown-float81) 1.0))
  :exit
    (behavior ()
      (set-forward-vel 0.0)
      (set! (-> self control ctrl-xz-vel) 0.0)
      (set-quaternion! (-> self control) (-> self control dir-targ))
      (set! (-> self control unknown-float81) 0.0)
      (target-board-exit))
  :trans
    (behavior ()
      ;; og:preserve-this - High FPS Fix
      (when (and (recently-pressed? x) (can-jump? 'board))
        (flush-trick-list (-> self board))
        (go target-board-jump
            (-> *TARGET_BOARD-bank* jump-height-min)
            (-> *TARGET_BOARD-bank* jump-height-max)
            (the surface #f)))
      (target-board-anim-trans)
      (when (board-on-ground?)
        (let ((gp-0 (-> self board turn-anim-tilt?))) (target-board-ground-check) (set! (-> self board turn-anim-tilt?) gp-0)))
      (set! (-> self board turn-anim-targ) (* 10.0 (-> self board turn-anim-targ))))
  :code
    (behavior ()
      (let ((f30-0 (-> self control ctrl-xz-vel))
            (gp-0 (vector-z-quaternion! (new 'stack-no-clear 'vector) (-> self control quat-for-control))))
        (ja-channel-push! 1 (seconds 0.04))
        (ja :group! eichar-board-turn-around-ja :num! min)
        (quaternion-rotate-y! (-> self control dir-targ) (-> self control quat-for-control) (degrees 180))
        (compute-alignment! (-> self align))
        (until (ja-done? 0)
          (suspend)
          (ja :num! (seek! max 1.25))
          (compute-alignment! (-> self align))
          (align! (-> self align) (align-opts adjust-quat) 1.0 1.0 1.0)
          (set! (-> self control ctrl-xz-vel)
                (* f30-0 (* (/ (-> *display* frames-per-second) (meters 10)) (-> self align delta trans z))))
          (vector-float*! (-> self control transv) gp-0 (-> self control ctrl-xz-vel))
          (let ((v1-31 (new-stack-vector0))
                (f1-2 (vector-dot (-> self control standard-dynamics gravity-normal) (-> self control transv))))
            (vector-! v1-31 (-> self control transv) (vector-float*! v1-31 (-> self control standard-dynamics gravity-normal) f1-2))
            (let* ((f2-0 (vector-length v1-31))
                   (f0-12 f2-0)
                   (f1-4 (fmax (meters -2) (fmin (meters 2) f1-2)))
                   (f2-1 (fmin (meters 90) f2-0)))
              (vector+! (-> self control transv)
                        (vector-float*! (-> self control transv) (-> self control standard-dynamics gravity-normal) f1-4)
                        (vector-float*! v1-31 v1-31 (/ f2-1 f0-12)))))))
      (sound-play "board-boost")
      (remove-exit)
      (set-quaternion! (-> self control) (-> self control dir-targ))
      (set! (-> self control unknown-float81) 0.0)
      (go target-board-stance))
  :post target-board-post)

(defstate target-board-ride-edge (target)
  :event
    (behavior ((proc process) (argc int) (message symbol) (block event-message-block))
      (case message
        (('edge-grab 'push-transv 'push-trans) #f)
        (('end-mode)
         (case (-> block param 0)
           (('ride)
            (when (-> block param 1)
              (let ((v1-7 (/ (- (current-time) (-> self board ride-start-time)) 300)))
                (if (> v1-7 0) (add-to-trick-list (-> self board) (board-tricks board-rail) (* 100.0 (the float v1-7))))))
            (when (< 32768.0 (-> self control ctrl-xz-vel))
              (forward-up-nopitch->quaternion (-> self control dir-targ)
                                              (-> self control transv)
                                              (vector-y-quaternion! (new 'stack-no-clear 'vector) (-> self control dir-targ)))
              (set-quaternion! (-> self control) (-> self control dir-targ)))
            (go target-board-turn-to (-> self control transv) (seconds 0.2)))
           (('board) (go target-board-get-off (process->handle proc) #f))))
        (else (target-board-handler proc argc message block))))
  :enter
    (behavior ((arg0 symbol))
      (set-time! (-> self state-time))
      (let ((v1-2 (the sound-rpc-set-param (get-sound-buffer-entry))))
        (set! (-> v1-2 command) (sound-command set-param))
        (set! (-> v1-2 id) (-> self board charge-sound-id))
        (set! (-> v1-2 parms volume) -4)
        (set! (-> v1-2 auto-time) 24)
        (set! (-> v1-2 auto-from) 2)
        (set! (-> v1-2 parms mask) (sound-mask volume time))
        (-> v1-2 id))
      ; (logior! (-> self focus-status) (focus-status rail))
      ; (logior! (-> self control root-prim prim-core action) (collide-action can-ride))
      (set! (-> self control mod-surface) *board-ride-mods*)
      (set! (-> self board mods-backup) (-> self control mod-surface))
      (let ((v1-14 (-> self control unknown-vector00)))
        (set! (-> self board ride-speed) (sqrtf (+ (* (-> v1-14 x) (-> v1-14 x)) (* (-> v1-14 z) (-> v1-14 z))))))
      (set! (-> self board ride-lean-targ) 0.0)
      (set! (-> self board ride-lean) 0.0)
      (set! (-> self board ride-leanv) 0.0)
      (set! (-> self board ride-tilt-targ) 0.0)
      (set! (-> self board ride-tilt) 0.0)
      (set! (-> self board ride-tiltv) 0.0)
      (set! (-> self neck flex-blend) 0.0)
      (set! (-> self board spin-control) 0.0)
      (set! (-> self board flip-control) 0.0)
      (set! (-> self board flip-count) 0)
      (set! (-> self board unk-float005) 0.0)
      (set! (-> self board unk-float006) 0.0)
      (set! (-> self control unknown-uint20) (the-as uint #t))
      (set! (-> self control unknown-uint20) (the uint 1000))
      (target-board-compute-edge)
      (let ((f0-17 (vector-dot (-> self control unknown-matrix01 fvec) (-> self control unknown-vector100))))
        (cond
          ((< 0.7 f0-17) (set! (-> self board ride-mode) (the uint 0)) (set! (-> self board ride-rot) 0.0))
          ((< f0-17 -0.7) (set! (-> self board ride-mode) (the uint 1)) (set! (-> self board ride-rot) 32768.0))
          (else
           (let ((f0-21 (vector-dot (-> self control unknown-matrix01 rvec) (-> self control unknown-vector100))))
             (cond
               ((< 0.7 f0-21) (set! (-> self board ride-mode) (the uint 2)) (set! (-> self board ride-rot) -16384.0))
               (else (set! (-> self board ride-mode) (the uint 3)) (set! (-> self board ride-rot) 16384.0)))))))
      (let ((f0-24 0.0))
        (if arg0 (set! f0-24 (+ 250.0 f0-24)))
        (if (and (!= (-> self board ride-rot-old) -1.0) (!= (-> self board ride-rot) (-> self board ride-rot-old)))
          (set! f0-24 (+ 500.0 f0-24)))
        (add-to-trick-list (-> self board) (board-tricks board-rail-jump) f0-24)))
  :exit
    (behavior ()
      ; (logclear! (-> self control status) (collide-status probe-hit))
      (let ((v1-2 (the sound-rpc-set-param (get-sound-buffer-entry))))
        (set! (-> v1-2 command) (sound-command set-param))
        (set! (-> v1-2 id) (-> self board ride-sound-id))
        (set! (-> v1-2 parms volume) -4)
        (set! (-> v1-2 auto-time) 24)
        (set! (-> v1-2 auto-from) 2)
        (set! (-> v1-2 parms mask) (sound-mask volume time))
        (-> v1-2 id))
      ((-> target-board-stance exit))
      (set! (-> self neck flex-blend) 1.0)
      ; (logclear! (-> self focus-status) (focus-status rail))
      (logclear! (-> self control root-prim prim-core action) (collide-action rider-target))
      (set! (-> self board ride-rot-old) (-> self board ride-rot))
      (let ((gp-0 (new 'stack-no-clear 'vector)))
        (vector-copy! gp-0 (-> self control trans))
        (let ((params (new 'stack-no-clear 'find-gspot-params)))
          (set! (-> params ignore-proc) (the process #f))
          (set! (-> params sphere-radius) (meters 0.25))
          (set! (-> params collide-with) (logclear (-> self control root-prim collide-with) (collide-kind water)))
          (if (find-gspot (-> self control) params (meters 2) (meters 20))
            (set! (-> self control gspot-pat-surface) (-> params tri pat))))
        (if (< (-> self control trans y) (-> self control gspot-pos y)) (vector-copy! gp-0 (-> self control gspot-pos)))
        (move-to-point! (-> self control) (vector+! (new 'stack-no-clear 'vector) gp-0 (new 'static 'vector :y 204.8 :w 1.0)))))
  :trans
    (behavior ()
      ;; og:preserve-this - High FPS Fix
      (when (and (recently-pressed? x) (can-jump? 'board))
        (let ((v1-15 (/ (- (current-time) (-> self board ride-start-time)) (seconds 1))))
          (if (> v1-15 0) (add-to-trick-list (-> self board) (board-tricks board-rail) (* 100.0 (the float v1-15)))))
        (+! (-> self control trans y) (meters 0.3))
        (go target-board-jump
            (-> *TARGET_BOARD-bank* jump-height-min)
            (-> *TARGET_BOARD-bank* jump-height-max)
            *board-ride-jump-mods*))
      (if (cpad-pressed? (-> self control cpad number) square) (set! (-> self control unknown-uint20) (the-as uint #f)))
      (if (-> self control unknown-spoolanim00) (set-time! (-> self board ride-button-time)))
      (set! (-> self board turn-anim-targ) (* (-> self board ride-lean) (- (-> *TARGET_BOARD-bank* turn-frames))))
      (cond
        ((= (-> self board ride-speed) 0.0)
         (let ((v1-43 (the sound-rpc-set-param (get-sound-buffer-entry))))
           (set! (-> v1-43 command) (sound-command set-param))
           (set! (-> v1-43 id) (-> self board ride-sound-id))
           (set! (-> v1-43 parms volume) -4)
           (set! (-> v1-43 auto-time) 24)
           (set! (-> v1-43 auto-from) 2)
           (set! (-> v1-43 parms mask) (sound-mask volume time))
           (-> v1-43 id)))
        (else
         (let ((f30-1 (* (lerp-scale 0.7 1.0 (fabs (-> self board ride-lean)) 0.0 1.0)
                         (lerp-scale 0.8 1.0 (fabs (-> self board ride-speed)) 0.0 (/ (-> self control mod-surface transv-max) 2))))
               (f28-1 (+ (lerp-scale 0.0 0.05 (fabs (-> self board ride-lean)) 0.0 1.0)
                         (lerp-scale -0.05 0.0 (fabs (-> self board ride-speed)) 0.0 (* 0.3 (-> self control mod-surface transv-max))))))
           (if (!= (-> self control unknown-uint20) (-> self control ground-pat material)) (sound-stop (-> self board ride-sound-id)))
           (let* ((v1-65 (-> self control ground-pat material))
                  (name (if (or (= v1-65 (pat-material wood)) (= v1-65 (pat-material crwood)))
                          (static-sound-name "board-rail-wood")
                          (static-sound-name "board-rail-mtl"))))
             (sound-play-by-name name
                                 (-> self board ride-sound-id)
                                 (the int (* 1024.0 f30-1))
                                 (the int (* 1524.0 f28-1))
                                 0
                                 (sound-group sfx)
                                 #t)))
         (set! (-> self control unknown-uint20) (the-as uint (-> self control ground-pat material)))))
      ; (when (< (meters 1) (-> self board ride-speed))
      ;   (let ((gp-1 (vector+float*! (new 'stack-no-clear 'vector) (-> self control trans) (-> self board ride-dir) (meters -1))))
      ;     (set! (-> *part-id-table* 670 init-specs 1 initial-valuef)
      ;           (lerp-scale 0.1 2.0 (fabs (-> self board ride-speed)) 0.0 (* 0.3 (-> self control mod-surface transv-max))))
      ;     (launch-particles (-> *part-id-table* 670) gp-1)))
      )
  :code
    (behavior ((arg0 symbol))
      (let* ((v1-1 (-> self board ride-mode))
             (gp-0 (cond
                     ((zero? v1-1) eichar-board-ride-turn-front-ja)
                     ((= v1-1 1) eichar-board-ride-turn-back-ja)
                     ((= v1-1 2) eichar-board-ride-turn-left-ja)
                     ((= v1-1 3) eichar-board-ride-turn-right-ja)
                     (else (the art-element #f)))))
        (when (!= (ja-group) gp-0)
          (ja-channel-push! 1 (seconds 0.1))
          (set! (-> self skel root-channel 0 frame-group) (the art-joint-anim gp-0))))
      (until #f
        (ja :num-func
            num-func-identity
            :frame-num
            (ja-aframe (fmax -5.0
                             (fmin 5.0
                                   (+ (* 3.0 (-> self board ride-lean)) (* 0.5 (sin (* 145.63556 (the float (- (current-time) (-> self state-time)))))))))
                       0))
        (suspend))
      #f)
  :post target-board-ride-post)

(defstate target-board-get-on (target)
  :event
    (behavior ((proc process) (argc int) (message symbol) (block event-message-block))
      (case message
        (('clone-anim) (go target-board-clone-anim (process->handle (the process (-> block param 0)))))
        (('attack 'attack-or-shove 'attack-invinc)
         (target-attacked message
                          (the attack-info (-> block param 1))
                          proc
                          (the touching-shapes-entry (-> block param 0))
                          target-hit))
        (else (target-generic-event-handler proc argc message block))))
  :enter
    (behavior ()
      (set! (-> self board shock-offsetv) 0.0)
      (set-time! (-> self state-time))
      (logclear! (-> self control status) (cshape-moving-flags onsurf onground tsurf))
      (set! (-> self control mod-surface) *board-jump-mods*)
      (set! (-> self board mods-backup) (-> self control mod-surface))
      (let ((a0-5 (target-time-to-ground)))
        (cond
          ((logtest? (water-flags wt09) (-> self water flags))
           (let ((v1-10 (new-stack-vector0)))
             (let ((f0-2 (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
               (vector-! v1-10 (-> self control transv) (vector-float*! v1-10 (-> self control dynam gravity-normal) f0-2)))
             (let* ((f0-3 (vector-length v1-10))
                    (f1-1 f0-3)
                    (f2-2 (+ (fmax 0.0 (fmin (meters 10) (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
                             (* 0.33 (-> self control dynam gravity-length)))))
               (vector+! (-> self control transv)
                         (vector-float*! (-> self control transv) (-> self control dynam gravity-normal) f2-2)
                         (vector-float*! v1-10 v1-10 (/ f0-3 f1-1)))))
           (set! (-> self control unknown-uint20) (the uint #t)))
          ((< a0-5 (seconds 0.25))
           (let ((v1-12 (new-stack-vector0)))
             (let ((f0-6 (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
               (vector-! v1-12 (-> self control transv) (vector-float*! v1-12 (-> self control dynam gravity-normal) f0-6)))
             (let* ((f0-7 (vector-length v1-12))
                    (f1-3 f0-7)
                    (f2-5 (+ (fmax 0.0 (fmin (meters 10) (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
                             (* 0.0016666667 (the float (- (seconds 0.66) a0-5)) (-> self control dynam gravity-length)))))
               (vector+! (-> self control transv)
                         (vector-float*! (-> self control transv) (-> self control dynam gravity-normal) f2-5)
                         (vector-float*! v1-12 v1-12 (/ f0-7 f1-3)))))
           (set! (-> self control unknown-uint20) (the uint #t)))
          (else
           (let ((v1-14 (new-stack-vector0)))
             (vector-! v1-14
                       (-> self control transv)
                       (vector-float*! v1-14
                                       (-> self control dynam gravity-normal)
                                       (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
             (let* ((f0-11 (vector-length v1-14))
                    (f1-5 f0-11)
                    (f2-7 (fmax 0.0 (fmin (meters 10) (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))))
               (vector+! (-> self control transv)
                         (vector-float*! (-> self control transv) (-> self control dynam gravity-normal) f2-7)
                         (vector-float*! v1-14 v1-14 (/ f0-11 f1-5)))))
           (set! (-> self control unknown-uint20) (the-as uint #f)))))
      (let ((v1-17 (new-stack-vector0))
            (f0-14 (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
        (vector-! v1-17 (-> self control transv) (vector-float*! v1-17 (-> self control dynam gravity-normal) f0-14))
        (let* ((f2-8 (vector-length v1-17))
               (f1-8 f2-8))
          (if (< (meters 20) f2-8) (set! f2-8 (meters 20)))
          (vector+! (-> self control transv)
                    (vector-float*! (-> self control transv) (-> self control dynam gravity-normal) f0-14)
                    (vector-float*! v1-17 v1-17 (/ f2-8 f1-8)))))
      (vector-copy! (-> self board slow-transv) (-> self control transv)))
  :exit target-board-exit
  :code
    (behavior ()
      (send-event (ppointer->process (-> self board board)) 'open)
      (ja-channel-push! 1 (the time-frame (if (-> self control unknown-spoolanim00) 9 60)))
      (let ((f30-1 (if (-> self control unknown-spoolanim00) 1.25 (fmax 1.0 (fmin 2.0 (/ 249.99 (the float (target-time-to-ground))))))))
        (ja-no-eval :group! eichar-board-get-on-ja :num! (seek! max f30-1) :frame-num 0.0)
        (until (ja-done? 0)
          (when (logtest? (-> self control status) (cshape-moving-flags onsurf))
            (set! (-> self board turn-anim-duck-vel) 0.0)
            (goto cfg-19))
          (suspend)
          (ja :num! (seek! max f30-1))))
      (set! (-> self board turn-anim-duck-vel) 15.0)
      (while (not (jump-hit-ground-stuck?))
        (suspend))
      (label cfg-19)
      (send-event (ppointer->process (-> self sidekick)) 'matrix 'board)
      (logior! (-> self control status) (cshape-moving-flags onsurf))
      (go target-board-hit-ground))
  :post target-board-post)

(defstate target-board-get-off (target)
  :event
    (-> target-board-get-on
        event)
  :enter
    (behavior ((arg0 handle) (arg1 symbol))
      ; (logclear! (-> self focus-status) (focus-status halfpipe))
      (set! (-> self board shock-offsetv) 0.0)
      (set-time! (-> self state-time))
      (logclear! (-> self control status) (cshape-moving-flags onsurf onground tsurf))
      (set! (-> self control mod-surface)
            (new 'static
                 'surface
                 :name 'jump
                 :turnv 131072.0
                 :turnvf 30.0
                 :turnvv 18204.445
                 :turnvvf 30.0
                 :tiltv 131072.0
                 :tiltvf 30.0
                 :tiltvv 262144.0
                 :tiltvvf 15.0
                 :transv-max 65536.0
                 :target-speed 65536.0
                 :seek0 0.3
                 :seek90 0.3
                 :seek180 0.3
                 :fric 0.05
                 :nonlin-fric-dist 1.0
                 :slip-factor 1.0
                 :slide-factor 1.0
                 :slope-up-factor 1.0
                 :slope-down-factor 1.0
                 :slope-slip-angle 1.0
                 :impact-fric 1.0
                 :bend-factor 1.0
                 :bend-speed 1.0
                 :alignv 1.0
                 :slope-up-traction 1.0
                 :align-speed 1.0
                 :mode 'air
                 :flags (surface-flags allow-edge-grab jump)))
      (set! (-> self control dynam gravity-length) (-> self control standard-dynamics gravity-length))
      (let ((a0-6 (target-time-to-ground)))
        (cond
          ((< a0-6 (seconds 0.207))
           (let ((v1-12 (new-stack-vector0)))
             (let ((f0-3 (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
               0.0
               (vector-! v1-12 (-> self control transv) (vector-float*! v1-12 (-> self control dynam gravity-normal) f0-3)))
             (let* ((f0-4 (vector-length v1-12))
                    (f1-1 f0-4)
                    (f2-2 (+ (fmax 0.0 (fmin (meters 10) (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
                             (* 0.0016666667 (the float (- (seconds 0.66) a0-6)) (-> self control dynam gravity-length)))))
               (vector+! (-> self control transv)
                         (vector-float*! (-> self control transv) (-> self control dynam gravity-normal) f2-2)
                         (vector-float*! v1-12 v1-12 (/ f0-4 f1-1)))))
           (set! (-> self control unknown-uint20) (the-as uint #t)))
          (else
           (let ((v1-14 (new-stack-vector0)))
             (let ((f0-7 (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
               0.0
               (vector-! v1-14 (-> self control transv) (vector-float*! v1-14 (-> self control dynam gravity-normal) f0-7)))
             (let* ((f0-8 (vector-length v1-14))
                    (f1-3 f0-8)
                    (f2-4 (fmax 0.0 (fmin (meters 10) (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))))
               (vector+! (-> self control transv)
                         (vector-float*! (-> self control transv) (-> self control dynam gravity-normal) f2-4)
                         (vector-float*! v1-14 v1-14 (/ f0-8 f1-3)))))
           (set! (-> self control unknown-uint20) (the uint #f)))))
      (vector-copy! (-> self board slow-transv) (-> self control transv)))
  :exit target-board-exit
  :code
    (behavior ((arg0 handle) (arg1 symbol))
      (local-vars (v1-117 symbol) (a0-36 int))
      (let ((f30-0 1.5151515))
        (let ((v1-1 arg1))
          (cond
            ((= v1-1 'hit)
             (ja-channel-push! 1 (seconds 0.1))
             (ja-no-eval :group! eichar-board-hit-get-off-ja :num! (seek! (ja-aframe 24.0 0) 2.5) :frame-num 0.0)
             (until (ja-done? 0)
               (suspend)
               (ja :num! (seek! (ja-aframe 24.0 0) 2.5))))
            ((-> self control unknown-spoolanim00)
             (ja-channel-push! 1 (seconds 0.1))
             (ja-no-eval :group! eichar-board-get-off-pre-ja :num! (seek! max f30-0) :frame-num 0.0)
             (until (ja-done? 0)
               (suspend)
               (ja :num! (seek! max f30-0)))
             (send-event (ppointer->process (-> self sidekick)) 'matrix 'normal)
             (ja-no-eval :group! eichar-board-get-off-ja :num! (seek! (ja-aframe 24.0 0) f30-0) :frame-num 0.0)
             (until (ja-done? 0)
               (if (and (jump-hit-ground-stuck?) (>= (ja-aframe-num 0) 14.0)) (go target-falling #f))
               (suspend)
               (ja :num! (seek! (ja-aframe 24.0 0) f30-0))))
            (else
             (set! f30-0 (fmax 0.5 (fmin 2.0 (/ 150.0 (the float (target-time-to-ground))))))
             (ja-channel-push! 1 (seconds 0.1))
             (send-event (ppointer->process (-> self sidekick)) 'matrix 'normal)
             (ja-no-eval :group! eichar-board-get-off-ja :num! (seek! (ja-aframe 24.0 0) f30-0) :frame-num (ja-aframe 11.0 0))
             (until (ja-done? 0)
               (if (and (jump-hit-ground-stuck?) (>= (ja-aframe-num 0) 14.0)) (go target-falling #f))
               (suspend)
               (ja :num! (seek! (ja-aframe 24.0 0) f30-0))))))
        (send-event (ppointer->process (-> self board board)) 'close)
        (logclear! (-> self state-flags) (state-flags board))
        (set! (-> self control pat-ignore-mask)
              (new 'static
                   'pat-surface
                   :noentity #x1
                   #| :nojak #x1 :probe #x1 :board #x1 |#
                   ))
        (ja-no-eval :num! (seek! max f30-0)))
      (while (let ((t9-36 ja-done?)) (set! a0-36 0) (not (t9-36 a0-36)))
        (if (jump-hit-ground-stuck?) (go target-falling #f))
        (suspend)
        (ja-eval))
      (set! (-> self board turn-anim-duck-vel) 15.0)
      (if (and (board-on-ground?)
               (let ((v1-115 #x100000))
                 (set! a0-36 (the-as int (-> self water flags)))
                 (not (or (logtest?
                            #| v1-115 |#
                            (water-flags wt09)
                            (the-as water-flags a0-36))
                          (logtest? (-> self control status) (cshape-moving-flags on-water))
                          ; (begin
                          ;   (let ((v1-118 #t))
                          ;     (set! a0-36 (the-as int (logand (-> self control status) (collide-status on-water))))
                          ;     (set! a0-36 a0-36)
                          ;     (cmove-#f-zero v1-117 (the-as collide-status a0-36) v1-118))
                          ;   v1-117)
                          ))))
        (go target-hit-ground (the symbol a0-36))
        (go target-falling (if (= arg1 'hit) 'hit))))
  :post
    (behavior ()
      (set! (-> self control unknown-float82) 0.0)
      (set! (-> self control unknown-float81) 0.0)
      (vector-seek! (-> self control draw-offset) *null-vector* (* (meters 4) (seconds-per-frame)))
      (target-post)
      (target-board-effect)))

(defstate target-board-grab (target)
  :event
    (behavior ((proc process) (argc int) (message symbol) (block event-message-block))
      (cond
        ((and (= message 'query) (= (-> block param 0) 'mode)) (-> self state name))
        (else
         (case message
           (('end-mode)
            (case (-> block param 0)
              ((#t) (go target-board-stance))
              (('grab) (go target-board-stance))
              (('board)
               (go target-grab
                   #| 'stance |#
                   ))))
           (('clone-anim) (go target-board-clone-anim (process->handle (the process (-> block param 0)))))
           (('change-mode)
            (case (-> block param 0)
              (('normal)
               (go target-grab
                   #| 'stance |#
                   ))))
           (else (target-generic-event-handler proc argc message block))))))
  :enter
    (behavior ((arg0 symbol))
      (set! (-> self control mod-surface) *grab-mods*)
      (set! (-> self neck flex-blend) 0.0)
      ; (logior! (-> self target-flags) (target-flags tf2))
      (logior! (-> self state-flags) (state-flags grabbed))
      ; (logclear! (-> self focus-status) (focus-status halfpipe))
      (true! (-> self board stick-off))
      (let ((v1-9 (the sound-rpc-set-param (get-sound-buffer-entry))))
        (set! (-> v1-9 command) (sound-command set-param))
        (set! (-> v1-9 id) (-> self board charge-sound-id))
        (set! (-> v1-9 parms volume) -4)
        (set! (-> v1-9 auto-time) 24)
        (set! (-> v1-9 auto-from) 2)
        (set! (-> v1-9 parms mask) (sound-mask volume time))
        (-> v1-9 id)))
  :exit
    (behavior ()
      (false! (-> self board stick-off))
      ; (logclear! (-> self target-flags) (target-flags tf2))
      (logclear! (-> self state-flags) (state-flags grabbed))
      (logclear! (-> self water flags) (water-flags wt16))
      (target-board-exit))
  :code
    (behavior ((arg0 symbol))
      (let ((v1-2 (ja-group)))
        (when (not (and v1-2 (= v1-2 eichar-board-stance-ja)))
          (ja-channel-push! 1 (seconds 0.1))
          (ja :group! eichar-board-stance-ja :num! (identity (ja-aframe 0.0 0)))))
      (until #f
        (set-forward-vel 0.0)
        (suspend))
      #f)
  :post target-board-post)

(defstate target-board-clone-anim (target)
  :event
    (behavior ((proc process) (argc int) (message symbol) (block event-message-block))
      (if (and (= message 'trans) (= (-> block param 0) 'restore)) (set! (-> self control unknown-uint20) (the-as uint #f)))
      (cond
        ((and (= message 'query) (= (-> block param 0) 'mode)) (-> self state name))
        (else
         (case message
           ;; fisher softlock hack
           (('clone-anim) (if (name= (-> proc name) "fisher-1") #t))
           (('end-mode)
            (cond
              ((and (= (-> proc type symbol) 'fuel-cell) (-> proc entity))
               (let* ((parent (-> proc parent))
                      (tasks '(firecanyon-buzzer lavatube-buzzer
                                                ogre-buzzer
                                                ogre-secret
                                                misty-bike
                                                misty-bike-jump
                                                rolling-robbers
                                                rolling-plants
                                                rolling-lake
                                                rolling-buzzer
                                                rolling-ring-chase-1
                                                rolling-ring-chase-2))
                      (task (the game-task
                                 (aif (res-lump-data (-> proc entity) 'eco-info (pointer int32))
                                   (if (and parent (= (-> (ppointer->process parent) type symbol) 'buzzer)) (logand! (-> it 1) #xffff) (-> it 1)))))
                      (task-name (game-task->string task))
                      (task-found? #f))
                 (dotimes (i (length tasks))
                   (if (name= (the basic (ref tasks i)) task-name) (true! task-found?)))
                 (if task-found? (go target-board-stance) (go target-stance))))
              (else (go target-stance)))
            ; (case (-> block param 0)
            ;   ((#t) (go target-board-stance))
            ;   (('grab) (go target-board-stance))
            ;   (('board)
            ;    (go target-grab
            ;        #| 'stance |#
            ;        )))
            )
           (('change-mode)
            (case (-> block param 0)
              (('normal)
               (go target-grab
                   #| 'stance |#
                   ))))
           (else (target-generic-event-handler proc argc message block))))))
  :enter
    (behavior ((arg0 handle))
      (target-set-lod 'default)
      (sound-stop (-> self board wind-sound-id))
      (sound-stop (-> self board engine-sound-id))
      (sound-stop (-> self board bank-sound-id))
      (sound-stop (-> self board ride-sound-id))
      (sound-stop (-> self board spin-sound-id))
      (sound-stop (-> self board eco-sound-id))
      (sound-stop (-> self board charge-sound-id))
      (send-event (ppointer->process (-> self sidekick)) 'matrix 'normal)
      (set! (-> self control unknown-handle10) arg0)
      (vector-copy! (-> self control unknown-vector102) (-> self control trans))
      (set! (-> self control unknown-uint20) (the uint #t))
      (quaternion-copy! (the quaternion (-> self control unknown-vector103)) (-> self control quat))
      (logior! (-> self state-flags) (state-flags grabbed))
      (vector-reset! (-> self control transv))
      (set! (-> self neck flex-blend) 0.0)
      (send-event (ppointer->process (-> self sidekick)) 'shadow #t))
  :exit
    (behavior ()
      (send-event (ppointer->process (-> self sidekick)) 'matrix 'normal)
      (send-event (ppointer->process (-> self sidekick)) 'shadow #t)
      (cond
        ((not (-> self control unknown-spoolanim00)))
        ((not (logtest? (-> self draw status) (draw-status hidden)))
         (move-to-point! (-> self control) (-> self control camera-pos))
         (matrix->quaternion (-> self control unknown-quaternion00) (-> self node-list data 3 bone transform))
         (quaternion-copy! (-> self control quat) (-> self control unknown-quaternion00))
         (move-to-ground (-> self control) (meters 1) (meters 10) #t (-> self control root-prim collide-with))
         (when (logtest? (-> self control status) (cshape-moving-flags on-water))
           (move-to-point! (-> self control)
                           (set-vector! (new-stack-vector0) (-> self control trans x) (-> self water height) (-> self control trans z) 1.0))))
        (else
         (format 0 "ERROR: <ASG>: camera used backup position~%")
         (move-to-point! (-> self control) (-> self control unknown-vector102))
         (quaternion-copy! (-> self control quat) (the quaternion (-> self control unknown-vector103)))))
      (rot->dir-targ! (-> self control))
      (logior! (-> self control status) (cshape-moving-flags onsurf onground tsurf))
      (set-time! (-> self control last-time-on-surface))
      (ja-channel-set! 0)
      (ja-post)
      (cond
        ((!= (-> self next-state name) 'target-stance)
         (send-event (ppointer->process (-> self board board)) 'open)
         (target-board-init))
        (else (target-board-exit))))
  :code
    (behavior ((arg0 handle))
      (set! (-> self control unknown-uint20) (the-as uint (-> self control draw-offset y)))
      (set! (-> self control draw-offset y) 0.0)
      (aif (handle->process (-> self control unknown-handle10))
        (if (= (-> it type symbol) 'fuel-cell)
          (send-event (ppointer->process (-> self sidekick)) 'matrix 'normal)
          (send-event (ppointer->process (-> self sidekick)) 'matrix 'play-anim))
        (send-event (ppointer->process (-> self sidekick)) 'matrix 'play-anim))
      (send-event (ppointer->process (-> self board board)) 'close)
      (clone-anim arg0 (the int (-> self draw origin-joint-index)) #t "")
      (go target-board-stance))
  :post
    (behavior ()
      (vector-! (-> self control cspace-offset) (-> self control draw-offset) (-> self control unknown-vector14))
      (let ((overlap-parms (new 'stack-no-clear 'overlaps-others-params)))
        (set! (-> overlap-parms options) (the uint 1))
        (set! (-> overlap-parms tlist) *touching-list*)
        (find-overlapping-shapes (-> self control) overlap-parms))
      (target-calc-camera-pos)
      ;; og:j1-board added
      (do-target-gspot)
      (do-target-shadow)
      (target-powerup-process)
      ;; og:j1-board added
      (target-board-joint-points)
      (none)))

(defbehavior target-board-knock-off? target ((att attack-info))
  (if (or (= (-> self control ground-pat material) (pat-material hotcoals))
          (= (-> self control ground-pat material) (pat-material lava)))
    (return #f))
  (let ((types '(nav-enemy lurkerworm junglesnake shover darkvine logtrap driller-lurker plant-boss plant-boss-arm swamp-bat-slave))
        (attacker (handle->process (-> att attacker))))
    (when attacker
      (dotimes (i (length types))
        (if (type-type? (-> attacker type) (the type (-> (the symbol (ref types i)) value))) (return #t)))))
  #f)

(defstate target-board-hit (target)
  :event target-board-handler
  :exit
    (behavior ()
      (when (not (and (-> self next-state)
                      (symbol-member? (-> self next-state name) '(target-death target-board-get-off target-board-hit target-board-jump))))
        (logclear! (-> self state-flags) (state-flags dying being-attacked invulnerable timed-invulnerable)))
      (let ((gp-1 (logtest? (-> self state-flags) (state-flags being-attacked))))
        (target-exit)
        (if gp-1 (logior! (-> self state-flags) (state-flags being-attacked))))
      ; (logior! (-> self target-flags) (target-flags lleg-no-ik rleg-no-ik))
      (target-board-exit))
  :trans
    (behavior ()
      (when (= *cheat-mode* 'debug)
        (when (and (not *pause-lock*) (cpad-hold? (-> self control cpad number) r2))
          ; (set-time! (-> self control time-of-last-debug-heal))
          (pickup-collectable! (-> self fact) (pickup-type eco-green) 100.0 (the handle #f))
          (go target-board-stance))))
  :code
    (behavior ((arg0 symbol) (arg1 attack-info))
      (logclear! (-> self water flags) (water-flags wt16))
      ; (logclear! (-> self focus-status) (focus-status halfpipe))
      (let ((snd (the sound-rpc-set-param (get-sound-buffer-entry))))
        (set! (-> snd command) (sound-command set-param))
        (set! (-> snd id) (-> self board charge-sound-id))
        (set! (-> snd parms volume) -4)
        (set! (-> snd auto-time) 24)
        (set! (-> snd auto-from) 2)
        (set! (-> snd parms mask) (sound-mask volume time))
        (-> snd id))
      (set-time! (-> self state-time))
      (let ((att (-> self attack-info)))
        (let ((s5-0 (new 'stack-no-clear 'vector)))
          (set! (-> att attacker) (the handle #f))
          (set! (-> att mode) 'generic)
          (set! (-> att shove-back)
                (meters 6)
                #| (meters 1.5) |#
                )
          (set! (-> att shove-up)
                (meters 3)
                #| (meters 1.2) |#
                )
          (set! (-> att angle) #f)
          (vector-copy! (-> att trans) (-> self control trans))
          (set! (-> att control) 1.0)
          (set! (-> att invinc-time) (-> *TARGET-bank* hit-invulnerable-timeout))
          (set! (-> att speed) 1.0)
          ; (set! (-> att damage) (-> *FACT-bank* health-default-inc))
          ; (set! (-> att knock) (knocked-type none))
          (case arg0
            (('shove)
             (set! (-> att shove-back) (-> *TARGET-bank* smack-surface-dist))
             (set! (-> att shove-up) (-> *TARGET-bank* smack-surface-height))
             (set! (-> att control) 0.0)
             (set! (-> att angle) 'shove)))
          (combine! att
                    arg1
                    #| self |#
                    )
          (when (not (logtest? (-> att mask) (attack-mask vector)))
            (vector-z-quaternion! (-> att vector) (-> self control quat-for-control))
            (vector-xz-normalize! (-> att vector) (- (fabs (-> att shove-back))))
            (set! (-> att vector y) (-> att shove-up)))
          (vector-copy! s5-0 (-> att vector))
          (let ((f0-12 (vector-dot (vector-normalize-copy! (new 'stack-no-clear 'vector) s5-0 1.0)
                                   (vector-z-quaternion! (new 'stack-no-clear 'vector) (-> self control quat-for-control)))))
            (if (not (-> self attack-info angle)) (set! (-> self attack-info angle) (if (>= 0.0 f0-12) 'front 'back))))
          (cond
            ((= arg0 'attack)
             (logior! (-> self state-flags) (state-flags being-attacked))
             (set-time! (-> self game hit-time))
             (case (-> att mode)
               (('endlessfall)
                (cond
                  ((= (-> self game mode) 'debug)
                   (ja-channel-set! 0)
                   (suspend-for (seconds 1))
                   (move-to-point! (-> self control) (-> self control last-known-safe-ground))
                   (vector-copy! (-> self control camera-pos) (-> self control trans))
                   (send-event *camera* 'teleport)
                   (go target-stance))
                  (else
                   (pickup-collectable! (-> self fact) (pickup-type eco-green) -1000.0 (the handle #f))
                   (go target-death (-> att mode)))))
               (('drown-death 'sharkey 'lava 'fry 'slime 'dark-eco-pool 'melt 'instant-death 'crush 'death)
                (pickup-collectable! (-> self fact) (pickup-type eco-green) -1000.0 (the handle #f))
                (if (= (-> self game mode) 'play) (go target-death (-> att mode))))
               (('death) (pickup-collectable! (-> self fact) (pickup-type eco-green) -1000.0 (the handle #f)))
               (else
                (pickup-collectable! (-> self fact)
                                     (pickup-type eco-green)
                                     (-
                                       #| (-> att damage) |#
                                       (-> *FACT-bank* health-single-inc))
                                     (the handle #f))))
             (target-hit-effect att))
            (else
             (case (-> att mode)
               (('burn 'burnup) (sound-play "get-burned")))))
          (when (not (and (= (-> self game mode) 'play) (>= 0.0 (-> self fact health))))
            (when (target-board-knock-off? att)
              (set-quaternion! (-> self control) (-> self control dir-targ))
              (set-forward-vel (* -3.0 (-> att shove-back)))
              (go target-board-get-off (the handle #f) 'hit))
            (if (= (-> att control) 1.0) (go target-board-jump (-> att shove-up) (-> att shove-up) (the surface 'hit))))
          (set! (-> self control mod-surface) *smack-mods*)
          (let ((ja (ja-group)))
            (when (not (and ja (or (= ja eichar-board-hit-ja) (= ja eichar-board-hit-forward-ja))))
              (ja-channel-push! 1 (seconds 0.075))
              (ja :group! eichar-board-hit-ja :num! min)))
          (target-hit-move att (target-hit-orient att s5-0) target-board-falling-anim-trans (-> att speed)))
        (if (and (= (-> self game mode) 'play) (>= 0.0 (-> self fact health))) (go target-death (-> att mode))))
      (go target-board-hit-ground))
  :post
    (behavior ()
      (set! (-> self control dynam gravity-max) (-> self control standard-dynamics gravity-max))
      (set! (-> self control dynam gravity-length) (-> self control standard-dynamics gravity-length))
      (vector-float*! (-> self control dynam gravity)
                      (-> self control dynam gravity-normal)
                      (-> self control dynam gravity-length))
      (target-post)
      (target-board-effect)
      (target-board-joint-points)))

(defstate target-board-yellow-blast (target)
  :event
    (-> target-running-attack
        event)
  :enter
    (behavior ()
      (set-time! (-> self state-time))
      ; (set! (-> self control unknown-surface00) *run-attack-mods*)
      ; (set! (-> *run-attack-mods* turnv) 655360.0)
      ; (set! (-> *run-attack-mods* turnvv) 655360.0)
      (target-start-attack)
      (target-danger-set! 'spin #f)
      (set! (-> self control unknown-uint20) (the uint 0))
      (set! (-> self control unknown-int21) 0)
      (set! (-> self control unknown-uint31) (the uint 0))
      ; (let ((gp-0 (new-stack-vector0))
      ;       (f30-0 (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
      ;   (vector-! gp-0 (-> self control transv) (vector-float*! gp-0 (-> self control dynam gravity-normal) f30-0))
      ;   (let* ((f0-5 (vector-length gp-0))
      ;          (f1-0 f0-5))
      ;     (if (< 0.0 f30-0) (set! f30-0 0.0))
      ;     (vector+! (-> self control transv)
      ;               (vector-float*! (-> self control transv) (-> self control dynam gravity-normal) f30-0)
      ;               (vector-float*! gp-0 gp-0 (/ f0-5 f1-0)))))
      )
  :exit
    (behavior ()
      ; (set! (-> *run-attack-mods* turnv) 0.0)
      ; (set! (-> *run-attack-mods* turnvv) 0.0)
      (set-time! (-> self control unknown-dword31))
      (target-board-exit))
  :code
    (behavior ()
      (let ((proj INVALID_HANDLE))
        (ja-channel-push! 1 (seconds 0.075))
        (level-hint-spawn (text-id swamp-eco-yellow-first-use) "sksp0145" (the-as entity #f) *entity-pool* (game-task none))
        (case (-> (level-get-target-inside *level*) name)
          (('maincave)
           (level-hint-spawn (text-id cave-gnawers-look-around) "sksp0328" (the-as entity #f) *entity-pool* (game-task none))))
        (ja-no-eval :group! eichar-yellow-running-blast-ja :num! (seek! (ja-aframe 9.0 0)) :frame-num 0.0)
        (until (ja-done? 0)
          (if (time-elapsed? (-> self state-time) (seconds 0.1)) (set! (-> *run-attack-mods* turnvv) 0.0))
          (suspend)
          (ja :num! (seek! (ja-aframe 9.0 0))))
        (let ((s5-2 (vector-z-quaternion! (new 'stack-no-clear 'vector) (-> self control quat))))
          (set! (-> s5-2 y) 0.0)
          (vector-normalize! s5-2 (-> *TARGET-bank* yellow-projectile-speed))
          (when (and (= (-> self fact eco-type) (pickup-type eco-yellow)) (>= (-> self fact eco-level) 1.0))
            (set! proj
                  (ppointer->handle (process-spawn projectile-yellow
                                                   :init
                                                   projectile-init-by-other
                                                   (-> self entity)
                                                   (vector<-cspace! (new 'stack-no-clear 'vector) (joint-node eichar-lod0-jg sk_rhand))
                                                   s5-2
                                                   (if (>= (-> self fact eco-level) (-> *FACT-bank* eco-level-max)) 25 9)
                                                   #f)))
            (set-time! (-> self control unknown-dword82))))
        (ja-no-eval :group! eichar-yellow-running-blast-ja :num! (seek!) :frame-num (ja-aframe 9.0 0))
        (until (ja-done? 0)
          (if (or (< (the-as uint (- (current-time) (the-as int (-> self control unknown-uint30)))) (the-as uint 30))
                  (= (-> self control unknown-uint31) 1))
            (send-event (handle->process proj) 'die))
          (suspend)
          (ja :num! (seek!))))
      (if (logtest? (-> self control status) (cshape-moving-flags onsurf)) (go target-board-stance) (go target-board-falling)))
  :post target-board-post)

(defstate target-board-yellow-jump-blast (target)
  :event target-board-handler
  :enter
    (behavior ()
      (set! (-> self control unknown-surface00) *yellow-jump-mods*)
      (let ((gp-0 (new-stack-vector0)))
        (vector-! gp-0
                  (-> self control transv)
                  (vector-float*! gp-0
                                  (-> self control dynam gravity-normal)
                                  (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
        (let* ((f0-2 (vector-length gp-0))
               (f1-1 f0-2))
          (vector+! (-> self control transv)
                    (vector-float*! (-> self control transv) (-> self control dynam gravity-normal) 46917.434)
                    (vector-float*! gp-0 gp-0 (/ f0-2 f1-1))))))
  :exit
    (behavior ()
      (rot->dir-targ! (-> self control))
      (set-time! (-> self control unknown-dword31))
      (target-board-exit))
  :code
    (behavior ()
      (ja-channel-push! 1 (seconds 0.075))
      (ja-no-eval :group! eichar-yellow-jumping-blast-ja :num! (seek! (ja-aframe 15.0 0)) :frame-num 0.0)
      (until (ja-done? 0)
        (suspend)
        (ja :num! (seek! (ja-aframe 15.0 0))))
      (suspend)
      (let ((gp-2 (new-stack-vector0)))
        (vector-! gp-2
                  (-> self control transv)
                  (vector-float*! gp-2
                                  (-> self control dynam gravity-normal)
                                  (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
        (let* ((f0-7 (vector-length gp-2))
               (f1-1 f0-7))
          (vector+! (-> self control transv)
                    (vector-float*! (-> self control transv) (-> self control dynam gravity-normal) 46917.434)
                    (vector-float*! gp-2 gp-2 (/ f0-7 f1-1)))))
      (ja :num! (seek!))
      (process-spawn projectile-yellow
                     :init
                     projectile-init-by-other
                     (-> self entity)
                     (-> self control unknown-vector90)
                     (vector-float*! (new 'stack-no-clear 'vector)
                                     (vector-z-quaternion! (new 'stack-no-clear 'vector) (-> self control quat))
                                     (-> *TARGET-bank* yellow-projectile-speed))
                     (if (>= (-> self fact eco-level) (-> *FACT-bank* eco-level-max)) 16 0)
                     #f
                     :to
                     self)
      (set-time! (-> self control unknown-dword82))
      (suspend-for (seconds 0.1))
      (ja-no-eval :group! eichar-yellow-jumping-blast-ja :num! (seek!) :frame-num (ja-frame-num 0))
      (until (ja-done? 0)
        (suspend)
        (ja :num! (seek!)))
      (if (logtest? (-> self control status) (cshape-moving-flags onsurf)) (go target-board-stance) (go target-board-falling)))
  :post target-no-stick-post)

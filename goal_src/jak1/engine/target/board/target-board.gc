(defbehavior target-board-green-eco-attack target ()
  (-! (-> self fact eco-timeout) (seconds 5))
  (none))

(defbehavior target-board-green-eco-use target ((arg0 float))
  ; (set! (-> self fact eco-green) (- (-> self fact eco-green) arg0))
  ; (if (< (-> self fact eco-green) 0.0) (set! (-> self fact eco-green) 0.0))
  (none))

(defun vector-segment-overlap ((arg0 vector) (arg1 vector) (arg2 vector))
  "Seems to compute (v1 - v0).dot(v2 - v1), but in a weird way."
  (let* ((gp-1 (vector-! (new 'stack-no-clear 'vector) arg1 arg2))
         (s5-0 (vector-normalize-copy! (new 'stack-no-clear 'vector) gp-1 1.0)))
    ;; og:preserve-this
    ;; this vector-line-distance-point! is totally unused.
    (let ((a3-0 (new 'stack-no-clear 'vector))) (vector-line-distance-point! arg0 arg1 arg2 a3-0))
    (/ (vector-dot s5-0 (vector-! (new 'stack-no-clear 'vector) arg1 arg0)) (vector-length gp-1))))

(defun target-board-zap-attack-active? ()
  (and (logtest? (-> *target* state-flags) (state-flags board))
       (not (time-elapsed? (-> *target* board zap-start-time)
                           (+ (-> *TARGET_BOARD-bank* zap-duration) (-> *TARGET_BOARD-bank* zap-reset-time))))))

(defbehavior target-board-should-send-attack? target ((p process))
  (let ((types '(process-taskable pelican plunger-lurker robber crate ecoventrock balloonlurker-pilot balloon lavaballoon cavecrystal)))
    (dotimes (i (length types))
      (if (type-type? (-> p type) (the type (-> (the symbol (ref types i)) value))) (return #t))))
  #f)

(defbehavior target-board-handler target ((proc process) (argc int) (msg symbol) (block event-message-block))
  (local-vars (v0-0 object) (a0-11 uint))
  (cond
    ((and (= msg 'query) (= (-> block param 0) 'mode)) 'board)
    (else
     (case msg
       (('end-mode)
        (case (-> block param 0)
          (('board) (go target-board-get-off (process->handle proc) #f))))
       (('change-mode)
        ; (if (!= (-> block param 0) 'grab)
        ;   (when (not (logtest? (-> self state-flags) (state-flags dying)))
        ;     (case (-> block param 0)
        ;       (('normal) (go target-board-get-off (process->handle proc) #f))
        ;       (('falling) (go target-board-falling))
        ;       (('pilot) (target-standard-event-handler proc argc msg block))))
        ;   (if (not (-> block param 1)) #t (go target-board-grab #f)))
        (let ((mode (-> block param 0)))
          (b! (!= mode 'grab) cfg-21 :delay (set! a0-11 (the uint #f)))
          (b! (logtest? (-> self state-flags) (state-flags dying)) cfg-20 :delay (set! v0-0 #f))
          (set! v0-0 (if (not (-> block param 1)) #t (go target-board-grab (the symbol a0-11))))
          (label cfg-20)
          (b! #t cfg-32 :delay (nop!))
          (label cfg-21)
          (set! v0-0
                (cond
                  ((= mode 'normal) (go target-board-get-off (process->handle proc) #f))
                  ((= mode 'falling) (go target-board-falling))
                  ((= mode 'racing) (go target-racing-start (process->handle (the process (-> block param 1)))))
                  ((= mode 'flut) (go target-flut-start (process->handle (the process (-> block param 1))))))))
        (label cfg-32)
        v0-0)
       (('swim 'wade 'slide 'pole-grab) #f)
       #|
        (('pole-grab)
        (if (not (logtest? (-> self control root-prim prim-core action) (collide-action swingpole-active)))
          (go target-pole-cycle (process->handle (the process (-> block param 0))))))
       |#
       (('clone-anim) (go target-board-clone-anim (process->handle (the process (-> block param 0)))))
       (('jump)
        (when (symbol-member? (-> self next-state name)
                              '(target-board-stance target-board-duck-stance target-board-falling target-board-jump))
          (sound-play "board-launch")
          (go target-board-jump
              (the-as float (-> block param 0))
              (the-as float (-> block param 1))
              (the surface (-> block param 2)))))
       #|
 (('edge-grab)
        (let ((gp-1 *edge-grab-info*)
              (s5-1 (new 'stack-no-clear 'vector)))
          (vector-normalize! (vector-! (-> self control edge-grab-edge-dir) (-> gp-1 world-vertex 1) (-> gp-1 world-vertex 0))
                             1.0)
          (vector+float*! s5-1 (-> self control trans) (-> self control c-R-w fvec) (* (meters 10) (seconds-per-frame)))
          (let ((f0-2 (vector-segment-overlap s5-1 (-> gp-1 world-vertex 0) (-> gp-1 world-vertex 1))))
            (if (and (time-elapsed? (-> self board ride-time) (seconds 0.4))
                     (>= f0-2 0.0)
                     (>= 1.0 f0-2)
                     (not (and (-> self next-state) (= (-> self next-state name) 'target-board-duck-stance))))
              (go target-board-ride-edge (logtest? (-> self control mod-surface flags) (surface-flags jump)))))))
       |#
       (('touched)
        (cond
          ((and (-> self control danger-mode)
                (prims-touching? (the touching-shapes-entry (-> block param 0)) (-> self control) (the uint 224)))
           (when (target-send-attack proc
                                     (the-as uint (-> self control danger-mode))
                                     (the-as touching-shapes-entry (-> block param 0))
                                     (the-as int (-> self control target-attack-id))
                                     (the-as int (-> self control attack-count))
                                     ; (-> self control penetrate-using)
                                     )
             ; (case (-> self control danger-mode)
             ;   (('board-spin) (part-tracker-spawn part-tracker :to self :group group-board-spin-attack :target self :mat-joint 37)))
             (target-timed-invulnerable (seconds 0.5) self)))
          ((target-board-should-send-attack? proc)
           (let ((attack (send-event proc 'attack (-> block param 0) 'board (-> self control target-attack-id) (-> self control attack-count))))
             (when attack
               (set! (-> self board attack-id) (1+! *global-attack-id*)))
             (set! v0-0 attack)))
          (else (set! v0-0 (send-event proc 'touch (-> block param 0))))))
       (('attack 'attack-or-shove 'attack-invinc)
        (let* ((att (the attack-info (-> block param 1)))
               (is-burn? (and (logtest? (-> att mask) (attack-mask mode)) (= (-> att mode) 'burn)))
               (do-burn-attack? (target-board-burn-attack? self)))
          (if (or (and is-burn? do-burn-attack?) (not is-burn?))
            (target-attacked msg att proc (the touching-shapes-entry (-> block param 0)) target-board-hit))))
       (('shove)
        (when (not (logtest? (-> self state-flags) (state-flags being-attacked)))
          (mem-copy! (the pointer (-> self attack-info-rec)) (the pointer (-> block param 1)) (size-of attack-info))
          (when (not (logtest? (-> self attack-info-rec mask) (attack-mask attacker)))
            (set! (-> self attack-info-rec attacker) (process->handle proc))
            (logior! (-> self attack-info-rec mask) (attack-mask attacker)))
          (go target-board-hit 'shove (-> self attack-info-rec))))
       (else (target-standard-event-handler proc argc msg block))))))

(defbehavior board-turn-around? target ()
  (let* ((gp-0 (vector<-pad-in-surface! (new-stack-vector0) #f))
         (s5-0 (vector-normalize! gp-0 1.0))
         (a0-2 (new-stack-vector0)))
    (vector-copy! a0-2 (-> self control transv))
    (let ((f30-0 (vector-dot s5-0 (vector-normalize! a0-2 1.0)))
          (s5-1 (-> self control transv-history))
          (f26-0 -1000.0)
          (f28-0 0.0)
          (s2-0 -1)
          (s3-0 (new 'static 'array time-frame 2 (seconds 0) (seconds 0)))
          (s4-0 (new 'stack-no-clear 'vector)))
      (countdown (v1-7 15)
        (let ((a0-5 (-> s5-1 v1-7 quad))) (set! (-> s5-1 (+ v1-7 1) quad) a0-5)))
      (cond
        ((>= (-> self control pad-magnitude) 0.2)
         (vector-copy! (-> s5-1 0) gp-0)
         (set! (-> s5-1 0 w) (-> self control pad-magnitude)))
        (else (vector-normalize-copy! (-> s5-1 0) (-> self control transv) 1.0) (set! (-> s5-1 0 w) 0.2)))
      (dotimes (v1-18 16)
        (+! f28-0 (-> s5-1 v1-18 w))
        (vector+float*! s4-0 s4-0 (-> s5-1 v1-18) (-> s5-1 v1-18 w))
        (when (< f26-0 (-> s5-1 v1-18 w))
          (set! s2-0 v1-18)
          (set! f26-0 (-> s5-1 v1-18 w))))
      (let ((f28-1 (/ f28-0 16)))
        (vector-normalize! s4-0 1.0)
        (set! (-> self control idx-of-fastest-xz-vel) s2-0)
        (set! (-> self control average-xz-vel) f28-1))
      (if (logtest? (-> self control current-surface flags) (surface-flags no-turn-around)) (set-time! (-> s3-0 0)))
      (and (>= (the-as uint (- (current-time) (-> s3-0 0))) (seconds 1))
           (< f30-0 0.0)
           (< (vector-dot s4-0 gp-0) -0.5)
           (< 0.5 (vector-dot gp-0 (-> s5-1 1)))
           (< 0.5 (vector-dot gp-0 (-> s5-1 2)))
           (< 0.5 (vector-dot gp-0 (-> s5-1 3)))
           (< 0.7 (-> self control pad-magnitude))
           (time-elapsed? (-> self control last-time-touching-actor) (seconds 0.3))
           (time-elapsed? (-> self control time-of-last-lc) (seconds 0.3))
           (logtest? (-> self control status) (cshape-moving-flags onsurf))
           (and (< 0.7 (-> self control surface-angle)) #t)))))

(defbehavior target-board-setup target ((arg0 symbol))
  (when (zero? (-> self board))
    (set! (-> self board) (new 'process 'board-info))
    (set! (-> self board process) (the (pointer target) (process->ppointer self)))
    (false! (-> self board latch?))
    (false! (-> self board prevent-board?))
    (set! (-> self board engine-sound-id) (new-sound-id))
    (set! (-> self board ride-sound-id) (new-sound-id))
    (set! (-> self board spin-sound-id) (new-sound-id))
    (set! (-> self board wind-sound-id) (new-sound-id))
    (set! (-> self board bank-sound-id) (new-sound-id))
    (set! (-> self board eco-sound-id) (new-sound-id))
    (set! (-> self board charge-sound-id) (new-sound-id))
    (set! (-> self board attack-id) (1+! *global-attack-id*))
    (set! (-> self board board) (the (pointer board) #f))
    (set! (-> self board mode-sound-bank) #f))
  (cond
    (arg0
     (if (not (-> self board board))
       (set! (-> self board board) (process-spawn board :name "board" :from *8k-dead-pool* :to self))))
    (else
     (when (-> self board board)
       (deactivate (-> self board board 0))
       (set! (-> self board board) (the (pointer board) #f)))))
  (none))

(defbehavior target-set-lod target ((mode symbol))
  (case mode
    (('board)
     (lods-assign! (-> self draw) (-> self board-lod))
     (set! (-> self node-list) (-> self board-node-list))
     (set! (-> self draw skeleton) (-> self board-skeleton))
     (set! (-> self draw jgeo) (-> self board-jgeo))
     (logclear! (-> self skel status) (janim-status blerc blerc-done eye eye-done))
     (set! (-> self draw origin-joint-index) (the uint 47))
     (set! (-> self draw shadow-joint-index) (the uint 47))
     (set! (-> self control unknown-cspace00 parent) (-> self node-list data 22))
     (set! (-> self control unknown-cspace00 joint) (the joint (-> self node-list data 36)))
     (set! (-> self control unknown-cspace10 parent) (-> self node-list data 44))
     (when (-> self sidekick)
       (set! (-> self sidekick 0 node-list data 0 param1) (the basic (-> self control unknown-cspace10 parent)))
       (send-event (-> self sidekick 0) 'set-lod mode)))
    (('default 'old 'normal)
     (lods-assign! (-> self draw) (-> self old-lod))
     (set! (-> self node-list) (-> self old-node-list))
     (set! (-> self draw skeleton) (-> self old-skeleton))
     (set! (-> self draw jgeo) (-> self old-jgeo))
     (logior! (-> self skel status) (janim-status inited eye))
     (set! (-> self draw origin-joint-index) (the uint 33))
     (set! (-> self draw shadow-joint-index) (the uint 33))
     (set! (-> self control unknown-cspace00 parent) (joint-node eichar-lod0-jg lindA))
     (set! (-> self control unknown-cspace00 joint) (the joint (joint-node eichar-lod0-jg rindA)))
     (set! (-> self control unknown-cspace10 parent) (joint-node eichar-lod0-jg LshoulderPad))
     (when (-> self sidekick)
       (send-event (-> self sidekick 0) 'set-lod mode)
       (set! (-> self sidekick 0 node-list data 0 param1) (the basic (-> self control unknown-cspace10 parent))))))
  (fill-skeleton-cache self)
  (ja-channel-set! 0)
  (ja-post))

(defbehavior target-board-init target ()
  (target-exit)
  (target-board-setup #t)
  (target-set-lod 'board)
  (false! (-> self board latch?))
  (if (zero? (-> self board main))
    (set! (-> self board main) (new 'process 'joint-mod (joint-mod-handler-mode flex-blend) self 3)))
  (if (zero? (-> self board upper-body))
    (set! (-> self board upper-body) (new 'process 'joint-mod (joint-mod-handler-mode flex-blend) self 5)))
  (if (zero? (-> self board effect-part)) (set! (-> self board effect-part) (create-launch-control group-target-board self)))
  (if (zero? (-> self board charge-part))
    (set! (-> self board charge-part) (create-launch-control group-target-board-duck-charge self)))
  (set-mode! (-> self board main) (joint-mod-handler-mode flex-blend))
  (set-mode! (-> self board upper-body) (joint-mod-handler-mode flex-blend))
  (set! (-> self board engine-sound-pitch) 0.0)
  (set! (-> self board engine-sound-volume) 1.0)
  (set! (-> self board bank-sound-pitch) 0.0)
  (set! (-> self board bank-sound-volume) 0.0)
  (set! (-> self board wind-sound-pitch) 0.0)
  (set! (-> self board wind-sound-volume) 1.0)
  (set! (-> self board spin-sound-volume) 0.0)
  (set! (-> self board eco-sound-volume) 0.0)
  (set! (-> self board sound-air-knob) 0.0)
  (set! (-> self board sound-bank-knob) 0.0)
  (set! (-> self board turn-sound-id) (new 'static 'sound-id))
  (set-time! (-> self board board-get-on-time))
  (false! (-> self board stick-lock))
  (false! (-> self board stick-off))
  (set-time! (-> self board unstuck-time))
  (set! (-> self board stuck-count) 0)
  (set! (-> self board slip-factor) 1.0)
  (set! (-> self board probe) #f)
  (set! (-> self board halfpipe-side-time) 0)
  (set! (-> self board spin-control) 0.0)
  (set! (-> self board rotyv) 0.0)
  (set! (-> self board roty) 0.0)
  (set! (-> self board roty-cum) 0.0)
  (set! (-> self board unk-deg00) 0.0)
  (set! (-> self board flip-control) 0.0)
  (set! (-> self board flip-count) 0)
  (set! (-> self board unk-float005) 0.0)
  (set! (-> self board unk-float006) 0.0)
  (set! (-> self board unk-float007) 0.0)
  (reset-combo! *board-trick-tracker*)
  (set! (-> self board trick-count) 0)
  (countdown (v1-69 16)
    (set! (-> self board trick-list 0) (board-tricks none)))
  (set! (-> self board charge-progress) 0.0)
  (set! (-> self board upper-body-rotyv) 0.0)
  (set! (-> self board upper-body-roty) 0.0)
  (set! (-> self board upper-body-rotyv-max) (degrees 500))
  (set! (-> self board ride-lock) #f)
  (set! (-> self board ride-lock-on) #f)
  (set! (-> self board ride-rot-old) -1.0)
  (set! (-> self control reaction) target-collision-reaction)
  (set! (-> self control pat-ignore-mask)
        (new 'static
             'pat-surface
             :noentity #x1
             #| :noboard #x1 :probe #x1 |#
             ))
  (logior! (-> self state-flags) (state-flags board))
  (logclear! (-> self control root-prim prim-core action) (collide-action rider-target))
  (set! (-> self control bend-target) 1.0)
  (set! (-> self node-list data 0 param0) (the (function cspace transformq none) cspace<-transformq+world-trans!))
  (set! (-> self node-list data 0 param1) (the basic (-> self control trans)))
  (set! (-> self node-list data 0 param2) (the basic (-> self control cspace-offset)))
  (target-collide-set! 'board 0.0)
  (set! (-> self board thrust-scale) 1.0)
  (set! (-> self board turn-anim-targ) 0.0)
  (set! (-> self board turn-anim-frame) 0.0)
  (set! (-> self board turn-anim-vel) 0.0)
  (set! (-> self board turn-anim-duck) 0.0)
  (false! (-> self board turn-anim-tilt?))
  (set! (-> self board cushion-base) 0.0)
  (set! (-> self board cushion-offset) 0.0)
  (set! (-> self board shock-offset) 0.0)
  (set! (-> self board shock-offsetv) 0.0)
  (set! (-> self board shock-rotx) 0.0)
  (set! (-> self control dynam gravity-max) (-> self control standard-dynamics gravity-max))
  (set! (-> self control dynam gravity-length) (-> self control standard-dynamics gravity-length))
  (vector-float*! (-> self control dynam gravity)
                  (-> self control dynam gravity-normal)
                  (-> self control dynam gravity-length))
  (none))

(defbehavior target-board-exit target ()
  (when (not (and (-> self next-state)
                  (symbol-member? (-> self next-state name)
                                  '(target-board-stance target-board-jump
                                                       target-board-hit-ground
                                                       target-board-jump-kick
                                                       target-board-wall-kick
                                                       target-board-ride-edge
                                                       target-board-duck-stance
                                                       target-board-falling
                                                       target-board-flip
                                                       target-board-trickx
                                                       target-board-tricky
                                                       target-board-hold
                                                       target-board-halfpipe
                                                       target-board-grenade
                                                       target-board-turn-to
                                                       target-board-turn-around
                                                       target-board-hit
                                                       target-board-get-off
                                                       target-board-grab
                                                       target-board-clone-anim
                                                       target-board-yellow-blast
                                                       target-board-yellow-jump-blast
                                                       target-board-launch
                                                       target-board-launch-jump))))
    (false! (-> self board latch?))
    (set-mode! (-> self board main) (joint-mod-handler-mode flex-blend))
    (set-mode! (-> self board upper-body) (joint-mod-handler-mode flex-blend))
    (if (-> self board board) (set-mode! (-> self board board 0 main) (joint-mod-handler-mode flex-blend)))
    (set! (-> self control dynam gravity-max) (-> self control standard-dynamics gravity-max))
    (set! (-> self control dynam gravity-length) (-> self control standard-dynamics gravity-length))
    (vector-float*! (-> self control dynam gravity)
                    (-> self control dynam gravity-normal)
                    (-> self control dynam gravity-length))
    (logclear! (-> self state-flags) (state-flags board))
    (logclear! (-> self control root-prim prim-core action) (collide-action no-normal-reset))
    (logior! (-> self control root-prim prim-core action)
             (collide-action
               #| can-ride |#
               rider-target))
    (set! (-> self control mod-surface) *walk-mods*)
    (set! (-> self node-list data 0 param0) (the (function cspace transformq none) cspace<-transformq+trans!))
    (set! (-> self node-list data 0 param1) (the basic (-> self control trans)))
    (set! (-> self node-list data 0 param2) (the basic (-> self control cspace-offset)))
    (target-collide-set! 'normal 0.0)
    (set! (-> self control reaction) target-collision-reaction)
    (set! (-> self control pat-ignore-mask)
          (new 'static
               'pat-surface
               :noentity #x1
               #| :nojak #x1 :probe #x1 :board #x1 |#
               ))
    (sound-stop (-> self board wind-sound-id))
    (sound-stop (-> self board engine-sound-id))
    (sound-stop (-> self board bank-sound-id))
    (sound-stop (-> self board ride-sound-id))
    (sound-stop (-> self board spin-sound-id))
    (sound-stop (-> self board eco-sound-id))
    (sound-stop (-> self board charge-sound-id))
    (set! (-> self board spin-sound-id) (new 'static 'sound-id))
    (send-event (ppointer->process (-> self sidekick)) 'matrix 'normal)
    (set! (-> self control cspace-offset quad) (the uint128 0))
    (set! (-> self board mode-sound-bank) #f)
    (send-event (ppointer->process (-> self sidekick)) 'cleanup)
    (target-set-lod 'default)
    (target-exit))
  (none))

(defbehavior target-board-falling-anim-trans target ()
  (let ((ja (ja-group)))
    (cond
      ((not (and ja (= ja eichar-board-jump-loop-ja)))
       (ja-channel-push! 1 (seconds 0.33))
       (ja :group! eichar-board-jump-loop-ja))
      ((let ((v1-11 (ja-group))) (and v1-11 (= v1-11 eichar-board-jump-loop-ja))) (ja :num! (loop!)))))
  (none))

(defbehavior board-on-ground? target ()
  (logtest? (-> self control status) (cshape-moving-flags onsurf)))

(defbehavior target-board-smack-surface? target ()
  (when (and (logtest? (-> self control status) (cshape-moving-flags twall))
             (< (+ (current-time) (seconds -0.05)) (-> self control last-time-touching-actor))
             (< 0.7 (-> self control touch-angle))
             (< (meters 18) (-> self control ctrl-xz-vel))
             (and (< (vector-dot (-> self control wall-contact-normal) (-> self control dynam gravity-normal)) 0.3)
                  (not (logtest? (-> self control status) (cshape-moving-flags t-act)))))
    (set-time! (-> self board smack-surface-time))
    (set! (-> self board smack-speed) (-> self control ctrl-xz-vel))
    (vector-copy! (-> self board smack-normal) (-> self control wall-contact-normal))
    #t))

(defbehavior board-add-thrust target ()
  (let ((transv-ctrl (-> self control transv-ctrl)))
    (let* ((f0-7 (cond
                   ((= (sqrtf (+ (square (-> transv-ctrl x)) (square (-> transv-ctrl z)))) 0.0) 0.0)
                   (else (/ (-> transv-ctrl z) (sqrtf (+ (square (-> transv-ctrl x)) (square (-> transv-ctrl z))))))))
           (f30-0 (if (>= f0-7 0.0)
                    (+ (* f0-7 (-> self control current-surface seek0)) (* (- 1.0 f0-7) (-> self control current-surface seek90)))
                    (+ (* (fabs f0-7) (-> self control current-surface seek180)) (* (+ 1.0 f0-7) (-> self control current-surface seek90)))))
           (turn-mag (cond
                       ((-> self board stick-off) 0.0)
                       ; ((= (-> self control ground-pat mode) (pat-mode halfpipe)) 1.0)
                       ; (*target-rc-board-controls* 1.0)
                       ((< (-> transv-ctrl z) 0.0) (fmax 0.75 (-> self control turn-to-magnitude)))
                       (else (-> self control turn-to-magnitude)))))
      (when (not (or (= (-> self control current-surface vel-turn) 0.0) (< (-> transv-ctrl z) 0.0)))
        (vector-rotate-y! transv-ctrl
                          transv-ctrl
                          (fmin (* 0.03 (-> *display* time-adjust-ratio) (- (atan (-> transv-ctrl x) (-> transv-ctrl z))))
                                (* (-> self control current-surface vel-turn) (seconds-per-frame)))))
      (let* ((f0-28 (* f30-0 (-> self board thrust-scale) (lerp-scale 0.4 1.0 turn-mag 0.3 1.0)))
             (f1-22 (-> self control current-surface target-speed))
             (f1-23 (if (< (-> self control local-slope-z) 0.0)
                      (+ f1-22 (* (- (-> self control local-slope-z)) (-> self control current-surface slope-down-factor)))
                      (+ f1-22 (* (- (-> self control local-slope-z)) (-> self control current-surface slope-up-factor))))))
        (when (-> self board stick-off)
          (set! f0-28 0.0)
          (set! f1-23 0.0))
        (when (and (not (time-elapsed? (-> self control last-time-touching-actor) (seconds 1)))
                   (>= turn-mag 0.5)
                   (< (vector-dot (-> self control wall-contact-normal) (-> self control to-target-pt-xz)) -0.7)
                   (logtest? (-> self control mod-surface flags) (surface-flags jump))
                   (< 0.0 (-> transv-ctrl y)))
          (cond
            ((and (time-elapsed? (-> self control last-time-touching-actor) (seconds 0.1)) (< 0.3 (-> self control blocked-factor)))
             (set! f0-28 f1-23))
            ((< (-> transv-ctrl z) 0.0) (set! (-> transv-ctrl z) 0.0))))
        (+! (-> transv-ctrl z) (* f0-28 (seconds-per-frame)))
        (when (!= f1-23 0.0)
          (let ((f0-33 (- 1.0 (/ (* f30-0 (seconds-per-frame)) f1-23))))
            (set! (-> transv-ctrl x) (* (-> transv-ctrl x) f0-33))
            (set! (-> transv-ctrl z) (* (-> transv-ctrl z) f0-33))))
        (set! (-> self board transv-max) f1-23)))
    (if (>= (sqrtf (+ (square (-> transv-ctrl x)) (square (-> transv-ctrl z)))) (-> self control current-surface transv-max))
      (vector-xz-normalize! transv-ctrl (-> self control current-surface transv-max)))
    (let ((s5-0 (new 'stack-no-clear 'vector)))
      (vector-matrix*! s5-0 transv-ctrl (-> self control c-R-w))
      (vector-float*! s5-0 s5-0 0.5)
      (vector+! s5-0 s5-0 (-> self control trans))
      (add-debug-text-sphere *display-target-marks*
                             (bucket-id debug-no-zbuf)
                             s5-0
                             (meters 0.2)
                             "ltransv"
                             (new 'static 'rgba :g #xff :a #x80))
      (vector-copy! s5-0 (-> self control btransv))
      (vector-float*! s5-0 s5-0 0.5)
      (vector+! s5-0 s5-0 (-> self control trans))
      (add-debug-text-sphere *display-target-marks*
                             (bucket-id debug-no-zbuf)
                             s5-0
                             (meters 0.2)
                             "btransv"
                             (new 'static 'rgba :r #xff :g #xff :b #xff :a #x80))))
  (none))

(defun segment-array-vector->index ((arg0 (inline-array vector)) (arg1 int) (arg2 float) (arg3 float))
  (let ((gp-0 -1)
        (f30-0 0.0)
        (f0-0 0.0))
    (while (< (+ gp-0 1) arg1)
      (+! gp-0 1)
      (set! f30-0 (vector-segment-overlap (the-as vector arg2) (-> arg0 gp-0) (-> arg0 (+ gp-0 1))))
      (set! f0-0 (/ arg3 (vector-vector-distance (-> arg0 gp-0) (-> arg0 (+ gp-0 1)))))
      (if (>= 1.0 (+ f30-0 f0-0)) (return (+ (the float gp-0) f30-0 f0-0))))
    (+ (the float gp-0) f30-0 f0-0)))

(defun segment-array-index->vector ((arg0 (inline-array vector)) (arg1 int) (arg2 float) (arg3 vector))
  (let ((v0-0 (the int arg2)))
    (let* ((f0-2 arg2)
           (f0-4 (- f0-2 (the float (the int f0-2)))))
      (when (>= v0-0 arg1)
        (set! v0-0 (+ arg1 -1))
        (set! f0-4 (- arg2 (the float v0-0))))
      (let ((v1-5 (-> arg0 v0-0))
            (a1-3 (-> arg0 (+ v0-0 1))))
        (vector+float*! arg3 v1-5 (vector-! (new 'stack-no-clear 'vector) a1-3 v1-5) f0-4)))
    v0-0))

(defbehavior target-board-exit-check target ()
  (if (and (or (and (cpad-pressed? (-> self control cpad number) r2)
                    (or (!= *cheat-mode* 'debug)
                        (not (logtest? (-> *cpad-list* cpads (-> self control cpad number) button0-abs 0) (pad-buttons l2))))
                    (not *pause-lock*)
                    ; (!= (-> *setting-control* user-current board) 'force)
                    )
               (-> self board prevent-board?))
           (and (not (logtest? (-> self state-flags) (state-flags dying grabbed)))
                (time-elapsed? (-> self board board-get-on-time) (seconds 1))
                (< (-> self board board-get-on-time) (max (-> self control last-time-on-ground) (-> self control last-time-of-stuck)))
                (not (and (-> self next-state) (= (-> self next-state name) 'target-board-grab)))))
    (go target-board-get-off (process->handle self) #f)))

(defbehavior target-board-trail target ()
  (let ((board-nodes (-> self board board 0 node-list))
        (pos (new-stack-vector0)))
    (if (< 0.0 (-> self fact eco-level))
      (case (-> self fact eco-type)
        (((pickup-type eco-yellow))
         (let ((rand-node (rand-vu-int-range 3 (1- (-> board-nodes length)))))
           (launch-particles (-> *part-id-table* (if (rand-vu-percent? 0.5) 269 270))
                             (vector<-cspace! pos (-> board-nodes data rand-node))))
         (dotimes (i 2)
           (let ((rand-node (rand-vu-int-range 3 (1- (-> board-nodes length)))))
             (launch-particles (-> *part-id-table* 271) (vector<-cspace! pos (-> board-nodes data rand-node))))))
        (((pickup-type eco-green))
         (let ((rand-node (rand-vu-int-range 3 (1- (-> board-nodes length)))))
           (launch-particles (-> *part-id-table* (if (rand-vu-percent? 0.5) 277 278))
                             (vector<-cspace! pos (-> board-nodes data rand-node)))
           (dotimes (i 2)
             (let ((rand-node (rand-vu-int-range 3 (1- (-> board-nodes length)))))
               (launch-particles (-> *part-id-table* 279) (vector<-cspace! pos (-> board-nodes data rand-node)))))))
        (((pickup-type eco-red))
         (let ((rand-node (rand-vu-int-range 3 (1- (-> board-nodes length)))))
           (launch-particles (-> *part-id-table* (if (rand-vu-percent? 0.5) 273 274))
                             (vector<-cspace! pos (-> board-nodes data rand-node))))
         (dotimes (i 2)
           (let ((rand-node (rand-vu-int-range 3 (1- (-> board-nodes length)))))
             (launch-particles (-> *part-id-table* 275) (vector<-cspace! pos (-> board-nodes data rand-node))))))
        (((pickup-type eco-blue))
         (cond
           ((and (logtest? (-> self control mod-surface flags) (surface-flags jump))
                 (not (logtest? (-> self control status) (cshape-moving-flags onsurf))))
            (set! (-> *part-id-table* 259 init-specs 4 initial-valuef) 0.0)
            (set! (-> *part-id-table* 259 init-specs 4 random-rangef) 65536.0))
           (else
            (set! (-> *part-id-table* 259 init-specs 4 initial-valuef) 40960.0)
            (set! (-> *part-id-table* 259 init-specs 4 random-rangef) 16384.0)))
         (let ((rand-node (rand-vu-int-range 3 (1- (-> board-nodes length)))))
           (launch-particles (-> *part-id-table* 259) (vector<-cspace! pos (-> board-nodes data rand-node))))
         (let ((rand-node (rand-vu-int-range 3 (1- (-> board-nodes length)))))
           (launch-particles (-> *part-id-table* (if (rand-vu-percent? 0.5) 255 256))
                             (vector<-cspace! pos (-> board-nodes data rand-node)))
           (if (rand-vu-percent? 0.5) (launch-particles (-> *part-id-table* 257) pos)))
         (let ((rand-node (rand-vu-int-range 3 (1- (-> board-nodes length)))))
           (launch-particles (-> *part-id-table* 260) (vector<-cspace! pos (-> board-nodes data rand-node))))))))
  (none))

(defbehavior target-board-effect target ()
  (let ((gp-0 0))
    (cond
      ; ((focus-test? self rail) (set! gp-0 10))
      ((= (-> self control mod-surface name) 'spin) (set! gp-0 3))
      ((and (-> self next-state) (= (-> self next-state name) 'target-board-flip)) (set! gp-0 4))
      ((and (logtest? (-> self control mod-surface flags) (surface-flags jump))
            (not (logtest? (-> self control status) (cshape-moving-flags onsurf))))
       (set! gp-0 1))
      ((not (logtest? (-> self control status) (cshape-moving-flags onsurf))) (set! gp-0 2)))
    (if (board-on-ground?)
      (seek! (-> self board sound-air-knob) 0.0 (* 16.0 (seconds-per-frame)))
      (seek! (-> self board sound-air-knob)
             (lerp-scale 0.0 1.0 (target-height-above-ground) (meters 0.1) (meters 7))
             (* 2.0 (seconds-per-frame))))
    (let ((f30-0 (fabs (/ (-> self board turn-anim-frame) (-> *TARGET_BOARD-bank* turn-frames)))))
      (seek! (-> self board sound-bank-knob)
             f30-0
             (if (< (-> self board sound-bank-knob) f30-0) (* 0.5 (seconds-per-frame)) (seconds-per-frame)))
      (set! (-> self board engine-sound-volume) (lerp-scale 0.8 1.0 f30-0 0.0 1.0)))
    (set! (-> self board engine-sound-pitch)
          (+ (lerp-scale 0.0 -0.1 (-> self board sound-bank-knob) 0.0 1.0)
             (lerp-scale -0.15 0.0 (-> self board shock-offset) -3072.0 52.0192)))
    (set! (-> self board bank-sound-volume) (lerp-scale 0.0 1.0 (-> self board sound-bank-knob) 0.0 1.0))
    (set! (-> self board bank-sound-pitch) (lerp-scale 0.0 -0.2 (-> self board sound-bank-knob) 0.0 1.0))
    (if (< 0.0 (-> self board sound-air-knob))
      (set! (-> self board engine-sound-volume)
            (lerp-scale (-> self board engine-sound-volume) 0.3 (-> self board sound-air-knob) 0.0 1.0)))
    (let ((spec (static-sound-spec "board-steady" :group 0 :volume 0.0 :mask (pitch reg0))))
      (set! (-> spec volume) (the int (* 1024.0 (-> self board engine-sound-volume))))
      (set! (-> spec pitch-mod) (the int (* 1524.0 (-> self board engine-sound-pitch))))
      (set! (-> spec reg 0) (the-as uint gp-0))
      (sound-play-by-spec spec (-> self board engine-sound-id) (the vector #t)))
    (if (< (-> self board bank-sound-volume) 0.1)
      (sound-stop (-> self board bank-sound-id))
      (sound-play-by-name (static-sound-name "board-bank")
                          (-> self board bank-sound-id)
                          (the int (* 1024.0 (-> self board bank-sound-volume)))
                          (the int (* 1524.0 (-> self board bank-sound-pitch)))
                          0
                          (sound-group sfx)
                          #t))
    (let ((spec (static-sound-spec "board-wind" :group 0 :volume 0.0 :mask (pitch reg0))))
      (set! (-> spec volume) (the int (-> self board wind-sound-volume)))
      (set! (-> spec pitch-mod) (the int (-> self board wind-sound-pitch)))
      (set! (-> spec reg 0) (the-as uint gp-0))
      (sound-play-by-spec spec (-> self board wind-sound-id) (the vector #t))))
  (cond
    ((= (-> self control mod-surface name) 'spin)
     (seek! (-> self board spin-sound-volume)
            (lerp-scale 0.0 1.0 (fabs (-> self board rotyv)) 0.0 (degrees 500))
            (* 8.0 (seconds-per-frame)))
     (seek! (-> self board spin-sound-pitch)
            (lerp-scale 0.0 0.3 (fabs (-> self board rotyv)) (degrees 200) (degrees 500))
            (seconds-per-frame))
     (when *sound-player-enable*
       (let ((spin-snd (the sound-rpc-set-param (get-sound-buffer-entry))))
         (set! (-> spin-snd command) (sound-command set-param))
         (set! (-> spin-snd id) (-> self board spin-sound-id))
         (set! (-> spin-snd parms volume) (the int (* 1024.0 (-> self board spin-sound-volume))))
         (set! (-> spin-snd parms mask) (sound-mask volume))
         (-> spin-snd id))))
    (else (set! (-> self board spin-sound-volume) 0.0)))
  ; (when (and (logtest? (the-as game-feature (logand (game-feature board-trail) (-> *setting-control* user-current features)))
  ;                      (-> self game features))
  ;            (and (-> *setting-control* user-current board-trail) (focus-test? self board) (< 0.0 (-> self fact eco-green))))
  ;   (seek! (-> self board eco-sound-volume) 1.0 (seconds-per-frame))
  ;   (let ((a0-43 (static-sound-spec "eco-loop" :group 0 :volume 0.0)))
  ;     (set! (-> a0-43 volume) (the int (* 1024.0 (-> self board eco-sound-volume))))
  ;     (sound-play-by-spec a0-43 (-> self board eco-sound-id) (the-as vector #t))))
  (when (and (< (* (-> self board turn-anim-frame) (-> self board unk-float001)) 0.0)
             (time-elapsed? (-> self board adjust-time) (seconds 0.5)))
    (set-time! (-> self board adjust-time))
    (sound-play "board-adjust"))
  (if (!= (-> self board upper-body-rotyv) 0.0) (set-mode! (-> self board upper-body) (joint-mod-handler-mode rotate)))
  (when (= (-> self board upper-body mode) (joint-mod-handler-mode rotate))
    (set! (-> self board upper-body-rotyv)
          (* 0.95
             (fmax (fmin (-> self board upper-body-rotyv) (-> self board upper-body-rotyv-max))
                   (- (-> self board upper-body-rotyv-max)))))
    (+! (-> self board upper-body-rotyv) (* -10.0 (seconds-per-frame) (-> self board upper-body-roty)))
    (let ((f1-25 (* (-> self board upper-body-rotyv) (seconds-per-frame)))
          (f0-74 (-> self board upper-body-roty)))
      (+! (-> self board upper-body-roty) f1-25)
      (when (< (* f0-74 (-> self board upper-body-roty)) 0.0)
        (set! (-> self board upper-body-roty) 0.0)
        (set! (-> self board upper-body-rotyv) 0.0)
        (set-mode! (-> self board upper-body) (joint-mod-handler-mode flex-blend))))
    (set-twist! (-> self board upper-body) (the float #f) (-> self board upper-body-roty) (the float #f)))
  (when (and (board-on-ground?)
             (not (or (logtest? (-> self draw status)
                                (draw-status hidden
                                             #| no-draw no-draw-temp no-draw-bounds no-draw-bounds2 |#
                                             ))
                      (zero? (-> self skel active-channels)))))
    (spawn (-> self board effect-part) (-> self control trans))
    (effect-control-method-10 (-> self skel effect) 'effect-board-poof 0.0 -1)
    (if (< (-> self board shock-offset) (meters -0.5))
      (effect-control-method-10 (-> self skel effect) 'effect-board-poof 0.0 -1)))
  (vector-lerp! (-> self board slow-transv) (-> self board slow-transv) (-> self control transv) 0.2)
  (if (< (-> self board slow-transv y) 0.0) (set! (-> self board slow-transv y) 0.0))
  (target-board-trail)
  (none))

(defbehavior target-board-physics target ((arg0 vector))
  (if (time-elapsed? (-> self board unk-time-frame01) (seconds 0.3))
    (+! (-> self board shock-offsetv) (* (- (-> arg0 y) (-> self control transv y)) 0.5))
    (vector-copy! (-> self board up-vector 1) (-> self board up-vector 0)))
  (+! (-> self board shock-offsetv)
      (+ (* -10.0 (seconds-per-frame) (-> self board shock-offset))
         (if (board-on-ground?) (* (-> self control dynam gravity-length) (seconds-per-frame) 0.5) 0.0)))
  (cond
    ((= (-> self control mod-surface mode) 'ride)
     (set! (-> self board shock-offsetv) 0.0)
     (set! (-> self board shock-offset) (* 0.96 (-> self board shock-offset))))
    ((and (or (not (time-elapsed? (-> self control last-time-on-surface) (seconds 0.2))) (< (-> self board shock-offset) 0.0))
          (!= (-> self control mod-surface mode) 'air))
     (+! (-> self board shock-offset) (* (-> self board shock-offsetv) (seconds-per-frame)))))
  (set! (-> self board shock-offset)
        (* (-> self board shock-offset) (lerp-scale 0.99 0.98 (-> self control ctrl-xz-vel) (meters 0) (meters 7))))
  (cond
    ((< (meters 10) (-> self board shock-offset))
     (set! (-> self board shock-offset) (meters 10))
     (set! (-> self board shock-offsetv) 0.0))
    ((< (-> self board shock-offset) (meters -0.75))
     (when (< (-> self board shock-offsetv) (meters -3))
       (case (-> self control ground-pat material)
         (((pat-material waterbottom))
          (let ((id (sound-play "swim-enter" :pitch -0.5))
                (snd (the-as sound-rpc-set-param (get-sound-buffer-entry))))
            (set! (-> snd command) (sound-command set-param))
            (set! (-> snd id) id)
            (set! (-> snd parms volume) -4)
            (set! (-> snd parms fo-curve) 1)
            (set! (-> snd auto-time) 480)
            (set! (-> snd auto-from) 2)
            (set! (-> snd parms mask) (sound-mask fo-curve time volume))
            (-> snd id)))
         (else
          0
          ; (sound-play-by-name (static-sound-name "board-bounce")
          ;                     (new-sound-id)
          ;                     (the int (* 1024.0 (lerp-scale 1.0 0.3 (-> self board shock-offsetv) (meters -10) (meters -3))))
          ;                     0
          ;                     0
          ;                     (sound-group sfx)
          ;                     #t)
          )))
     (set! (-> self board shock-offset) (meters -0.75))
     (set! (-> self board shock-offsetv) 0.0)
     (let* ((pat (-> self control ground-pat material))
            (part (cond
                    ((= pat (pat-material sand)) group-land-poof-sand)
                    ((= pat (pat-material wood)) group-land-poof-wood)
                    ((= pat (pat-material crwood)) group-land-poof-crwood)
                    ((or (= pat (pat-material tube))
                         (= pat (pat-material pcmetal))
                         (= pat (pat-material metal))
                         (= pat (pat-material rotate)))
                     group-land-poof-pcmetal)
                    ((= pat (pat-material ice)) group-land-poof-ice)
                    ((or (= pat (pat-material snow)) (= pat (pat-material deepsnow))) group-land-poof-snow)
                    #| ((= pat (pat-material gravel)) group-land-poof-gravel) |#
                    ((= pat (pat-material dirt)) group-land-poof-dirt)
                    ((= pat (pat-material stone)) group-land-poof-stone)
                    ((= pat (pat-material grass)) group-land-poof-grass)
                    #|
                     ((= pat (pat-material waterbottom)) group-land-poof-water)
                    ((= pat (pat-material tar)) group-land-poof-tar)
                    ((= pat (pat-material straw)) group-land-poof-straw)
                    ((= pat (pat-material swamp)) group-land-poof-swamp)
                    ((= pat (pat-material neutral)) group-land-poof-neutral)
                    |#
                    (else (the sparticle-launch-group #f)))))
       (if part (process-spawn part-tracker :init part-tracker-init part -1 #f #f #f (-> self control trans) :to self)))))
  (set! (-> self control draw-offset y)
        (+ (-> self board cushion-base) (-> self board cushion-offset) (-> self board shock-offset)))
  (if (< (-> self control draw-offset y) 0.0) (set! (-> self control draw-offset y) 0.0))
  (none))

(defbehavior target-board-collision target ()
  (let ((gp-0 (new 'stack-no-clear 'vector)))
    (vector-copy! gp-0 (-> self control transv))
    (when #f ; (focus-test? self halfpipe)
      (when (-> self control unknown-spoolanim00)
        (let ((v1-9 (new-stack-vector0))
              (f0-1 (vector-dot (-> self control edge-grab-across-edge-dir) (-> self control transv))))
          (vector-! v1-9 (-> self control transv) (vector-float*! v1-9 (-> self control edge-grab-across-edge-dir) f0-1))
          (let* ((f1-2 (vector-length v1-9))
                 (f2-0 f1-2))
            (if (< 0.0 f0-1) (set! f0-1 -2048.0))
            (vector+! (-> self control transv)
                      (vector-float*! (-> self control transv) (-> self control edge-grab-across-edge-dir) f0-1)
                      (vector-float*! v1-9 v1-9 (/ f1-2 f2-0)))))))
    (fill-cache-integrate-and-collide! (-> self control) (-> self control transv) (-> self control root-prim collide-with))
    (when (and (logtest? (-> self control root-prim prim-core action) (collide-action edgegrab-possible)))
      ; (logclear! (-> *collide-edge-board-spec* flags) (collide-edge-spec-flags one))
      ; (set! (-> *collide-edge-board-spec* touching-segment) #f)
      (find-edge-grabs! *target*
                        *collide-cache*
                        #| *collide-edge-board-spec* |#
                        ))
    (target-board-physics gp-0)
    (deg-diff (vector-y-angle gp-0) (vector-y-angle (-> self control transv)))
    (let* ((v1-25 gp-0)
           (f30-0 (sqrtf (+ (* (-> v1-25 x) (-> v1-25 x)) (* (-> v1-25 z) (-> v1-25 z))))))
      (when (and (logtest? (-> self control status) (cshape-moving-flags twall))
                 (and (< (meters 4) f30-0)
                      (not (and (-> self next-state) (= (-> self next-state name) 'target-board-smack)))
                      ; (not (focus-test? self halfpipe))
                      (!= (-> self control ground-pat mode) 3)
                      (time-elapsed? (-> self board halfpipe-time) (seconds 0.1))))
        (let ((s5-1 (new 'stack-no-clear 'vector)))
          (vector-copy! s5-1 (-> self control wall-contact-normal))
          (vector-normalize! s5-1 1.0)
          (let ((s3-0 (vector-reflect! (new 'stack-no-clear 'vector) gp-0 s5-1))
                (s4-1 (new 'stack-no-clear 'vector)))
            (vector-copy! s4-1 (-> self control c-R-w fvec))
            (set! (-> s3-0 y) 0.0)
            (vector-normalize! s3-0 1.0)
            (set! (-> s4-1 y) 0.0)
            (vector-normalize! s4-1 1.0)
            (let ((f0-11 (y-angle (-> self control)))) (deg-diff f0-11 (vector-y-angle s3-0)))
            (let ((s2-1 (vector-matrix*! (new 'stack-no-clear 'vector) (-> self control transv) (-> self control w-R-c)))
                  (s3-1 (vector-matrix*! (new 'stack-no-clear 'vector) s3-0 (-> self control w-R-c))))
              ; (logior! (-> self control status) (cshape-moving-flags glance))
              (set-time! (-> self board glance-time))
              (let ((v1-64 s2-1))
                (set! (-> self board glance-speed) (sqrtf (+ (* (-> v1-64 x) (-> v1-64 x)) (* (-> v1-64 z) (-> v1-64 z))))))
              (vector-copy! (-> self board glance-normal) s5-1)
              (vector-copy! (-> self board glance-in-transv) gp-0)
              (set! (-> s3-1 y) (-> s2-1 y))
              (vector-xz-normalize! s3-1 (-> self board glance-speed))
              (vector-matrix*! (-> self control transv) s3-1 (-> self control c-R-w)))
            (vector-copy! (-> self board glance-out-transv) (-> self control transv))
            (forward-up-nopitch->quaternion (-> self control dir-targ)
                                            (vector-normalize-copy! (new 'stack-no-clear 'vector) (-> self control transv) 1.0)
                                            (vector-y-quaternion! (new 'stack-no-clear 'vector) (-> self control dir-targ)))
            (when (and (< (vector-dot s4-1 s5-1) -0.77) (not (logtest? (-> self state-flags) (state-flags dying being-attacked))))
              (cond
                ((not (and (logtest? (-> self control mod-surface flags) (surface-flags jump))
                           (not (logtest? (-> self control status) (cshape-moving-flags onsurf)))))
                 (if (< (meters 8) f30-0) (sound-play "board-glance"))
                 (go target-board-turn-to (-> self control transv) (seconds 0.2)))
                (else
                 (set! (-> self control turn-lockout-end-time)
                       (max (+ (current-time) (seconds 0.1)) (-> self control turn-lockout-end-time)))))))))))
  ; (let ((gp-3 (new 'stack-no-clear 'collide-query)))
  ;   (let ((v1-103 gp-3))
  ;     (set! (-> v1-103 radius) 1638.4)
  ;     (set! (-> v1-103 collide-with) (logclear (-> self control root-prim prim-core collide-with) (collide-spec crate)))
  ;     (set! (-> v1-103 ignore-process0) self)
  ;     (set! (-> v1-103 ignore-process1) #f)
  ;     (set! (-> v1-103 ignore-pat) (-> self control pat-ignore-mask))
  ;     (set! (-> v1-103 action-mask) (collide-action solid)))
  ;   (vector+float*! (-> gp-3 start-pos) (-> self control trans) (-> self control c-R-w fvec) 10240.0)
  ;   (vector+float*! (-> gp-3 start-pos) (-> gp-3 start-pos) (-> self control dynam gravity-normal) 8192.0)
  ;   (vector-float*! (-> gp-3 move-dist) (-> self control dynam gravity-normal) -49152.0)
  ;   (cond
  ;     ((>= (fill-and-probe-using-line-sphere *collide-cache* gp-3) 0.0)
  ;      (vector-copy! (-> self board probe-intersect) (-> gp-3 best-other-tri intersect))
  ;      (vector-copy! (-> self board probe-normal) (-> gp-3 best-other-tri normal))
  ;      (set! (-> self board probe-pat) (-> gp-3 best-other-tri pat))
  ;      (set! (-> self board probe) #t))
  ;     (else (set! (-> self board probe) #f))))
  (if (and (< (target-move-dist (-> *TARGET-bank* stuck-time)) (-> *TARGET-bank* stuck-distance))
           (not (and *cheat-mode* (cpad-hold? (-> self control cpad number) r2))))
    (set-time! (-> self control last-time-of-stuck)))
  (none))

(defbehavior target-board-joint-points target ()
  (when (-> self board board)
    (let ((joint (if (= (-> self node-list) (-> self board-node-list)) 47 67)))
      (matrix->transformq (-> self board board-tq)
                          (-> self
                              node-list
                              data
                              joint
                              #| (joint-node eichar-lod0-jg packStrapTop) |#
                              bone
                              transform)))
    (when (and (-> self next-state)
               (= (-> self next-state name) 'target-stance)
               #| (not (board?)) |#
               )
      ; (matrix->quat (-> self old-node-list data 26 bone transform) (-> self board board-tq quat))
      ; (quaternion-rotate-x! (-> self board board-tq quat) (-> self board board-tq quat) (degrees -90))
      ; (quaternion-rotate-y! (-> self board board-tq quat) (-> self board board-tq quat) (degrees 360))
      ; (quaternion-rotate-z! (-> self board board-tq quat) (-> self board board-tq quat) (degrees 180))
      ;
      )
    (vector-copy! (-> self board board-scale) (-> self control scale))
    ; (vector-copy! (-> *board-shadow-control* settings shadow-dir) (-> *target-shadow-control* settings shadow-dir))
    )
  (none))

(defbehavior target-board-pre-move target ()
  (cond
    ((and (and (logtest? (-> self control mod-surface flags) (surface-flags jump))
               (not (logtest? (-> self control status) (cshape-moving-flags onsurf))))
          (begin
            (set-time! (-> self board in-air-time))
            (and (not (and (-> self next-state)
                           (symbol-member? (-> self next-state name) '(target-board-stance target-board-duck-stance target-board-turn-to))))
                 (and (or (and (or (< (meters 5)
                                      (vector-dot (-> self control dynam gravity-normal)
                                                  (vector-! (new 'stack-no-clear 'vector) (-> self control trans) (-> self control gspot-pos))))
                                   (< 0.0 (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
                               (< (-> self control gspot-slope-z) 0.0))
                          (or (not (or (= (-> self control gspot-pat-surface mode) (pat-mode ground))
                                       (= (-> self control gspot-pat-surface mode)
                                          (the pat-mode 3)
                                          #| (pat-mode halfpipe) |#
                                          )))
                              (or (= (-> self control gspot-pat-surface event)
                                     (the pat-event 13)
                                     #| (pat-event rail) |#
                                     )
                                  (and (logtest? (-> self water flags) (water-flags wt01))
                                       (< (-> self control gspot-pos y) (-> self water surface-height)))
                                  (and (and (-> self next-state)
                                            (symbol-member? (-> self next-state name) '(target-board-hold target-board-trickx target-board-tricky)))
                                       #t
                                       #| (not (logtest? (focus-status halfpipe) (-> self focus-status))) |#
                                       )
                                  (and (= (-> self control gspot-pat-surface mode)
                                          (the pat-mode 3)
                                          #| (pat-mode halfpipe) |#
                                          )
                                       (and (< (fabs (vector-dot (-> self control gspot-normal) (-> self control dynam gravity-normal))) 0.7)
                                            #t
                                            #| (not (logtest? (focus-status halfpipe) (-> self focus-status))) |#
                                            )))))
                      (time-elapsed? (-> self board last-jump-time) (seconds 0.2))))))
     (set! (-> self control bend-speed) 0.0)
     (set! (-> self control bend-target) 0.0))
    (else
     (set! (-> self control bend-speed) 1024.0)
     (set! (-> self control bend-target) 1.0)
     (when (not (time-elapsed? (-> self board last-jump-time) (seconds 0.1)))
       (forward-up-nopitch->quaternion (-> self control dir-targ)
                                       (vector-z-quaternion! (new 'stack-no-clear 'vector) (-> self control dir-targ))
                                       (-> self control gspot-normal))
       (quaternion-slerp! (-> self control quat-for-control) (-> self control quat-for-control) (-> self control dir-targ) 0.1))))
  (if (and (cpad-hold? (-> self control cpad number) square) (not (-> self board ride-lock)))
    (logior! (-> self control root-prim prim-core action) (collide-action edgegrab-possible))
    (logclear! (-> self control root-prim prim-core action) (collide-action edgegrab-possible)))
  (if (not (cpad-hold? (-> self control cpad number) square)) (false! (-> self board ride-lock)))
  (cond
    ((and (-> self next-state) (symbol-member? (-> self next-state name) '(target-board-get-on target-board-get-off))))
    ((and (-> self next-state)
          (symbol-member? (-> self next-state name) '(target-board-trickx target-board-tricky target-board-hold)))
     (seek! (-> self control dynam gravity-length) (meters 60) (* 30.0 (seconds-per-frame))))
    ((= (-> self control mod-surface name) 'spin)
     (set! (-> self control dynam gravity-length)
           (lerp-scale (meters 60) (meters 50) (fabs (-> self board rotyv)) 0.0 (degrees 800))))
    ((and (-> self next-state) (= (-> self next-state name) 'target-board-halfpipe))
     (if (>= 0.0 (vector-dot (-> self control dynam gravity-normal) (-> self control transv)))
       (set! (-> self control dynam gravity-length) (meters 60))
       (set! (-> self control dynam gravity-length) (meters 40))))
    ((and (-> self next-state)
          (symbol-member? (-> self next-state name) '(target-board-stance target-board-duck-stance target-board-turn-to)))
     (cond
       (#f (set! (-> self control dynam gravity-length) (meters 60)))
       ((time-elapsed? (-> self control last-time-on-surface) (seconds 0.1))
        (seek! (-> self control dynam gravity-length) (meters 60) (* (meters 60) (seconds-per-frame))))
       (else (set! (-> self control dynam gravity-length) (meters 20)))))
    (else (set! (-> self control dynam gravity-length) (meters 60))))
  (vector-float*! (-> self control dynam gravity)
                  (-> self control dynam gravity-normal)
                  (-> self control dynam gravity-length))
  (if (< (-> self control force-turn-to-strength) 0.0)
    (set! (-> self control force-turn-to-strength) (- 1.0 (-> self control cpad stick0-speed))))
  (when (and (-> self board probe) ; (not (logtest? (focus-status halfpipe) (-> self focus-status)))
             )
    (let ((f30-0 (vector-dot (-> self control dynam gravity-normal)
                             (vector-! (new 'stack-no-clear 'vector) (-> self board probe-intersect) (-> self control trans))))
          (f26-0 (vector-dot (-> self control dynam gravity-normal)
                             (vector-! (new 'stack-no-clear 'vector) (-> self board probe-intersect) (-> self control gspot-pos))))
          (f28-0 (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
      (let ((f0-36 (* (-> self control local-slope-z)
                      (vector-length (vector-flatten! (new 'stack-no-clear 'vector)
                                                      (vector-! (new 'stack-no-clear 'vector) (-> self control trans) (-> self board probe-intersect))
                                                      (-> self control standard-dynamics gravity-normal))))))
        (when (and (= (-> self board probe-pat mode) (pat-mode ground))
                   (!= (-> self board probe-pat event) 13)
                   (time-elapsed? (-> self board unk-time-frame01) (seconds 0.2))
                   (< (meters 0.2) (- f30-0 f0-36))
                   (or (< (-> self board jump-end-time) (-> self control last-time-on-surface))
                       (not (time-elapsed? (-> self board jump-end-time) (seconds 0.2))))
                   (< 0.98 (vector-dot (-> self board probe-normal) (-> self control standard-dynamics gravity-normal)))
                   (< f26-0 (meters 2))
                   (< f30-0 (meters 2))
                   (or (< (/ f28-0 5) f30-0) (not (time-elapsed? (-> self board last-jump-time) (seconds 0.1)))))
          (vector+float*! (-> self control transv)
                          (-> self control transv)
                          (-> self control dynam gravity-normal)
                          (* 7.0 (fmin (meters 1) f30-0)))
          (if (time-elapsed? (-> self board last-jump-time) (seconds 0.1)) (set-time! (-> self board jump-end-time)))
          (set-time! (-> self board last-jump-time))))
      (when (and (not (logtest? (-> self control status) (cshape-moving-flags onsurf)))
                 (< 0.0 f28-0)
                 (or (and (or (< (target-height-above-ground) (meters 1)) (not (time-elapsed? (-> self board last-jump-time) (seconds 0.1))))
                          (< (meters 2) (- f28-0 (vector-dot (-> self control dynam gravity-normal) (-> self board slow-transv)))))
                     (not (time-elapsed? (-> self board unk-time-frame01) (seconds 0.1))))
                 (>= (meters 0.05) f30-0)
                 (not (and (-> self next-state) (= (-> self next-state name) 'target-board-jump))))
        (set-time! (-> self board unk-time-frame01))
        (vector-length (-> self control transv))
        (let ((v1-303 (new-stack-vector0))
              (f0-51 (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
          (vector-! v1-303 (-> self control transv) (vector-float*! v1-303 (-> self control dynam gravity-normal) f0-51))
          (let* ((f1-24 (vector-length v1-303))
                 (f2-0 f1-24)
                 (f0-52 (* 0.9 f0-51)))
            (vector+! (-> self control transv)
                      (vector-float*! (-> self control transv) (-> self control dynam gravity-normal) f0-52)
                      (vector-float*! v1-303 v1-303 (/ f1-24 f2-0)))))
        (vector-copy! (-> self board slow-transv) (-> self control transv))
        (set! (-> self board turn-anim-duck-vel) 0.0))))
  (none))

(defbehavior target-board-yellow-eco-zap-attack target ()
  (when (and (= (-> self fact eco-type) (pickup-type eco-yellow))
             (>= (-> self fact eco-level) 1.0)
             (time-elapsed? (-> self board yellow-eco-zap-last-use-time) (seconds 2)))
    (-! (-> self fact eco-timeout) (seconds 5))
    (let ((rot (new-stack-quaternion0)))
      (quaternion-copy! rot (-> self control quat))
      (dotimes (i 8)
        (process-spawn projectile-yellow
                       :init
                       projectile-init-by-other
                       (-> self entity)
                       (-> self control unknown-vector90)
                       (vector-float*! (new-stack-vector0)
                                       (vector-z-quaternion! (new-stack-vector0) rot)
                                       (-> *TARGET-bank* yellow-projectile-speed))
                       (if (>= (-> self fact eco-level) (-> *FACT-bank* eco-level-max)) 16 0)
                       #f
                       :to
                       self)
        (quaternion-rotate-y! rot rot (degrees 45))))
    (set-time! (-> self board yellow-eco-zap-last-use-time)))
  (none))

(defbehavior target-board-real-post target ()
  (let ((f30-0 (the int (-> *display* time-ratio))))
    (set-time-ratios *display* 1.0)
    (countdown (i f30-0)
      (set! (-> self control remaining-ctrl-iterations) i)
      (flag-setup)
      (target-board-pre-move)
      (build-conversions (-> self control transv))
      (do-rotations1)
      (let ((pad-vec (new-stack-vector0)))
        (read-pad pad-vec)
        (when (-> self board stick-off)
          (set! (-> self control cpad stick0-speed) 0.0)
          (set! (-> self control pad-magnitude) 0.0))
        ; (when *target-rc-board-controls*
        ;   (vector-rotate-y! pad-vec
        ;                     (-> self control c-R-w fvec)
        ;                     (* -42.666668 (+ -128.0 (the float (-> self control cpad leftx)))))
        ;   (add-debug-vector #t
        ;                     (bucket-id debug-no-zbuf1)
        ;                     (-> self control trans)
        ;                     pad-vec
        ;                     (meters 2)
        ;                     (the-as rgba (new 'static 'rgba :g #xff :a #x80))))
        (turn-to-vector pad-vec (-> self control pad-magnitude)))
      (if (and (= (-> self control pad-magnitude) 0.0)
               (>= (current-time) (-> self control turn-lockout-end-time))
               (not (logtest? (-> self control current-surface flags) (surface-flags always-rotate-toward-transv)))
               (time-elapsed? (-> self board last-jump-time) (seconds 0.1)))
        (rot->dir-targ! (-> self control)))
      (when (and (not (time-elapsed? (-> self control last-time-on-surface) (seconds 0.1)))
                 (>= (current-time) (-> self control turn-lockout-end-time))
                 (not (logtest? (-> self control current-surface flags) (surface-flags always-rotate-toward-transv)))
                 (time-elapsed? (-> self board last-jump-time) (seconds 0.1)))
        (let* ((s3-0 (vector-flatten! (new 'stack-no-clear 'vector)
                                      (vector-negate! (new 'stack-no-clear 'vector) (-> self control dynam gravity-normal))
                                      (-> self control local-normal)))
               (a2-4 (forward-up-nopitch->quaternion (new 'stack-no-clear 'quaternion)
                                                     s3-0
                                                     (vector-y-quaternion! (new 'stack-no-clear 'vector) (-> self control dir-targ)))))
          (quaternion-slerp! (-> self control dir-targ)
                             (-> self control dir-targ)
                             a2-4
                             (* 0.05 (fabs (-> self control ctrl-slope-heading))))))
      (if (cpad-pressed? (-> self control cpad number) l1) (set-time! (-> self board duck-start-time)))
      (if (cpad-pressed? (-> self control cpad number) l2) (set-time! (-> self board l2-start-time)))
      (board-add-thrust)
      (add-gravity)
      (cond
        ((= (-> self control mod-surface name) 'spin)
         (set! (-> self board rotyv)
               (* 0.95 (fmax (fmin (-> self board rotyv) (-> self board rotyv-max)) (- (-> self board rotyv-max)))))
         (let ((y-rot-inc (* (-> self board rotyv) (seconds-per-frame))))
           (set! (-> self board roty) (the float (sar (shl (the int (+ (-> self board roty) y-rot-inc)) 48) 48)))
           (set! (-> self board unk-deg00) (-> self board roty-cum))
           (+! (-> self board roty-cum) y-rot-inc))
         (seek! (-> self board rotyv-max) (degrees 500) (* (degrees 500) (seconds-per-frame)))
         (set-mode! (-> self board main) (joint-mod-handler-mode rotate))
         (set-twist! (-> self board main) (the float #f) (-> self board roty) (the float #f))
         (set-mode! (-> self board board 0 main) (joint-mod-handler-mode rotate))
         (set-twist! (-> self board board 0 main) (the float #f) (-> self board roty) (the float #f)))
        (else
         (cond
           ((!= (-> self board main mode) (joint-mod-handler-mode flex-blend))
            (let ((total-rot (fabs (-> self board roty-cum))))
              (cond
                ((>= total-rot (degrees 1050)) (add-to-trick-list (-> self board) (board-tricks board-spin) 4000.0))
                ((>= total-rot (degrees 695)) (add-to-trick-list (-> self board) (board-tricks board-spin) 2000.0))
                ((>= total-rot (degrees 270)) (add-to-trick-list (-> self board) (board-tricks board-spin) 500.0))))

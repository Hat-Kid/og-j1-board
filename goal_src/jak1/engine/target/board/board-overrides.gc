                             ;; og:j1-board changed
                             ((and (or (>= 0.0 (-> self control unknown-float12)) (< (current-time) (-> self control turn-lockout-end-time)))
                                   (not (logtest? (-> self control current-surface flags) (surface-flags turn-when-centered))))
                              0.0)
                             ((< f0-2 f1-2) 1.0)
                             (else (/ f1-2 f0-2))))
        (quaternion-slerp! (-> self control dir-targ)
                           s4-0
                           s3-1
                           (cond
                             ((>= 0.0 (-> self control unknown-float12)) 0.0)
                             ((< f0-2 f1-2) 1.0)
                             (else (/ f1-2 f0-2))))))

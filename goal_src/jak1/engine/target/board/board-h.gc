  ((jump-height-min        meters)
   (jump-height-max        meters)
   (duck-jump-height-min   meters)
   (duck-jump-height-max   meters)
   (turn-frames            float)
   (wall-kick-window       time-frame)
   (cushion                meters)
   (trickx-jump-height-min meters)
   (trickx-jump-height-max meters)
   (tricky-jump-height-min meters)
   (tricky-jump-height-max meters)
   (trickz-jump-height-min meters)
   (trickz-jump-height-max meters)
   (charge-jump-time       time-frame)
   (charge-jump-fade-time  time-frame)
   (charge-jump-height     meters)
   (zap-duration           time-frame)
   (zap-reset-time         time-frame)))

(define *TARGET_BOARD-bank*
  (new 'static
       'target-board-bank
       :jump-height-min (meters 1.01)
       :jump-height-max (meters 3.5)
       :duck-jump-height-min (meters 2.5)
       :duck-jump-height-max (meters 5)
       :turn-frames 8.0
       :wall-kick-window (seconds 0.05)
       :cushion (meters 1)
       :trickx-jump-height-min (meters 0.9)
       :trickx-jump-height-max (meters 1.2)
       :tricky-jump-height-min (meters 0.9)
       :tricky-jump-height-max (meters 1.2)
       :trickz-jump-height-min (meters 0.9)
       :trickz-jump-height-max (meters 1.2)
       :charge-jump-time (seconds 0.7)
       :charge-jump-fade-time (seconds 0.25)
       :charge-jump-height (meters 3.5)
       :zap-duration (seconds 0.25)
       :zap-reset-time (seconds 0.25)))

(define-extern can-exit-duck? (function symbol :behavior target))

(defbehavior want-to-board? target ()
  (and (not (symbol-member? (-> self next-state name) '(target-wheel target-wheel-flip target-hit-ground-hard)))
       (or (and (cpad-pressed? (-> self control unknown-cpad-info00 number) r2)
                (or (!= *cheat-mode* 'debug)
                    (not (logtest? (-> *cpad-list* cpads (-> self control unknown-cpad-info00 number) button0-abs 0) (pad-buttons l2))))
                (not *pause-lock*)
                ; (time-elapsed? (-> self control time-of-last-debug-heal) (seconds 0.1))
                ; (>= (-> self control unknown-dword11) (-> self control time-of-last-debug-float))
                )
           (or (-> self board latch?)))
       (not (or (logtest? (-> self control root-prim prim-core action)
                          (collide-action edgegrab-cam swingpole-active racer snowball tube flut))
                (logtest? (-> self state-flags) (state-flags dying being-attacked grabbed board))))
       (or (zero? (-> self board)) (time-elapsed? (-> self board board-time) (seconds 0.5)))
       (< (-> self board board-time) (-> self control unknown-dword10))
       (not (-> self board prevent-board?))
       (can-exit-duck?)
       (not (and (logtest? (-> self water flags) (water-flags wt12)) (not (logtest? (-> self water flags) (water-flags wt04)))))
       (not *artist-fix-visible*)
       (let ((cquery (new 'stack-no-clear 'collide-using-spheres-params))
             (spheres (new 'stack-no-clear 'inline-array 'sphere 3)))
         (dotimes (i 3)
           ((method-of-type sphere new) (the symbol (-> spheres i)) sphere))
         (let ((trans (new 'stack-no-clear 'vector)))
           (vector-copy! trans (-> self control trans))
           (if (logtest? (-> self control status) (cshape-moving-flags on-water)) (set! (-> trans y) (-> self water height)))
           (vector-copy! (-> spheres 0) trans)
           (+! (-> spheres 0 y) (meters 2))
           (set! (-> spheres 0 r) (meters 0.7))
           (vector-copy! (-> spheres 1) trans)
           (+! (-> spheres 1 y) (meters 3))
           (set! (-> spheres 1 r) (meters 0.7))
           (vector-copy! (-> spheres 2) trans))
         (+! (-> spheres 2 y) (meters 4))
         (set! (-> spheres 2 r) (meters 0.7))
         (set! (-> cquery spheres) spheres)
         (set! (-> cquery num-spheres) (the uint 3))
         (set! (-> cquery collide-with) (logclear (-> self control root-prim collide-with) (collide-kind projectile)))
         (set! (-> cquery proc) #f)
         (set! (-> cquery ignore-pat) (new 'static 'pat-surface :noentity #x1))
         (true! (-> cquery solid-only))
         (and (if (fill-and-probe-using-spheres *collide-cache* cquery) #f #t) (true! (-> self board latch?))))))


(define *board-shadow-control*
  (new 'static
       'shadow-control
       :settings
       (new 'static
            'shadow-settings
            :center
            (new 'static 'vector :w (the-as float #xa))
            :shadow-dir
            (new 'static 'vector :y -1.0 :w 614400.0)
            :bot-plane
            (new 'static 'plane :y 1.0 :w 81920.0)
            :top-plane
            (new 'static 'plane :y 1.0 :w 2048.0))))

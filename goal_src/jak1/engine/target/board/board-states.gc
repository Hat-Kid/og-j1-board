;;-*-Lisp-*-
(in-package goal)
(defbehavior ground-tween-initialize-board target ((arg0 ground-tween-info) (arg1 uint) (arg2 uint) (arg3 uint) (arg4 uint) (arg5 uint) (arg6 uint) (arg7 float))
  (set! (-> arg0 group 0) arg2)
  (set! (-> arg0 group 1) arg3)
  (set! (-> arg0 group 2) arg4)
  (set! (-> arg0 group 3) arg5)
  (set! (-> arg0 group 4) arg6)
  (dotimes (s2-0 3)
    (set! (-> arg0 chan s2-0) (+ arg1 s2-0))
    (let ((s1-0 (-> self skel root-channel (-> arg0 chan s2-0))))
      (let ((f0-1 (fabs (-> arg0 blend s2-0)))) (set! (-> s1-0 frame-interp) f0-1))
      (joint-control-channel-group-eval! s1-0 (the art-joint-anim arg2) num-func-identity)
      (set! (-> s1-0 frame-num) arg7)))
  arg0)

(defbehavior ground-tween-update-board target ((arg0 ground-tween-info) (arg1 float) (arg2 float) (arg3 float))
  (let ((f0-1 (fmax -1.0 (fmin 1.0 arg1)))
        (f30-0 (fmax -1.0 (fmin 1.0 arg2))))
    (let ((f1-5 (fabs (- f0-1 (-> arg0 blend 1)))))
      (seek! (-> arg0 blend 1) f0-1 (fmax (fmin (* f1-5 arg3) (* 0.8 arg3)) (/ arg3 5))))
    (let ((f0-9 (fabs (- f30-0 (-> arg0 blend 2)))))
      (seek! (-> arg0 blend 2) f30-0 (fmax (fmin (* f0-9 arg3) (* 0.8 arg3)) (/ arg3 5)))))
  (cond
    ((>= (-> arg0 blend 1) 0.0)
     (let ((v1-12 (-> self skel root-channel (-> arg0 chan 1))))
       (let ((f0-16 (fabs (-> arg0 blend 1)))) (set! (-> v1-12 frame-interp) f0-16))
       (set! (-> v1-12 frame-group) (the art-joint-anim (-> arg0 group 1)))))
    (else
     (let ((v1-15 (-> self skel root-channel (-> arg0 chan 1))))
       (let ((f0-18 (fabs (-> arg0 blend 1)))) (set! (-> v1-15 frame-interp) f0-18))
       (set! (-> v1-15 frame-group) (the art-joint-anim (-> arg0 group 2))))))
  (cond
    ((>= (-> arg0 blend 2) 0.0)
     (let ((v1-18 (-> self skel root-channel (-> arg0 chan 2))))
       (let ((f0-21 (fabs (-> arg0 blend 2)))) (set! (-> v1-18 frame-interp) f0-21))
       (set! (-> v1-18 frame-group) (the art-joint-anim (-> arg0 group 4)))))
    (else
     (let ((v1-21 (-> self skel root-channel (-> arg0 chan 2))))
       (let ((f0-23 (fabs (-> arg0 blend 2)))) (set! (-> v1-21 frame-interp) f0-23))
       (set! (-> v1-21 frame-group) (the art-joint-anim (-> arg0 group 3))))))
  (none))

(defun vector-vector-angle ((arg0 vector) (arg1 vector))
  (let ((s4-0 (new 'stack-no-clear 'matrix))
        (gp-0 (new 'stack-no-clear 'matrix))
        (s3-0 (new 'stack-no-clear 'vector)))
    (forward-up-nopitch->inv-matrix gp-0 (new 'static 'vector :z 1.0 :w 1.0) arg1)
    (matrix-transpose! s4-0 gp-0)
    (vector-matrix*! s3-0 arg0 s4-0)
    (vector-y-angle s3-0)))

(defbehavior target-time-to-ground target ()
  (let ((f0-0 (target-height-above-ground))
        (f2-0 (vector-dot (-> self control dynam gravity-normal) (-> self control transv)))
        (f1-1 0.0))
    (while (< 0.0 f0-0)
      (set! f1-1 (+ 5.0 f1-1))
      (+! f0-0 (* f2-0 (seconds-per-frame)))
      (set! f2-0 (- f2-0 (* (-> self control dynam gravity-length) (seconds-per-frame)))))
    (the time-frame f1-1)))

(defbehavior jump-hit-ground-stuck? target ()
  (or (logtest? (-> self control status) (cshape-moving-flags onsurf))
      (when (and (< (target-move-dist (-> *TARGET-bank* stuck-time)) (-> *TARGET-bank* stuck-distance))
                 (not (and *cheat-mode* (cpad-hold? (-> self control cpad number) r2))))
        (set-time! (-> self control unknown-dword36))
        #t)))

(defbehavior target-board-anim-trans target ()
  (let ((f26-0 (deg- (quaternion-vector-y-angle (-> self control dir-targ) (-> self control local-normal))
                     (quaternion-vector-y-angle (-> self control quat-for-control) (-> self control local-normal))))
        (f28-0 (* (deg- (quaternion-vector-y-angle (-> self control quat-for-control) (-> self control local-normal))
                        (quaternion-vector-y-angle (-> self control last-quat-for-control) (-> self control local-normal)))
                  (-> *display* frames-per-second)))
        (f30-0 (-> self board turn-anim-targ)))
    (let ((f0-1 (lerp-scale 1.0 -1.0 f28-0 -32768.0 32768.0)))
      (if (or (< (fabs f0-1) 0.1) (< (-> self control turn-to-magnitude) 0.3))
        (seek! (-> self board turn-anim-mag) 0.0 (* 8.0 (seconds-per-frame)))
        (seek! (-> self board turn-anim-mag) f0-1 (* 2.0 (seconds-per-frame)))))
    (set! (-> self board turn-anim-targ)
          (+ (lerp-scale (/ (-> *TARGET_BOARD-bank* turn-frames) 2)
                         (/ (-> *TARGET_BOARD-bank* turn-frames) -2)
                         f26-0
                         -5461.3335
                         5461.3335)
             (lerp-scale (* 0.3 (-> *TARGET_BOARD-bank* turn-frames))
                         (* -0.3 (-> *TARGET_BOARD-bank* turn-frames))
                         f28-0
                         -32768.0
                         32768.0)
             (lerp-scale (/ (-> *TARGET_BOARD-bank* turn-frames) 5)
                         (/ (-> *TARGET_BOARD-bank* turn-frames) -5)
                         (-> self board turn-anim-mag)
                         1.0
                         -1.0)))
    (when (and (or (< (* f30-0 (-> self board turn-anim-targ)) 0.0) (= f30-0 0.0))
               (and (< (/ (-> *TARGET_BOARD-bank* turn-frames) 5) (fabs (- f30-0 (-> self board turn-anim-targ))))
                    (>= (current-time) (-> self control turn-lockout-end-time))))
      (let ((v1-50 (the sound-rpc-set-param (get-sound-buffer-entry))))
        (set! (-> v1-50 command) (sound-command set-param))
        (set! (-> v1-50 id) (-> self board turn-sound-id))
        (set! (-> v1-50 parms volume) -4)
        (set! (-> v1-50 auto-time) 120)
        (set! (-> v1-50 auto-from) 2)
        (set! (-> v1-50 parms mask) (sound-mask volume time))
        (-> v1-50 id))
      (set! (-> self board turn-sound-id) (sound-play "board-turn"))))
  (set! (-> self board turn-anim-duck-vel) (* 0.98 (-> self board turn-anim-duck-vel)))
  (+! (-> self board turn-anim-duck-vel) (* -8.0 (seconds-per-frame)))
  (when (and (board-on-ground?) (time-elapsed? (-> self board unk-time-frame01) (seconds 0.2)))
    (if (logtest? (-> self control status) (cshape-moving-flags csmf11)) ;; impact-surface
      (+! (-> self board turn-anim-duck-vel) (lerp-scale 0.0 15.0 (-> self control normal-impact-vel) 0.0 81920.0)))
    (let ((f0-38 (vector-dot (-> self board up-vector 0) (-> self board up-vector 1))))
      (if (< f0-38 1.0) (+! (-> self board turn-anim-duck-vel) (* (lerp-scale 400.0 0.0 f0-38 0.6 1.0) (seconds-per-frame))))))
  (none))

;; WARN: Return type mismatch object vs none.
(defbehavior target-board-spin-check target ()
  (when (and (or (cpad-pressed? (-> self control cpad number) r1)
                 (and (cpad-hold? (-> self control cpad number) r1) (time-elapsed? (-> self board spin-check-time) (seconds 0.3))))
             (and (not (and (and (-> self next-state) (symbol-member? (-> self next-state name) '(target-board-tricky target-board-hold)))
                            (not (time-elapsed? (-> self board spin-start-time) (seconds 0.5)))))
                  (not (and (= *cheat-mode* 'debug) (cpad-hold? (-> self control cpad number) r2)))))
    (set-time! (-> self board spin-start-time))
    (vector-copy! (-> self board spin-start-dir) (-> self node-list data 3 bone transform fvec))
    (vector-flatten! (-> self control turn-to-alt-heading) (-> self control unknown-matrix01 fvec) *up-vector*)
    (vector-normalize! (-> self control turn-to-alt-heading) 1.0)
    (rot->dir-targ! (-> self control))
    (set! (-> self board rotyv-max)
          (lerp-scale (degrees 1200) (degrees 500) (the float (- (current-time) (-> self control unknown-dword11))) 0.0 300.0))
    (set! (-> self board rotyv) 0.0)
    (set! (-> self board roty) 0.0)
    (set! (-> self board roty-cum) 0.0)
    (set! (-> self board unk-deg00) 0.0)
    (set! (-> self board spin-sound-id) (new 'static 'sound-id))
    (set! (-> self control mod-surface) *board-spin-mods*))
  (cond
    ((and (cpad-hold? (-> self control cpad number) r1)
          (or (= (-> self control mod-surface name) 'spin) (not (time-elapsed? (-> self board spin-time) (seconds 0.05))))
          (not (and (= *cheat-mode* 'debug) (cpad-hold? (-> self control cpad number) r2))))
     (false! (-> self board turn-anim-tilt?))
     (set! (-> self control mod-surface) *board-spin-mods*)
     (set-time! (-> self board spin-time))
     (let ((gp-0 (new 'stack-no-clear 'vector)))
       (set! (-> gp-0 x) (* -0.0078125 (+ -128.0 (the float (-> self control cpad leftx)))))
       (set! (-> gp-0 y) 0.0)
       (set! (-> gp-0 z) (* -0.0078125 (+ -128.0 (the float (-> self control cpad lefty)))))
       (set! (-> gp-0 w) 0.0)
       (let ((f28-0 (analog-input (the int (* 128.0 (-> gp-0 x))) 0.0 64.0 110.0 2184533.2))
             (f30-0 (analog-input (the int (* 128.0 (-> gp-0 z))) 0.0 96.0 110.0 1.0)))
         (if (and (zero? (-> self board spin-sound-id)) (< 5461.3335 (fabs (-> self board rotyv))))
           (set! (-> self board spin-sound-id) (sound-play "board-spin-loop")))
         (if (and (< (* 0.9 (fabs (-> self board spin-control))) (fabs f28-0)) (>= (* (-> self board spin-control) f28-0) 0.0))
           (set! (-> self board spin-control) f28-0))
         (if (not (-> self control unknown-symbol30)) (target-danger-set! 'board-spin #f))
         ;; og:preserve-this changed for high fps
         (+! (-> self board rotyv) (* (-> self board spin-control) (seconds-per-frame)))
         (when (and (< (fabs f28-0) (degrees 6000))
                    (< (fabs (-> self board spin-control)) (degrees 6000))
                    (< (* 0.9 (fabs (-> self board flip-control))) (fabs f30-0))
                    (>= (* (-> self board flip-control) f30-0) 0.0)
                    (not (board-on-ground?))
                    (< 0.0 (vector-dot (-> self control dynam gravity-normal) (-> self control transv)))
                    (>= (target-height-above-ground) (meters 1)))
           (set! (-> self board flip-control) f30-0)
           (go target-board-flip
               (-> *TARGET_BOARD-bank* jump-height-min)
               (-> *TARGET_BOARD-bank* jump-height-max)
               #f ; (if (focus-test? self halfpipe) 'halfpipe)
               )))))
    (else (set! (-> self control mod-surface) (-> self board mods-backup))))
  (set-time! (-> self board spin-check-time))
  (cond
    ((and (or (cpad-pressed? (-> self control cpad number) l1)
              (< (-> self control unknown-dword11) (-> self board duck-start-time)))
          (not (and (= *cheat-mode* 'debug) (cpad-hold? (-> self control cpad number) r2))))
     (set! (-> self board turn-anim-tilt?) #f)
     (set! (-> self control mod-surface) *board-spin-mods*)
     (set-time! (-> self board unk-time000))
     (let ((gp-2 (new 'stack-no-clear 'vector)))
       (set! (-> gp-2 x) (* -0.0078125 (+ -128.0 (the float (-> self control cpad leftx)))))
       (set! (-> gp-2 y) 0.0)
       (set! (-> gp-2 z) (* -0.0078125 (+ -128.0 (the float (-> self control cpad lefty)))))
       (set! (-> gp-2 w) 0.0)
       (let ((f30-1 (analog-input (the int (* 128.0 (-> gp-2 x))) 0.0 64.0 110.0 1.0))
             (f28-1 (analog-input (the int (* 128.0 (-> gp-2 z))) 0.0 96.0 110.0 1.0)))
         (when (and (< (fabs f30-1) 0.5)
                    (< (fabs (-> self board unk-float005)) 0.5)
                    (= (-> self board unk-float006) 0.0)
                    (< (* 0.9 (fabs (-> self board unk-float006))) (fabs f28-1))
                    (>= (* (-> self board unk-float006) f28-1) 0.0)
                    (and (not (board-on-ground?))
                         (< 0.0 (vector-dot (-> self control dynam gravity-normal) (-> self control transv)))
                         (and (>= (target-height-above-ground) (meters 1))
                              (< (seconds 0.165) (target-time-to-ground))
                              (time-elapsed? (-> self board tricky-exit-time) (seconds 0.05))
                              (< (-> self board tricky-exit-time) (-> self board duck-start-time)))))
           (set! (-> self board unk-float006) f28-1)
           (go target-board-tricky
               (-> *TARGET_BOARD-bank* tricky-jump-height-min)
               (-> *TARGET_BOARD-bank* tricky-jump-height-max)
               #f ; (if (focus-test? self halfpipe) 'halfpipe)
               ))
         (when (and (< (fabs f28-1) 0.5)
                    (< (fabs (-> self board unk-float006)) 0.5)
                    (= (-> self board unk-float005) 0.0)
                    (< (* 0.9 (fabs (-> self board unk-float005))) (fabs f30-1))
                    (>= (* (-> self board unk-float005) f30-1) 0.0)
                    (and (not (board-on-ground?))
                         (< 0.0 (vector-dot (-> self control dynam gravity-normal) (-> self control transv)))
                         (and (>= (target-height-above-ground) (meters 1))
                              (< (seconds 0.165) (target-time-to-ground))
                              (time-elapsed? (-> self board tricky-exit-time) (seconds 0.05)))))
           (set! (-> self board unk-float005) f30-1)
           (go target-board-trickx
               (-> *TARGET_BOARD-bank* trickx-jump-height-min)
               (-> *TARGET_BOARD-bank* trickx-jump-height-max)
               #f ; (if (focus-test? self halfpipe) 'halfpipe)
               )))))
    ((and (or (cpad-pressed? (-> self control cpad number) l2)
              (< (-> self control unknown-dword11) (-> self board l2-start-time)))
          (not (and (= *cheat-mode* 'debug) (cpad-hold? (-> self control cpad number) r2))))
     (false! (-> self board turn-anim-tilt?))
     (set! (-> self control mod-surface) *board-spin-mods*)
     (set-time! (-> self board unk-time001))
     (let ((gp-5 (new 'stack-no-clear 'vector)))
       (set! (-> gp-5 x) (* -0.0078125 (+ -128.0 (the float (-> self control cpad leftx)))))
       (set! (-> gp-5 y) 0.0)
       (set! (-> gp-5 z) (* -0.0078125 (+ -128.0 (the float (-> self control cpad lefty)))))
       (set! (-> gp-5 w) 0.0)
       (let ((f30-2 (analog-input (the int (* 128.0 (-> gp-5 x))) 0.0 64.0 110.0 1.0))
             (f28-2 (analog-input (the int (* 128.0 (-> gp-5 z))) 0.0 96.0 110.0 1.0)))
         (when (and (< (fabs f30-2) 0.5)
                    (< (fabs (-> self board unk-float005)) 0.5)
                    (= (-> self board unk-float006) 0.0)
                    (< (* 0.9 (fabs (-> self board unk-float006))) (fabs f28-2))
                    (>= (* (-> self board unk-float006) f28-2) 0.0)
                    (and (not (board-on-ground?))
                         (< 0.0 (vector-dot (-> self control dynam gravity-normal) (-> self control transv)))
                         (and (>= (target-height-above-ground) (meters 1))
                              (< (seconds 0.165) (target-time-to-ground))
                              (time-elapsed? (-> self board hold-exit-time) (seconds 0.05))
                              (< (-> self board hold-exit-time) (-> self board l2-start-time)))))
           (set! (-> self board unk-float006) f28-2)
           (go target-board-hold
               (-> *TARGET_BOARD-bank* trickz-jump-height-min)
               (-> *TARGET_BOARD-bank* trickz-jump-height-max)
               #f ; (if (focus-test? self halfpipe) 'halfpipe)
               ))
         (when (and (< (fabs f28-2) 0.5)
                    (< (fabs (-> self board unk-float006)) 0.5)
                    (= (-> self board unk-float005) 0.0)
                    (< (* 0.9 (fabs (-> self board unk-float005))) (fabs f30-2))
                    (>= (* (-> self board unk-float005) f30-2) 0.0)
                    (and (not (board-on-ground?))
                         (< 0.0 (vector-dot (-> self control dynam gravity-normal) (-> self control transv)))
                         (and (>= (target-height-above-ground) (meters 1))
                              (< (seconds 0.165) (target-time-to-ground))
                              (time-elapsed? (-> self board hold-exit-time) (seconds 0.05)))))
           (set! (-> self board unk-float005) f30-2)
           (go target-board-hold
               (-> *TARGET_BOARD-bank* trickz-jump-height-min)
               (-> *TARGET_BOARD-bank* trickz-jump-height-max)
               #f ; (if (focus-test? self halfpipe) 'halfpipe)
               ))))))
  (none))

(defbehavior target-board-halfpipe-trans target ()
  #|
   (when (and (focus-test? self halfpipe) *camera*)
    (let ((gp-0 (new 'stack-no-clear 'vector)))
      (let ((s5-0 (camera-master-method-15 *camera* (new 'stack-no-clear 'vector))))
        (vector-flatten! gp-0 (-> self control unknown-vector101) (-> *camera* local-down))
        (when (< (vector-dot gp-0 s5-0) 0.0)
          (let* ((v1-11 (camera-master-method-14 *camera* (new 'stack-no-clear 'vector)))
                 (f0-3 (vector-dot (-> self control unknown-vector100) v1-11))
                 (s4-1 (vector-float*! (new 'stack-no-clear 'vector) (-> self control unknown-vector100) f0-3)))
            (vector-flatten! s4-1 s4-1 (-> *camera* local-down))
            (if (< 0.0 (vector-dot s4-1 s5-0)) (vector-negate! gp-0 s4-1)))))
      (vector-normalize! gp-0 8192.0)
      (+! (-> gp-0 y) 40960.0)
      (vector+! gp-0 gp-0 (get-trans self 6))
      (vector-! gp-0 gp-0 (get-trans self 0))
      (send-event *camera* 'relative-position gp-0))
    (set-setting! 'matrix-blend-max-angle 'abs (degrees 12.000001) 0)
    (set-setting! 'matrix-blend-max-partial 'abs 0.5 0))
  |#
  (none))

(defbehavior target-board-resolve-points target ()
  (when (= (-> self board main mode) (joint-mod-handler-mode rotate))
    (let ((f0-1 (fabs (-> self board roty-cum))))
      (cond
        ((>= f0-1 (degrees 1050)) (add-to-trick-list (-> self board) (board-tricks board-spin) 4000.0))
        ((>= f0-1 (degrees 695)) (add-to-trick-list (-> self board) (board-tricks board-spin) 2000.0))
        ((>= f0-1 (degrees 270)) (add-to-trick-list (-> self board) (board-tricks board-spin) 500.0)))))
  (set! (-> self board roty-cum) 0.0)
  (set! (-> self board flip-count) 0)
  (if (time-elapsed? (-> self board in-air-time) (seconds 0.2)) (flush-trick-list (-> self board)))
  (none))

;; WARN: Return type mismatch symbol vs none.
(defbehavior target-board-ground-check target ()
  (when (board-on-ground?)
    (when (!= (-> self board roty-cum) 0.0)
      (let ((f30-0 (fabs (-> self board roty-cum)))
            (f28-0 (vector-y-angle (-> self control transv)))
            (f0-2 (y-angle (-> self control))))
        (if (not (time-elapsed? (-> self board halfpipe-time) (seconds 0.1))) (set! f28-0 (+ (degrees 180) f28-0)))
        (let ((f0-5 (fabs (deg-diff f0-2 f28-0))))
          (when (and (>= f30-0 (degrees 230)) (>= (degrees 180) f0-5))
            (cond
              ((>= f30-0 (degrees 1050)) (add-to-trick-list (-> self board) (board-tricks board-boost) 2000.0))
              ((>= f30-0 (degrees 695)) (add-to-trick-list (-> self board) (board-tricks board-boost) 1000.0))
              (else (add-to-trick-list (-> self board) (board-tricks board-boost) 500.0)))
            (let ((f30-1 (lerp-scale (meters 5) (meters 10) f30-0 (degrees 270) (degrees 1000))))
              (vector+float*! (-> self control transv)
                              (-> self control transv)
                              (vector-normalize-copy! (new 'stack-no-clear 'vector) (-> self control transv) 1.0)
                              f30-1))
            (if (< (vector-length (-> self control transv)) (meters 28)) (vector-normalize! (-> self control transv) (meters 28)))
            (when (not (logtest? (-> self control old-status) (cshape-moving-flags onsurf)))
              (let ((gp-2 (new 'stack-no-clear 'vector)))
                (vector-copy! gp-2 (-> self control trans))
                (+! (-> gp-2 y) (meters 0.5))
                ; (vector-copy! (-> *launch-matrix* trans) gp-2)
                ; (part-tracker-spawn part-tracker :to self :group group-board-land-straight)
                ; (let ((s5-3 (process-spawn manipy
                ;                            :init
                ;                            manipy-init
                ;                            gp-2
                ;                            (-> self entity)
                ;                            (art-group-get-by-name *level* "skel-generic-blast" (the (pointer level) #f))
                ;                            #f
                ;                            0
                ;                            :name "manipy"
                ;                            :to
                ;                            self
                ;                            :stack-size #x20000)))
                ;   (when s5-3
                ;     (quaternion-copy! (-> (the process-drawable (-> s5-3 0)) root quat) (-> self control quat-for-control))
                ;     (send-event (ppointer->process s5-3) 'anim-mode 'play1)
                ;     (send-event (ppointer->process s5-3) 'anim "idle")
                ;     (send-event (ppointer->process s5-3) 'speed 1.5)
                ;     (set-vector! (-> (the process-drawable (-> s5-3 0)) root scale) 0.2 0.4 0.2 1.0)))
                )
              (cpad-set-buzz! (-> *cpad-list* cpads 0) 1 255 (seconds 0.3))
              (sound-play "board-boost"))))))
    (target-board-resolve-points))
  (true! (-> self board turn-anim-tilt?))
  (none))

(defbehavior target-board-halfpipe-check target ()
  #|
   (local-vars (v0-3 collide-action))
  (let ((gp-0 (vector-flatten! (new-stack-vector0) (-> self control dynam gravity-normal) (-> self control unknown-vector53))))
    (vector-normalize! gp-0 1.0)
    (cond
      ((and (board-on-ground?)
            (= (-> self control ground-pat mode) (pat-mode halfpipe))
            (< 0.0 (vector-dot (-> self control transv) gp-0))
            (and (< (-> self control surface-angle) 0.3) (zero? (-> self board halfpipe-side-time))))
       (set-time! (-> self board halfpipe-side-time))
       (set! v0-3 (logior (-> self control root-prim prim-core action) (collide-action no-normal-reset)))
       (set! (-> self control root-prim prim-core action) v0-3)
       v0-3)
      (else
       (if (and (not (board-on-ground?))
                (nonzero? (-> self board halfpipe-side-time))
                (time-elapsed? (-> self board halfpipe-side-time) (seconds 0.05)))
         (go target-board-halfpipe))
       (when (time-elapsed? (-> self board halfpipe-side-time) (seconds 0.2))
         (set! (-> self board halfpipe-side-time) 0)
         (set! v0-3 (logclear (-> self control root-prim prim-core action) (collide-action no-normal-reset)))
         (set! (-> self control root-prim prim-core action) v0-3)
         v0-3))))
  |#
  )

(defbehavior target-board-jump-trans target ()
  (when (and (!= (-> self state-time) (current-time)) (jump-hit-ground-stuck?))
    (set-time! (-> self board jump-land-time))
    (go target-board-hit-ground))
  (if (time-elapsed? (-> self state-time) (seconds 0.1)) (target-board-smack-surface?))
  (if (and (cpad-pressed? (-> self control cpad number) x)
           (< (vector-dot (-> self control dynam gravity-normal) (-> self control transv)) (meters 3))
           (and (< (meters -15) (vector-dot (-> self control dynam gravity-normal) (-> self control transv)))
                (not (logtest? (water-flags wt09) (-> self water flags)))
                ; (not (logtest? (-> self target-flags) (target-flags prevent-jump)))
                (not (and (-> self next-state) (= (-> self next-state name) 'target-board-wall-kick)))))
    (go target-board-jump-kick))
  (target-board-spin-check)
  (none))

(defstate target-board-start (target)
  :event target-board-handler
  :exit target-board-exit
  :code
    (behavior ((arg0 handle))
      (target-board-init)
      (remove-exit)
      (go target-board-get-on))
  :post target-post)

(defstate target-board-stance (target)
  :event
    (behavior ((proc process) (argc int) (message symbol) (block event-message-block))
      (case message
        ; (('lip)
        ;  (when (and (= (-> self control ground-pat mode) (pat-mode halfpipe))
        ;             (< (-> self control poly-angle) 0.5)
        ;             (let ((s5-0 (vector-flatten! (new-stack-vector0) (-> self control dynam gravity-normal) (-> self control unknown-vector53))))
        ;               (vector-normalize! s5-0 1.0)
        ;               (< 0.0 (vector-dot (-> self control transv) s5-0))))
        ;    (set-time! (-> self board halfpipe-lip-time))
        ;    (set-time! (-> self board halfpipe-side-time))
        ;    (set! (-> self board halfpipe-lip-event) (the symbol (-> block param 0)))
        ;    (let ((v0-2 (the object (logior (-> self control root-prim prim-core action) (collide-action no-normal-reset)))))
        ;      (set! (-> self control root-prim prim-core action) (the collide-action v0-2))
        ;      v0-2)))
        (else (target-board-handler proc argc message block))))
  :enter
    (behavior ()
      (set! (-> self control mod-surface) *board-walk-mods*)
      (set! (-> self board mods-backup) (-> self control mod-surface)))
  :exit
    (behavior ()
      (when (not (and (-> self next-state) (symbol-member? (-> self next-state name) '(target-board-stance target-board-duck-stance))))
        (set! (-> self board halfpipe-side-time) 0))
      (logclear! (-> self control root-prim prim-core action) (collide-action no-normal-reset))
      (false! (-> self board turn-anim-tilt?))
      (when (not (and (-> self next-state)
                      (symbol-member? (-> self next-state name)
                                      '(target-board-stance target-board-duck-stance target-board-ride-edge target-board-launch))))
        (set! (-> self board turn-anim-frame) 0.0)
        (set! (-> self board turn-anim-mag) 0.0)
        (set! (-> self board turn-anim-vel) 0.0)
        (set! (-> self board turn-anim-duck) 0.0))
      (target-board-exit))
  :trans
    (behavior ()
      (if (and (cpad-hold? (-> self control cpad number) l1)
               (not (logtest? (-> self state-flags) (state-flags prevent-duck)))
               (not (time-elapsed? (-> self control unknown-dword11) (-> *TARGET-bank* ground-timeout))))
        (go target-board-duck-stance))
      (when (and (cpad-pressed? (-> self control cpad number) square)
                 (and (and (= (-> self fact eco-type) (pickup-type eco-yellow)) (>= (-> self fact eco-level) 1.0))
                      (time-elapsed? (-> self control unknown-dword82) (seconds 0.5))))
        (process-spawn projectile-yellow
                       :init
                       projectile-init-by-other
                       (-> self entity)
                       (-> self control unknown-vector90)
                       (vector-float*! (new 'stack-no-clear 'vector)
                                       (vector-z-quaternion! (new 'stack-no-clear 'vector) (-> self control quat))
                                       (-> *TARGET-bank* yellow-projectile-speed))
                       (if (>= (-> self fact eco-level) (-> *FACT-bank* eco-level-max)) 16 0)
                       #f
                       :to
                       self)
        (set-time! (-> self control unknown-dword82))
        ; (go target-board-yellow-blast)
        )
      ;; og:preserve-this - High FPS Fix
      (when (and (recently-pressed? x) (can-jump? 'board))
        (let ((gp-0 (vector-flatten! (new-stack-vector0) (-> self control dynam gravity-normal) (-> self control unknown-vector53))))
          (vector-normalize! gp-0 1.0)
          (cond
            ; ((and (not (time-elapsed? (-> self board halfpipe-jump-time) (seconds 0.5)))
            ;       (= (-> self control ground-pat mode) (pat-mode halfpipe))))
            ; ((and (= (-> self control ground-pat mode) (pat-mode halfpipe))
            ;       (< 0.0 (vector-dot (-> self control transv) gp-0))
            ;       (< (-> self control surface-angle) 0.5))
            ;  (set-time! (-> self board halfpipe-jump-time))
            ;  (vector-float*! (-> self control transv)
            ;                  (-> self control transv)
            ;                  (+ 1.0 (/ (-> *setting-control* user-current halfpipe-jump-mult) 2))))
            (else
             (flush-trick-list (-> self board))
             (go target-board-jump
                 (-> *TARGET_BOARD-bank* jump-height-min)
                 (-> *TARGET_BOARD-bank* jump-height-max)
                 (the surface #f))))))
      (if (cpad-pressed? (-> self control cpad number) r1) (set-time! (-> self board spin-ground-press-time)))
      (when (and (can-feet?)
                 (and (cpad-pressed? (-> self control cpad number) triangle) (< (target-height-above-ground) (meters 2))))
        (cond
          (#t
           #| (= (-> self ext-anim) (target-anim board)) |#
           (go target-board-turn-around))
          ((not (time-elapsed? (-> self board spin-ground-press-time) (seconds 0.3)))
           (set-time! (-> self board spin-ground-start-time)))))
      (target-board-halfpipe-check)
      (if (target-board-smack-surface?) 0)
      (target-board-anim-trans)
      (cond
        ((board-on-ground?)
         (target-board-ground-check)
         (set! (-> self control mod-surface) *board-walk-mods*)
         (set! (-> self board mods-backup) (-> self control mod-surface)))
        ((and (time-elapsed? (-> self control unknown-dword11) (seconds 0.1))
              (or (= (-> self control mod-surface name) 'spin) (< (meters 1) (target-height-above-ground))))
         (set! (-> self control mod-surface) *board-jump-mods*)
         (set! (-> self board mods-backup) (-> self control mod-surface))
         (target-board-spin-check))
        (else
         (set! (-> self control mod-surface) *board-air-mods*)
         (set! (-> self board mods-backup) (-> self control mod-surface)))))
  :code
    (behavior ()
      (let ((gp-0 (-> self board stance-info)))
        (let ((f30-0 0.0))
          (let ((s5-0 30)
                (v1-3 (ja-group)))
            (when (not (and (and v1-3 (= v1-3 eichar-board-turn-left-ja)) (= (ja-group-size) 4)))
              (let ((v1-10 (ja-group)))
                (cond
                  ((and v1-10 (= v1-10 eichar-board-get-on-ja))
                   (ja-channel-set! 1)
                   (ja-no-eval :group! eichar-board-get-on-land-ja :num! (seek! max 1.8) :frame-num 0.0)
                   (until (ja-done? 0)
                     (suspend)
                     (ja :num! (seek! max 1.8)))
                   (suspend)
                   (set! (-> self board turn-anim-duck) 1.0)
                   (set! (-> self board turn-anim-duck-vel) 15.0))
                  ((let ((v1-45 (ja-group))) (and v1-45 (= v1-45 eichar-board-turn-around-ja))) (set! s5-0 60))))
              (ja-channel-push! 4 (the time-frame s5-0))
              (set! f30-0 (ja-frame-num 0))))
          (ground-tween-initialize-board gp-0
                                         (the uint 0)
                                         (the uint eichar-board-turn-ja)
                                         (the uint eichar-board-turn-up-ja)
                                         (the uint eichar-board-turn-down-ja)
                                         (the uint eichar-board-turn-right-ja)
                                         (the uint eichar-board-turn-left-ja)
                                         f30-0))
        (ja :chan 3 :group! eichar-board-duck-turn-ja)
        (until #f
          (target-board-turn-anim 0)
          (let ((f0-10 (* 1.6 (-> self control ctrl-slope-z)))
                (f1-2 (* 1.6 (-> self control ctrl-slope-x))))
            (cond
              ((not (-> self board turn-anim-tilt?)) (set! f0-10 0.0) (set! f1-2 0.0))
              ; ((= (-> self control ground-pat mode) (pat-mode halfpipe)) (set! f0-10 0.0))
              )
            (ground-tween-update-board gp-0 f0-10 f1-2 0.1))
          (ja :chan 1 :num! (chan 0))
          (ja :chan 2 :num! (chan 0))
          (cond
            ((>= (-> self board turn-anim-duck) 0.0) (ja :chan 3 :frame-interp (-> self board turn-anim-duck) :num! (chan 0)))
            (else (ja :chan 3 :frame-interp (- (-> self board turn-anim-duck)) :num! (chan 0))))
          (suspend)
          (can-play-stance-amibent?)))
      #f)
  :post target-board-post)

(defstate target-board-duck-stance (target)
  :event
    (-> target-board-stance
        event)
  :enter
    (behavior ()
      (set! (-> self control mod-surface) *board-duck-mods*)
      (set! (-> self board mods-backup) (-> self control mod-surface)))
  :exit
    (behavior ()
      (set! (-> self board turn-anim-duck-vel) -8.0)
      ((-> target-board-stance exit)))
  :trans
    (behavior ()
      (if (and (or (not (cpad-hold? (-> self control cpad number) l1))
                   (logtest? (-> self state-flags) (state-flags prevent-duck))
                   (time-elapsed? (-> self control unknown-dword11) (-> *TARGET-bank* ground-timeout)))
               (can-exit-duck?))
        (go target-board-stance))
      ;; og:preserve-this - High FPS Fix
      (when (and (recently-pressed? x) (can-jump? 'board))
        (let ((gp-0 (vector-flatten! (new-stack-vector0) (-> self control dynam gravity-normal) (-> self control unknown-vector53))))
          (vector-normalize! gp-0 1.0)
          (cond
            ; ((and (not (time-elapsed? (-> self board halfpipe-jump-time) (seconds 0.5)))
            ;       (= (-> self control ground-pat mode) (pat-mode halfpipe))))
            ; ((and (= (-> self control ground-pat mode) (pat-mode halfpipe))
            ;       (< 0.0 (vector-dot (-> self control transv) gp-0))
            ;       (< (-> self control surface-angle) 0.5))
            ;  (let ((f30-0 (if (cpad-hold? (-> self control cpad number) l1)
            ;                 (* (-> self board charge-progress) (-> *TARGET_BOARD-bank* charge-jump-height))
            ;                 0.0)))
            ;    (sound-play "board-launch")
            ;    (when (!= (-> self board charge-progress) 0.0)
            ;      (part-tracker-spawn part-tracker
            ;                          :to
            ;                          self
            ;                          :group
            ;                          group-board-launch
            ;                          :mat-joint
            ;                          (-> self node-list data 0 bone transform)))
            ;    (set-time! (-> self board halfpipe-jump-time))
            ;    (set! (-> self board charge-progress) 0.0)
            ;    (sound-stop (-> self board charge-sound-id))
            ;    (vector-float*! (-> self control transv)
            ;                    (-> self control transv)
            ;                    (+ 1.0 f30-0 (/ (-> *setting-control* user-current halfpipe-jump-mult) 2)))))
            (else
             (flush-trick-list (-> self board))
             (deg-diff (vector-y-angle (-> self control unknown-matrix01 fvec)) (vector-y-angle (-> self control unknown-vector20)))
             (go target-board-jump
                 (-> *TARGET_BOARD-bank* duck-jump-height-min)
                 (-> *TARGET_BOARD-bank* duck-jump-height-max)
                 *board-duck-jump-mods*)))))
      (if (cpad-pressed? (-> self control cpad number) r1) (set-time! (-> self board spin-ground-press-time)))
      (if (and (cpad-hold? (-> self control cpad number) r1)
               (can-feet?)
               (not (time-elapsed? (-> self board spin-ground-press-time) (seconds 0.3)))
               (board-turn-around?))
        (set-time! (-> self board spin-ground-start-time)))
      (target-board-halfpipe-check)
      (if (target-board-smack-surface?) 0)
      (target-board-anim-trans)
      (set! (-> self board turn-anim-duck-vel) 8.0)
      (cond
        ((board-on-ground?)
         (target-board-ground-check)
         (set! (-> self control mod-surface) *board-duck-mods*)
         (set! (-> self board mods-backup) (-> self control mod-surface)))
        ((and (time-elapsed? (-> self control unknown-dword11) (seconds 0.1))
              (or (= (-> self control mod-surface name) 'spin) (< (meters 1) (target-height-above-ground))))
         (set! (-> self control mod-surface) *board-duck-jump-mods*)
         (set! (-> self board mods-backup) (-> self control mod-surface))
         (target-board-spin-check))
        (else
         (set! (-> self control mod-surface) *board-air-mods*)
         (set! (-> self board mods-backup) (-> self control mod-surface)))))
  :code
    (-> target-board-stance
        code)
  :post target-board-post)

(defstate target-board-launch (target)
  :event
    (behavior ((proc process) (argc int) (message symbol) (block event-message-block))
      (if (and (= message 'query) (= (-> block param 0) 'mode)) 'target-launch (target-board-handler proc argc message block)))
  :code
    (behavior ((arg0 float) (arg1 (state camera-slave)) (arg2 vector) (arg3 time-frame))
      (set-time! (-> self state-time))
      ; (set! (-> self board turn-anim-duck) 1.0)
      ; (set! (-> self board turn-anim-duck-vel) 15.0)
      ; (set! (-> self control unknown-surface00) *turn-around-mods*)
      ; (ja-channel-push! 1 (seconds 0.15))
      ; ; (set-forward-vel 0.0)
      ; (ja-no-eval :group! eichar-duck-stance-ja :num! (seek! (ja-aframe 15.0 0) 3.0) :frame-num 0.0)
      ; (until (ja-done? 0)
      ;   (suspend)
      ;   (ja :num! (seek! (ja-aframe 15.0 0) 3.0)))
      (if arg1 (send-event *camera* 'change-state arg1 (seconds 0.3)))
      (if (nonzero? arg3)
        (process-spawn-function process
          (lambda :behavior process ((arg0 vector) (arg1 time-frame) (arg2 float))
            (let ((sv-32 (current-time))
                  (v1-2 (new-stack-vector0)))
              (vector-copy! v1-2 arg0)
              (let ((sv-40 v1-2)
                    (sv-44 #t))
                (until (time-elapsed? sv-32 arg1)
                  (let ((targ (the target (ppointer->process (-> self parent)))))
                    (cond
                      ((and sv-44 (< (- (-> targ control trans y) (-> targ control last-trans-any-surf y)) arg2))
                       (vector-xz-normalize! (-> targ control transv) 0.0)
                       (when (< (vector-vector-xz-distance (-> targ control trans) sv-40) (meters 5))
                         (let ((v1-16 (vector-! (new-stack-vector0) (-> targ control trans) sv-40)))
                           (set! (-> targ control trans x) (+ (-> sv-40 x) (fmax (meters -0.7) (fmin (meters 0.7) (-> v1-16 x)))))
                           (set! (-> targ control trans z) (+ (-> sv-40 z) (fmax (meters -0.7) (fmin (meters 0.7) (-> v1-16 z))))))))
                      (else
                       (if sv-44 (set! sv-32 (current-time)))
                       (false! sv-44)
                       (when (or (= (-> targ next-state name) 'target-board-jump) (= (-> targ next-state name) 'target-board-falling))
                         (let ((trans (-> targ control trans))
                               (transv (-> targ control transv)))
                           (set! (-> transv x) (- (-> sv-40 x) (-> trans x)))
                           (set! (-> transv z) (- (-> sv-40 z) (-> trans z)))
                           (let ((vel (vector-xz-length transv)))
                             (if (< (meters 30) vel) (vector-xz-normalize! transv (meters 30)))
                             (if (< (meters 1) vel)
                               (forward-up-nopitch->quaternion (-> targ control dir-targ)
                                                               (vector-normalize-copy! (new 'stack-no-clear 'vector) transv 1.0)
                                                               (vector-y-quaternion! (new 'stack-no-clear 'vector) (-> targ control quat))))))))))
                  (suspend))))
            #f)
          arg2
          arg3
          (meters 35)
          :to
          self))
      (sound-play "launch-fire")
      (go target-board-launch-jump arg0 arg0))
  :post target-board-post)

(defstate target-board-jump (target)
  :event
    (behavior ((proc process) (argc int) (message symbol) (block event-message-block))
      (case message
        (('edge-grab)
         ; (if (and (= message 'edge-grab) (not (time-elapsed? (-> self state-time) (seconds 0.1)))) (return #f))
         (if (not (time-elapsed? (-> self state-time) (seconds 0.1))) (return #f)))
        (else (target-board-handler proc argc message block))))
  :enter
    (behavior ((arg0 meters) (arg1 meters) (arg2 surface))
      (when (= (-> self control unknown-symbol40) 'launch)
        (go target-board-launch
            (the-as float (-> self control unknown-dword60))
            (the-as (state camera-slave) (-> self control unknown-dword61))
            (vector-copy! (-> self control unknown-vector102) (the vector (-> self control unknown-dword62)))
            (-> self control unknown-dword63)))
      (when (= arg2 'hit)
        (logclear! (-> self state-flags) (state-flags being-attacked))
        (set! arg2 (the surface #f)))
      (when (not (time-elapsed? (-> self board ride-time) (seconds 0.5)))
        (set! arg2 *board-ride-jump-mods*)
        (let ((s2-0 (vector-normalize-copy! (new 'stack-no-clear 'vector) (-> self control transv) 1.0)))
          (forward-up-nopitch->quaternion (-> self control dir-targ)
                                          s2-0
                                          (vector-y-quaternion! (new-stack-vector0) (-> self control dir-targ)))
          (set! (-> self control turn-lockout-end-time)
                (+ (current-time) (the int (lerp-scale 225.0 0.0 (vector-dot s2-0 (-> self control unknown-matrix01 fvec)) -1.0 1.0))))))
      (set! (-> self control dynam gravity-length) (meters 60))
      (set-time! (-> self state-time))
      (let ((f30-0 0.0))
        (when (and (cpad-hold? (-> self control cpad number) l1) (!= (-> self board charge-progress) 0.0))
          (+! f30-0 (* (-> self board charge-progress) (-> *TARGET_BOARD-bank* charge-jump-height)))
          (sound-play "board-launch")
          (process-spawn part-tracker
                         :init
                         part-tracker-init
                         group-board-launch
                         -1
                         #f
                         #f
                         #f
                         (-> self node-list data 0 bone transform trans)
                         :to
                         self))
        (set! (-> self board charge-progress) 0.0)
        (sound-stop (-> self board charge-sound-id))
        (cond
          ((and (< 0.0 (-> self board shock-offsetv))
                (not (time-elapsed? (-> self board jump-land-time) (seconds 0.5)))
                (time-elapsed? (-> self board ride-time) (seconds 0.5)))
           (let ((s3-5 (new 'stack-no-clear 'vector)))
             ; (vector-copy! s3-5 (-> self control trans))
             ; (+! (-> s3-5 y) (meters 0.5))
             ; (vector-copy! (-> *launch-matrix* trans) s3-5)
             ; (part-tracker-spawn part-tracker :to self :group group-board-quick-jump)
             ; (let ((s2-4 (process-spawn manipy
             ;                            :init
             ;                            manipy-init
             ;                            s3-5
             ;                            (-> self entity)
             ;                            (art-group-get-by-name *level* "skel-generic-blast" (the (pointer level) #f))
             ;                            #f
             ;                            0
             ;                            :name "manipy"
             ;                            :to
             ;                            self
             ;                            :stack-size #x20000)))
             ;   (when s2-4
             ;     (quaternion-copy! (-> (the process-drawable (-> s2-4 0)) root quat) (-> self control quat-for-control))
             ;     (send-event (ppointer->process s2-4) 'anim-mode 'play1)
             ;     (send-event (ppointer->process s2-4) 'anim "idle")
             ;     (send-event (ppointer->process s2-4) 'speed 1.5)
             ;     (set-vector! (-> (the process-drawable (-> s2-4 0)) root scale) 0.2 0.4 0.2 1.0)))
             )
           (set! f30-0 (+ (meters 2) f30-0))
           (add-to-trick-list (-> self board) (board-tricks board-quick-jump) 0.0)
           (sound-play "board-q-jump"))
          (else
           (if (= arg2 *board-duck-jump-mods*)
             (add-to-trick-list (-> self board) (board-tricks board-duck-jump) 0.0)
             (add-to-trick-list (-> self board) (board-tricks board-jump) 0.0))
           (set! (-> self board jump-sound-id) (sound-play "board-jump"))))
        (init-var-jump-board (+ arg0 f30-0)
                             (+ arg1 f30-0)
                             #t
                             #f
                             (-> self control transv)
                             (if (time-elapsed? (-> self board last-jump-time) (seconds 0.1)) 2.0 0.0)))
      (logclear! (-> self control status) (cshape-moving-flags onsurf onground tsurf))
      (set! arg2
            (cond
              (arg2 arg2)
              (else *board-jump-mods*)))
      (set! (-> self control mod-surface) (the surface arg2))
      (set! (-> self board mods-backup) (-> self control mod-surface))
      (set! (-> self board shock-offsetv) 0.0)
      (set! (-> self control unknown-float123)
            (fmax 0.0 (fmin 1.0 (* 0.00004359654 (+ -11468.8 (-> self control ctrl-xz-vel))))))
      (vector-copy! (-> self board slow-transv) (-> self control transv)))
  :exit target-board-exit
  :trans
    (behavior ()
      (when (and (cpad-pressed? (-> self control cpad number) square)
                 (and (= (-> self fact eco-type) (pickup-type eco-yellow)) (>= (-> self fact eco-level) 1.0))
                 (time-elapsed? (-> self control unknown-dword82) (seconds 0.45)))
        (process-spawn projectile-yellow
                       :init
                       projectile-init-by-other
                       (-> self entity)
                       (-> self control unknown-vector90)
                       (vector-float*! (new 'stack-no-clear 'vector)
                                       (vector-z-quaternion! (new 'stack-no-clear 'vector) (-> self control quat))
                                       (-> *TARGET-bank* yellow-projectile-speed))
                       (if (>= (-> self fact eco-level) (-> *FACT-bank* eco-level-max)) 16 0)
                       #f
                       :to
                       self)
        (set-time! (-> self control unknown-dword82))
        ; (go target-board-yellow-jump-blast)
        )
      (target-board-jump-trans)
      (set! (-> self control unknown-float123)
            (fmax (-> self control unknown-float123)
                  (* 0.003921569 (the float (-> *cpad-list* cpads (-> self control cpad number) abutton (abutton-idx x))))))
      (mod-var-jump-board #t #f (cpad-hold? (-> self control cpad number) x) (-> self control transv))
      (vector-copy! (-> self board slow-transv) (-> self control transv))
      (set! (-> self board shock-offset) (* 0.8 (-> self board shock-offset))))
  :code
    (behavior ((arg0 meters) (arg1 meters) (arg2 surface))
      (cond
        ((= arg2 (the surface 'hit))
         (ja-channel-push! 1 (seconds 0.05))
         (ja-no-eval :group! eichar-board-hit-ja :num! (seek!) :frame-num 0.0)
         (until (ja-done? 0)
           (suspend)
           (ja :num! (seek!)))
         (ja-channel-push! 1 (seconds 0.05)))
        ((or (= arg2 (the surface 'launch)) (>= (the-as float (-> self control unknown-uint20)) (meters 5)))
         (ja-channel-push! 1 (seconds 0.05))
         (ja :group! eichar-board-jump-high-ja :num! min)
         (suspend)
         (until (ja-done? 0)
           (let* ((vel-dir (vector-dot (-> self control dynam gravity-normal) (-> self control transv)))
                  (frame (- 25.0 (ja-aframe-num 0)))
                  (going-down? (and (< 0.0 vel-dir) (< 0.0 frame)))
                  (anim-speed (cond
                                (going-down? (fmin (fmin 1.5 frame) (/ (* 2.0 frame) (the float (time-to-apex vel-dir (meters -60))))))
                                ((< (seconds 0.165) (target-time-to-ground)) 1.5)
                                (else 0.8))))
             (ja :num! (seek! max anim-speed)))
           (suspend))
         (ja-channel-push! 1 (seconds 0.05)))
        (else
         (ja-channel-push! 1 (seconds 0.05))
         (ja :group! eichar-board-jump-ja :num! min)
         (suspend)
         (until (ja-done? 0)
           (let* ((vel-dir (vector-dot (-> self control dynam gravity-normal) (-> self control transv)))
                  (frame (- 10.0 (ja-aframe-num 0)))
                  (going-down? (and (< 0.0 vel-dir) (< 0.0 frame)))
                  (anim-speed (cond
                                (going-down? (fmin (fmin 0.8 frame) (/ (* 10.0 frame) (the float (time-to-apex vel-dir (meters -60))))))
                                ((< (seconds 0.165) (target-time-to-ground)) 0.5)
                                (else 0.25))))
             ; (format 0
             ;         "frame ~,,2f~%going-down? ~A~%anim-speed ~,,2f~%tta ~,,2f~%"
             ;         frame
             ;         going-down?
             ;         anim-speed
             ;         (the float (time-to-apex vel-dir (meters -60))))
             (ja :num! (seek! max anim-speed)))
           (suspend))
         (ja-channel-push! 1 (seconds 0.05))))
      (ja :group! eichar-board-jump-loop-ja)
      (until #f
        (suspend)
        (ja :num! (loop!)))
      #f)
  :post target-board-post)

(defstate target-board-launch-jump (target)
  :event
    (-> target-board-jump
        event)
  :enter
    (behavior ((arg0 float) (arg1 float))
      (set-time! (-> self state-time))
      (sound-play "board-launch")
      (process-spawn part-tracker
                     :init
                     part-tracker-init
                     group-board-launch
                     -1
                     #f
                     #f
                     #f
                     (-> self node-list data 0 bone transform trans)
                     :to
                     self)
      (init-var-jump-board arg0 arg1 #t #f (-> self control transv) 0.0)
      (logclear! (-> self control status) (cshape-moving-flags onsurf onground tsurf))
      (set! (-> self neck flex-blend) 0.0)
      ; (set! (-> self control unknown-surface00) *launch-jump-mods*)
      )
  :exit target-board-exit
  :trans
    (behavior ()
      ((-> target-board-jump trans))
      (case (-> self control unknown-int37)
        (('launch)
         (let ((snd (the sound-rpc-set-param (get-sound-buffer-entry))))
           (set! (-> snd command) (sound-command set-param))
           (set! (-> snd id) (-> self control unknown-soundid01))
           (let ((pos (ear-trans)))
             (when (= pos #t)
               (if (and self (type-type? (-> self type) process-drawable) (nonzero? (-> self control)))
                 (set! pos (-> self control trans))
                 (set! pos (the vector #f))))
             (sound-trans-convert (-> snd parms trans) pos))
           (set! (-> snd parms mask) (sound-mask trans))
           (-> snd id)))))
  :code
    (behavior ((arg0 float) (arg1 float))
      (ja-channel-push! 1 (seconds 0.05))
      (ja :group! eichar-board-jump-high-ja :num! min)
      (suspend)
      (until (ja-done? 0)
        (let* ((vel-dir (vector-dot (-> self control dynam gravity-normal) (-> self control transv)))
               (frame (- 25.0 (ja-aframe-num 0)))
               (going-down? (and (< 0.0 vel-dir) (< 0.0 frame)))
               (anim-speed (cond
                             (going-down? (fmin (fmin 1.5 frame) (/ (* 5.0 frame) (the float (time-to-apex vel-dir (meters -60))))))
                             ((< (seconds 0.165) (target-time-to-ground)) 1.5)
                             (else 0.8))))
          (ja :num! (seek! max anim-speed)))
        (suspend))
      (ja-channel-push! 1 (seconds 0.05))
      (ja-no-eval :group! eichar-board-jump-loop-ja :num! (loop! 1.0) :frame-num 0.0)
      (loop
        (suspend)
        (ja :group! eichar-board-jump-loop-ja :num! (loop! 1.0))))
  :post target-board-post)

(defstate target-board-halfpipe (target)
  :event
    (behavior ((proc process) (argc int) (message symbol) (block event-message-block))
      (case message
        (('edge-grab)
         (format #t "halfpipe found edge ~m~%" (vector-dot (-> self control dynam gravity-normal) (-> self control transv)))
         (set! (-> self control unknown-uint20) (the uint #t))
         (let ((v1-6 *edge-grab-info*))
           (vector-normalize! (vector-! (-> self control unknown-vector100) (-> v1-6 world-vertex 0) (-> v1-6 world-vertex 1)) 1.0))
         (vector-cross! (-> self control unknown-vector101)
                        (-> self control unknown-vector100)
                        (-> self control dynam gravity-normal))
         (let ((v1-11 (new-stack-vector0)))
           (let ((f0-2 (vector-dot (-> self control unknown-vector101) (-> self control transv))))
             0.0
             (vector-! v1-11 (-> self control transv) (vector-float*! v1-11 (-> self control unknown-vector101) f0-2)))
           (let* ((f0-3 (vector-length v1-11))
                  (f1-1 f0-3)
                  (f2-0 -2048.0))
             (vector+! (-> self control transv)
                       (vector-float*! (-> self control transv) (-> self control unknown-vector101) f2-0)
                       (vector-float*! v1-11 v1-11 (/ f0-3 f1-1))))))
        (('ramp)
         (when (not (-> self control unknown-int21))
           (let ((v0-3 (the object #t))) (set! (-> self control unknown-int21) (the-as int v0-3)) v0-3)))
        (else (target-board-handler proc argc message block))))
  :enter
    (behavior ()
      ; (logior! (-> self focus-status) (focus-status halfpipe))
      ; (set-time! (-> self state-time))
      ; (logior! (-> self control root-prim prim-core action) (collide-action no-normal-reset))
      ; (set! (-> self control mod-surface) *board-halfpipe-mods*)
      ; (set! (-> self board mods-backup) (-> self control mod-surface))
      ; (set! (-> self control sliding-start-time) 0)
      ; (when (< (vector-dot (-> self control unknown-matrix01 uvec) (-> self control dynam gravity-normal)) 0.7)
      ;   (vector-matrix*! (-> self control unknown-vector00) (-> self control transv) (-> self control w-R-c))
      ;   (set! (-> self control unknown-vector00 y) 0.0)
      ;   (vector-matrix*! (-> self control transv) (-> self control unknown-vector00) (-> self control unknown-matrix01)))
      ; (set! (-> self control unknown-uint20) (the-as uint #f))
      ; (set! (-> self control unknown-int21) (the-as float #f))
      ; (target-method-28 *target* *collide-cache* *collide-edge-board-halfpipe-spec*)
      ; (when (not (-> self control unknown-spoolanim00))
      ;   (let ((gp-0 (vector-flatten! (-> self control unknown-vector101)
      ;                                (-> self control dynam gravity-normal)
      ;                                (-> self control unknown-vector53))))
      ;     (set! (-> gp-0 y) 0.0)
      ;     (vector-normalize! gp-0 1.0)
      ;     (vector-rotate-y! (-> self control unknown-vector100) (-> self control unknown-vector101) 16384.0)
      ;     (let ((v1-40 (new-stack-vector0)))
      ;       (let ((f0-5 (vector-dot gp-0 (-> self control transv))))
      ;         0.0
      ;         (vector-! v1-40 (-> self control transv) (vector-float*! v1-40 gp-0 f0-5)))
      ;       (let* ((f0-6 (vector-length v1-40))
      ;              (f1-2 f0-6)
      ;              (f2-0 -2048.0))
      ;         (vector+! (-> self control transv)
      ;                   (vector-float*! (-> self control transv) gp-0 f2-0)
      ;                   (vector-float*! v1-40 v1-40 (/ f0-6 f1-2)))))))
      ; (if (or (< (vector-dot (-> self control dynam gravity-normal) (-> self control transv)) 20480.0)
      ;         (< (vector-dot (vector-z-quaternion! (new 'stack-no-clear 'vector) (-> self control quat-for-control))
      ;                        (vector-normalize-copy! (new 'stack-no-clear 'vector) (-> self control transv) 1.0))
      ;            0.3))
      ;   (go target-board-turn-to (-> self control transv) (seconds 0.5)))
      )
  :exit
    (behavior ()
      (if (not (and (-> self next-state)
                    (symbol-member? (-> self next-state name)
                                    '(target-board-flip target-board-hold target-board-trickx target-board-tricky target-board-grenade target-board-falling))))
        0 ; (logclear! (-> self focus-status) (focus-status halfpipe))
        )
      (send-event *camera* 'relative-position #f)
      ; (remove-setting! 'matrix-blend-max-angle)
      ; (remove-setting! 'matrix-blend-max-partial)
      (logclear! (-> self control root-prim prim-core action) (collide-action no-normal-reset))
      (target-board-exit))
  :trans
    (behavior ()
      (when (and (or (= (the-as int (-> self control unknown-int21)) #t)
                     (and (not (time-elapsed? (-> self board halfpipe-lip-time) (seconds 0.1)))
                          (= (-> self board halfpipe-lip-event) 'lipramp)))
                 (< 0.0 (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
        (set! (-> self control unknown-int21) (the-as int 'done))
        (let ((v1-16 (new-stack-vector0))
              (f0-2 (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
          (vector-! v1-16 (-> self control transv) (vector-float*! v1-16 (-> self control dynam gravity-normal) f0-2))
          (let* ((f1-4 (vector-length v1-16))
                 (f2-0 f1-4))
            (if (!= f1-4 0.0) (set! f1-4 0.0))
            (vector+! (-> self control transv)
                      (vector-float*! (-> self control transv) (-> self control dynam gravity-normal) f0-2)
                      (vector-float*! v1-16 v1-16 (/ f1-4 f2-0))))))
      (set-time! (-> self board halfpipe-time))
      ; (if (= (-> self control gspot-pat-surfce mode) (pat-mode halfpipe)) (set-time! (-> self board halfpipe-gspot-time)))
      (when (jump-hit-ground-stuck?)
        (vector-float*! (-> self control transv) (-> self control transv) 1.5)
        (go target-board-turn-to (-> self control transv) (seconds 0.5)))
      (when (and (cpad-pressed? (-> self control cpad number) x)
                 (time-elapsed? (-> self board halfpipe-jump-time) (seconds 0.6))
                 (not (time-elapsed? (-> self state-time) (-> *TARGET-bank* ground-timeout)))
                 (< 0.0 (vector-dot (-> self control dynam gravity-normal) (-> self control transv))))
        (set-time! (-> self board halfpipe-jump-time))
        (vector-float*! (-> self control transv)
                        (-> self control transv)
                        1.0
                        #| (+ 1.0 (/ (-> *setting-control* user-current halfpipe-jump-mult) 2)) |#
                        ))
      (target-board-spin-check)
      ; (cond
      ;   ((> (-> self control sliding-start-time) 0)
      ;    (cond
      ;      ((< 0.7 (-> self control turn-to-magnitude))
      ;       (let ((gp-0 (new 'stack-no-clear 'vector)))
      ;         (vector-copy! gp-0 (-> self control unknown-vector101))
      ;         (set! (-> gp-0 y) 0.0)
      ;         (vector-normalize! gp-0 1.0)
      ;         (if (< 0.7 (vector-dot (-> self control unknown-vector20) gp-0))
      ;           (+! (-> self control sliding-start-time) (- (current-time) (-> self clock old-frame-counter)))
      ;           (set! (-> self control sliding-start-time) 1))))
      ;      (else (set! (-> self control sliding-start-time) 1))))
      ;   ((and (= (-> *cpad-list* cpads (-> self control cpad number) stick0-speed) 0.0)
      ;         (< (-> self board halfpipe-lip-time) (+ (-> self state-time) (seconds -0.2))))
      ;    (set! (-> self control sliding-start-time) 1)))
      ; (when (or (>= (-> self control sliding-start-time) (seconds 0.05))
      ;           (and (time-elapsed? (-> self board halfpipe-gspot-time) (seconds 0.5))
      ;                (< (-> self board halfpipe-lip-time) (+ (-> self state-time) (seconds -0.2)))))
      ;   (+! (-> self control transv x) (* 20480.0 (-> self control unknown-vector101 x)))
      ;   (+! (-> self control transv z) (* 20480.0 (-> self control unknown-vector101 z)))
      ;   (go target-board-stance))
      (target-board-halfpipe-trans))
  :code
    (behavior ()
      (cond
        ((not (time-elapsed? (-> self board halfpipe-jump-time) (seconds 0.5)))
         (ja-channel-push! 1 (seconds 0.05))
         (ja-no-eval :group! eichar-board-jump-ja :num! (seek! (ja-aframe 8.0 0) 0.5) :frame-num 0.0)
         (until (ja-done? 0)
           (suspend)
           (ja :num! (seek! (ja-aframe 8.0 0) 0.5)))
         (ja-no-eval :group! eichar-board-jump-ja :num! (seek! (ja-aframe 10.0 0) 0.2) :frame-num (ja-aframe 8.0 0))
         (until (ja-done? 0)
           (suspend)
           (ja :num! (seek! (ja-aframe 10.0 0) 0.2)))
         (ja-no-eval :group! eichar-board-jump-ja :num! (seek! (ja-aframe 12.0 0) 0.1) :frame-num (ja-aframe 10.0 0))
         (until (ja-done? 0)
           (suspend)
           (ja :num! (seek! (ja-aframe 12.0 0) 0.1)))
         (anim-loop))
        (else ((the (function none) (-> target-board-stance code))))))
  :post target-board-post)

(defstate target-board-falling (target)
  :event target-board-handler
  :enter
    (behavior ()
      (if (and (= *cheat-mode* 'debug) (cpad-hold? (-> self control cpad number) r2) (not *pause-lock*))
        (set! (-> self control mod-surface) *board-air-mods*)
        (set! (-> self control mod-surface) *board-jump-mods*))
      (set! (-> self board mods-backup) (-> self control mod-surface)))
  :exit
    (-> target-board-halfpipe
        exit)
  :trans
    (behavior ()
      (target-board-jump-trans)
      ; (if (focus-test? self halfpipe) (target-board-halfpipe-trans))
      (when (and (= *cheat-mode* 'debug) (and (cpad-hold? (-> self control cpad number) r2) (not *pause-lock*)))
        (set! (-> self control mod-surface) *board-air-mods*)
        (set! (-> self board mods-backup) (-> self control mod-surface))))
  :code
    (behavior ()
      (let ((v1-2 (ja-group)))
        (cond
          ((and v1-2 (= v1-2 eichar-board-jump-loop-ja)))
          ((let ((v1-8 (ja-group))) (and v1-8 (= v1-8 eichar-board-noseflip-ja)))
           (ja-no-eval :num! (seek!))
           (ja-channel-push! 1 (seconds 0.5)))
          ((let ((v1-22 (ja-group)))
             (and v1-22
                  (or (= v1-22 eichar-board-flip-backward-ja)
                      (= v1-22 eichar-board-flip-backward-loop-ja)
                      (= v1-22 eichar-board-flip-forward-ja)
                      (= v1-22 eichar-board-flip-forward-loop-ja))))
           (ja-no-eval :num! (seek!))
           (ja-channel-push! 1 (seconds 0.2)))
          (else
           (let ((v1-36 (ja-group)))
             (cond
               ((and v1-36 (= v1-36 eichar-board-spin-ja)) (ja-no-eval :num! (seek!)) (ja-channel-push! 1 (seconds 0.1)))
               (else (ja-channel-push! 1 (seconds 0.5))))))))
      (cond
        (#f ; (focus-test? self halfpipe)
         (ja :group! eichar-board-duck-turn-ja :num! (identity (ja-aframe 0.0 0)))
         (loop
           (suspend)
           (ja-blend-eval)))
        (else (ja :group! eichar-board-jump-loop-ja) (loop (suspend) (ja-blend-eval) (ja :num! (loop!))))))
  :post target-board-post)

(defstate target-board-jump-kick (target)
  :event target-board-handler
  :enter
    (behavior ()
      (set-time! (-> self state-time))
      (set! (-> self control mod-surface) *board-jump-mods*)
      (set! (-> self board mods-backup) (-> self control mod-surface))
      (sound-play "board-k-jump"))
  :exit target-board-exit
  :trans
    (behavior ()
      (if (jump-hit-ground-stuck?) (go target-board-hit-ground))
      (target-board-smack-surface?)
      (cond
        ((not (time-elapsed? (-> self board smack-surface-time) (seconds 0.2)))
         (go target-board-wall-kick (-> self board smack-normal) (-> self board smack-speed)))
        ((not (time-elapsed? (-> self board glance-time) (seconds 0.2)))
         (go target-board-wall-kick
             (vector-normalize-copy! (-> self control unknown-vector103) (-> self board glance-out-transv) 1.0)
             (-> self board glance-speed)))))
  :code
    (behavior ()
      (ja-channel-push! 1 (seconds 0.1))
      (ja-no-eval :group! eichar-board-jump-kick-ja :num! (seek!) :frame-num 0.0)
      (until (ja-done? 0)
        (suspend)
        (ja :num! (seek!)))
      (ja-channel-push! 1 (seconds 2))
      (ja :group! eichar-board-jump-loop-ja)
      (until #f
        (suspend)
        (ja :num! (loop!)))
      #f)
  :post target-board-post)

(defstate target-board-wall-kick (target)
  :event target-board-handler
  :enter
    (behavior ((arg0 vector) (arg1 float))
      (sound-play "board-kick")
      (vector-copy! (-> self control transv) arg0)
      (vector-xz-normalize! (-> self control transv) (* 0.8 arg1))
      (set! (-> self control unknown-uint20) (the-as uint (fmax (meters 20) (* 0.8 arg1))))
      (vector-copy! (-> self control unknown-vector103) arg0)
      (set! (-> self control transv y) 0.0)
      (vector-turn-to (vector-negate! (new 'stack-no-clear 'vector) (-> self control transv)))
      (set! (-> self control transv y)
            (- (sqrtf (* (meters 6) (-> self control dynam gravity-length)))
               (* 0.008333334 (- (-> self control dynam gravity-length)))))
      (set-time! (-> self state-time))
      (set! (-> self control mod-surface) *board-wall-kick-mods*)
      (set! (-> self board mods-backup) (-> self control mod-surface))
      (set! (-> self board smack-surface-time) 0))
  :exit target-board-exit
  :trans target-board-jump-trans
  :code
    (behavior ((arg0 vector) (arg1 float))
      (ja-no-eval :group! eichar-board-jump-kickoff-ja :num! (seek!) :frame-num 0.0)
      (until (ja-done? 0)
        (if (and (jump-hit-ground-stuck?) (< 31.0 (ja-aframe-num 0))) (go target-board-hit-ground))
        (let ((v1-21 (-> self control unknown-vector103)))
          (set! (-> self control transv x) (-> v1-21 x))
          (set! (-> self control transv z) (-> v1-21 z)))
        (vector-xz-normalize! (-> self control transv) (the-as float (-> self control unknown-uint20)))
        (compute-alignment! (-> self align))
        (align! (-> self align) (align-opts adjust-quat) 1.0 1.0 1.0)
        (suspend)
        (ja :num! (seek!)))
      (go target-board-falling))
  :post target-board-post)

(defstate target-board-flip (target)
  :event
    (-> target-board-jump
        event)
  :enter
    (behavior ((arg0 float) (arg1 float) (arg2 symbol))
      (set! (-> self control unknown-uint20) (the-as uint arg2))
      (forward-up-nopitch->quaternion (-> self control dir-targ)
                                      (-> self control transv)
                                      (vector-y-quaternion! (new 'stack-no-clear 'vector) (-> self control dir-targ)))
      (set! (-> self control dynam gravity-length) (meters 60))
      (set-time! (-> self state-time))
      (cond
        (#f ; (= arg2 'halfpipe) (logior! (-> self focus-status) (focus-status halfpipe)) (target-board-halfpipe-trans)
         )
        (else
         (init-var-jump-board arg0 arg1 #t #f (-> self control transv) 1.0)
         (logclear! (-> self control status) (cshape-moving-flags onsurf onground tsurf))
         (set! (-> self control unknown-float123)
               (fmax 0.0 (fmin 1.0 (* 0.00004359654 (+ -11468.8 (-> self control ctrl-xz-vel))))))))
      (set! (-> self control mod-surface) *board-flip-mods*)
      (set! (-> self board mods-backup) (-> self control mod-surface))
      (let ((snd (the sound-rpc-set-param (get-sound-buffer-entry))))
        (set! (-> snd command) (sound-command set-param))
        (set! (-> snd id) (-> self board jump-sound-id))
        (set! (-> snd parms volume) -4)
        (set! (-> snd auto-time) 72)
        (set! (-> snd auto-from) 2)
        (set! (-> snd parms mask) (sound-mask volume time))
        (-> snd id))
      (set! (-> self board unknown-sound-id00) (sound-play "board-flip"))
      (target-start-attack)
      (target-danger-set! 'board-spin #f))
  :exit
    (behavior ()
      (target-danger-set! 'harmless #f)
      (set! (-> self board flip-control) 0.0)
      (add-to-trick-list (-> self board)
                         (board-tricks board-flip)
                         (+ (* 500.0 (the float (-> self board flip-count))) (if (>= (-> self board flip-count) 2) 2000.0 0.0)))
      (let ((v1-9 (the sound-rpc-set-param (get-sound-buffer-entry))))
        (set! (-> v1-9 command) (sound-command set-param))
        (set! (-> v1-9 id) (-> self board unknown-sound-id00))
        (set! (-> v1-9 parms volume) -4)
        (set! (-> v1-9 auto-time) 24)
        (set! (-> v1-9 auto-from) 2)
        (set! (-> v1-9 parms mask) (sound-mask volume time))
        (-> v1-9 id))
      ((-> target-board-halfpipe exit)))
  :trans
    (behavior ()
      (cond
        (#f ; (= (-> self control unknown-spoolanim00) 'halfpipe) (target-board-halfpipe-trans)
         )
        (else
         (set! (-> self control unknown-float123)
               (fmax (-> self control unknown-float123)
                     (* 0.003921569 (the float (-> *cpad-list* cpads (-> self control cpad number) abutton (abutton-idx x))))))
         (mod-var-jump-board #t #f (cpad-hold? (-> self control cpad number) x) (-> self control transv))))
      (vector-copy! (-> self board slow-transv) (-> self control transv)))
  :code
    (behavior ((arg0 float) (arg1 float) (arg2 symbol))
      (let ((gp-0 (>= (-> self board flip-control) 0.0)))
        (let ((s5-0 (new 'stack-no-clear 'vector)))
          (set! (-> s5-0 x) 0.0)
          (set! (-> s5-0 y) 0.0)
          (set! (-> s5-0 z) (* -0.0078125 (+ -128.0 (the float (-> self control cpad lefty)))))
          (set! (-> s5-0 w) 1.0)
          (let ((f0-9 (analog-input (the int (* 128.0 (-> s5-0 z))) 0.0 96.0 110.0 1.0))
                (s4-0 0))
            (while (not (and (or (not (cpad-hold? (-> self control cpad number) r1))

(defun board-charge-track ((arg0 sparticle-system) (arg1 sparticle-cpuinfo) (arg2 vector))
  (when *target*
    (let ((board-pos (vector<-cspace! (new-stack-vector0) (-> *target* node-list data 47))))
      (set! (-> arg2 x) (-> board-pos x))
      (set! (-> arg2 y) (-> board-pos y))
      (set! (-> arg2 z) (-> board-pos z))))
  (none))

(defun board-zap-track ((arg0 sparticle-system) (arg1 sparticle-cpuinfo) (arg2 vector))
  (let* ((pd (the process-drawable (ppointer->process (-> arg1 key proc parent))))
         (joint-idx (the int (-> arg1 user-float)))
         (pos (vector<-cspace! (new-stack-vector0) (-> pd node-list data joint-idx))))
    (set! (-> arg2 x) (-> pos x))
    (set! (-> arg2 y) (-> pos y))
    (set! (-> arg2 z) (-> pos z)))
  (none))

